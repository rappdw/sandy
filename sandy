# harness via `sandy --print-protected-paths`.
_sandy_protected_files() {
    cat <<'EOF'
.bashrc
.bash_profile
.zshrc
.zprofile
.profile
.gitconfig
.ripgreprc
.mcp.json
.envrc
.tool-versions
.mise.toml
.nvmrc
.node-version
.python-version
.ruby-version
.npmrc
.yarnrc
.yarnrc.yml
.pypirc
.netrc
.pre-commit-config.yaml
EOF
}
# Top-level .git files that can trigger host-side code execution if tampered.
# Separate list because gated on -f instead of -e.
_sandy_protected_git_files() {
    cat <<'EOF'
.git/config
.gitmodules
.git/HEAD
.git/packed-refs
EOF
}
# Protected directories. .github/workflows is included by default; opt out via
# SANDY_ALLOW_WORKFLOW_EDIT=1 in .sandy/config (passive tier).
_sandy_protected_dirs() {
    cat <<'EOF'
.git/hooks
.git/info
.vscode
.idea
.circleci
.devcontainer
EOF
    [ "${SANDY_ALLOW_WORKFLOW_EDIT:-0}" = "1" ] || echo ".github/workflows"
}

# True (0) only for git scaffolding that is INERT by construction, so the
# session-end warning can suppress it (#12). Narrow + enumerated on purpose —
# this is a suppression path in a security feature. Operates on a workspace-
# relative protected-dir path ($1) under $WORK_DIR.
#   .git/hooks (and submodule hooks/): inert IFF every entry ends in `.sample`
#     (git never executes a `.sample` hook). A real/executable hook → NOT inert.
#   .git/info: inert IFF its ONLY entry is `exclude` (gitignore-syntax template).
#     `attributes` present → NOT inert (filter-driver injection vector).
_sandy_dir_is_inert_git() {
    local rel="$1" full="$WORK_DIR/$1" e had=1
    case "$rel" in
        .git/hooks|*/hooks)
            for e in "$full"/* "$full"/.*; do
                [ -e "$e" ] || continue
                case "${e##*/}" in .|..) continue ;; esac
                had=0
                case "$e" in *.sample) ;; *) return 1 ;; esac
            done
            return $had ;;   # 0 only if there was ≥1 entry and all were *.sample
        .git/info)
            [ "$(ls -A "$full" 2>/dev/null)" = "exclude" ] && return 0
            return 1 ;;
    esac
    return 1
}

# Debug flag for test harness — print the three protected-path lists and exit.
# Format: one path per line, prefixed by "file:", "gitfile:", or "dir:".
# Reads SANDY_ALLOW_WORKFLOW_EDIT from the environment (not from .sandy/config).
if [[ "${1:-}" == "--print-protected-paths" ]]; then
    while IFS= read -r _p; do [ -n "$_p" ] && echo "file:$_p"; done < <(_sandy_protected_files)
    while IFS= read -r _p; do [ -n "$_p" ] && echo "gitfile:$_p"; done < <(_sandy_protected_git_files)
    while IFS= read -r _p; do [ -n "$_p" ] && echo "dir:$_p"; done < <(_sandy_protected_dirs)
    exit 0
fi

# --- Introspection: machine-readable schema / state / validation ---
# Emits JSON on stdout. All three flags are non-interactive and exit before
# Docker or network checks. The schema contract is SPEC_INTROSPECTION.md.

# Pipe-separated metadata table: key|type|default|pattern|description.
# Types: string | int | bool | secret | enum:v1,v2 | agent_combo.
# Empty fields are allowed (e.g. no default, no pattern).
_sandy_key_metadata() {
    cat <<'EOF'
SANDY_SSH|enum:token,agent|token||0.1.0|stable|SSH auth mode: 'token' uses gh CLI (HTTPS); 'agent' forwards the host SSH agent.
SANDY_SKIP_PERMISSIONS|bool|true||0.1.0|stable|Skip Claude Code's in-session permission prompts (default: true).
SANDY_ALLOW_NO_ISOLATION|bool|0||0.1.0|stable|Allow launch when iptables rules cannot be applied (Linux only).
SANDY_ALLOW_LAN_HOSTS|string|||0.7.9|stable|Comma-separated IPs/CIDRs to allow through LAN isolation. World-open entries rejected.
SANDY_LOCAL_LLM_HOST|string||^[^[:space:]]+:[0-9]+$|0.12.0|stable|Single host:port (e.g. '127.0.0.1:11434') to allow through LAN isolation, typically for a local LLM. With the egress proxy on (default) the proxy's forward listener relays host.docker.internal:<port> to the host; with the proxy off (=0, Linux) it inserts one iptables ACCEPT and maps host.docker.internal.
SANDY_ALLOW_HOSTS|string|||0.14.0|stable|Comma-separated extra egress-proxy allowlist entries (exact host, '*.suffix' wildcard, or 'host:port' for CONNECT/SSH). Appended to the built-in default allowlist. In strict mode (SANDY_EGRESS_PROXY=2) these are the only hosts reachable beyond defaults; in permissive mode (=1) they are LAN-exceptions reachable despite the private-IP block. Privileged tier so workspace config requires approval.
