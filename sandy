# sandy-ss-paths: agent-agnostic helper for the /ss screenshot skill.
# Lists newest N image paths from $SANDY_SCREENSHOTS_PATH (default 1). Used
# internally by the per-agent /ss skill files; also a manual escape hatch
# for opencode (which has no slash-command surface in v0).
RUN cat > /usr/local/bin/sandy-ss-paths <<'SS_HELPER' \
    && chmod +x /usr/local/bin/sandy-ss-paths
#!/bin/bash
# Usage: sandy-ss-paths [N]   (default N=1)
# Emits one absolute image path per line, newest first.
set -uo pipefail
N="${1:-1}"
case "$N" in
    ''|*[!0-9]*) echo "usage: sandy-ss-paths [N]   (N must be a positive integer)" >&2; exit 2 ;;
esac
DIR="${SANDY_SCREENSHOTS_PATH:-}"
if [ -z "$DIR" ] || [ ! -d "$DIR" ]; then
    echo "sandy-ss-paths: screenshot directory not configured." >&2
    echo "  Set SANDY_SCREENSHOT_DIR=<host-path> in ~/.sandy/config and relaunch sandy." >&2
    exit 1
fi
# Glob all common screenshot/image extensions, case-insensitive. Skip dotfiles.
shopt -s nullglob nocaseglob
files=( "$DIR"/*.png "$DIR"/*.jpg "$DIR"/*.jpeg "$DIR"/*.webp "$DIR"/*.heic "$DIR"/*.gif )
shopt -u nullglob nocaseglob
if [ "${#files[@]}" -eq 0 ]; then
    echo "sandy-ss-paths: no images found in $DIR" >&2
    exit 1
fi
# Sort by mtime newest-first, take N. printf %T@ then strip the timestamp.
printf '%s\0' "${files[@]}" \
    | xargs -0 stat -c '%Y %n' \
    | sort -rn \
    | head -n "$N" \
    | cut -d' ' -f2-
SS_HELPER

# User
RUN useradd -m -s /bin/bash -u 1001 claude

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PATH="/home/claude/.local/bin:/usr/local/cargo/bin:/usr/local/go/bin:$PATH"
DOCKERFILE_BASE
}

