fi

FULL_HASH="$(printf '%s' "$WORK_DIR" | sha256)"
FULL_HASH="${FULL_HASH%% *}"
SHORT_HASH="${FULL_HASH:0:8}"
# Sanitize the directory basename for use in the sandbox name
