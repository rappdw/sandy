RUN_FLAGS+=(-v "$SANDBOX_DIR/go:/home/claude/go")
RUN_FLAGS+=(-v "$SANDBOX_DIR/cargo:/home/claude/.cargo")
# Skill pack persistent state mounts
case ",${SANDY_SKILL_PACKS:-}," in
    *,gstack,*) RUN_FLAGS+=(-v "$SANDBOX_DIR/gstack:/home/claude/.gstack") ;;
esac
# SANDY_WORKSPACE was computed earlier (before Docker/network setup).
# Map: host ~/dev/sandy → container /home/claude/dev/sandy.

# --- Git submodule support ---
# Submodules use a .git *file* with a relative gitdir: path. We remap the gitdir
# into the container using the same $HOME-relative mapping so the relative
# references between worktree and gitdir resolve correctly.
if [ -f "$WORK_DIR/.git" ]; then
    GITDIR_REL="$(sed 's/^gitdir: //' "$WORK_DIR/.git" | tr -d '[:space:]')"
    if [ -n "$GITDIR_REL" ]; then
        GITDIR_HOST="$(cd "$WORK_DIR" && cd "$GITDIR_REL" && pwd)"
        if [[ "$GITDIR_HOST" == "$HOME"/* ]]; then
            _gitdir_rel="${GITDIR_HOST#$HOME/}"
            GITDIR_CONTAINER="/home/claude/$_gitdir_rel"
        else
            GITDIR_CONTAINER="$GITDIR_HOST"
        fi
        RUN_FLAGS+=(-v "$GITDIR_HOST:$GITDIR_CONTAINER")
        info "  Git submodule: gitdir at $GITDIR_CONTAINER"
    fi
fi
# Check for symlinks that escape the workspace (potential sandbox escape).
# We track both the display info and the mount info needed to make them work.
REAL_WORK_DIR="$(cd "$WORK_DIR" && pwd -P)"
DANGEROUS_SYMLINKS=()
# Parallel arrays: resolved host path and the container path where it should be mounted
SYMLINK_HOST_PATHS=()
SYMLINK_CONTAINER_PATHS=()
while IFS= read -r -d '' link; do
    target="$(readlink -f "$link" 2>/dev/null || true)"
    [ -z "$target" ] && continue
    if [[ "$target" != "$REAL_WORK_DIR"* ]]; then
        # Skip symlinks to system paths — mounting host system binaries over
        # the container's (e.g. /usr/bin/python3) breaks the container.
        # Only mount targets under $HOME.
        if [[ "$target" != "$HOME"/* ]]; then
            continue
        fi
        link_rel="${link#$WORK_DIR/}"
        DANGEROUS_SYMLINKS+=("$link_rel -> $target")
        SYMLINK_HOST_PATHS+=("$target")
        # Determine the container mount path based on symlink type.
        raw="$(readlink "$link")"
        if [[ "$raw" == /* ]]; then
            # Absolute symlink: the OS looks up the raw path literally inside the
            # container, so mount the resolved target at the raw symlink value.
            SYMLINK_CONTAINER_PATHS+=("$raw")
        else
            # Relative symlink: resolves relative to the symlink's parent dir.
            # In the container, the parent dir is at its $HOME-relative path, so
            # the relative traversal lands at the $HOME-relative mapping of the
            # resolved target.
            if [[ "$target" == "$HOME"/* ]]; then
                SYMLINK_CONTAINER_PATHS+=("/home/claude/${target#$HOME/}")
            else
                SYMLINK_CONTAINER_PATHS+=("$target")
            fi
        fi
    fi
done < <(find "$WORK_DIR" -maxdepth 5 -type l \
    -not -path '*/node_modules/*' \
    -not -path '*/.venv*/*' \
    -not -path '*/.git/*' \
    -print0 2>/dev/null)

if [ ${#DANGEROUS_SYMLINKS[@]} -gt 0 ]; then
    warn "Symlinks that point outside the workspace:"
    for s in "${DANGEROUS_SYMLINKS[@]}"; do
        warn "  $s"
    done
    printf "\033[0;33m[sandy] These could allow Claude to access files outside the sandbox.\033[0m\n"
    printf "\033[0;33m[sandy] Proceed anyway? [y/N] \033[0m"
    read -r REPLY
    if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
        error "Aborting. Remove dangerous symlinks and try again."
        exit 1
    fi
fi

RUN_FLAGS+=(-v "$WORK_DIR:$SANDY_WORKSPACE")

# Mount symlink targets so they resolve correctly inside the container.
# Dedup by container path (multiple symlinks may resolve to same target).
# Avoids associative arrays for bash 3.2 (macOS) compatibility.
_mounted_list=""
for i in "${!SYMLINK_HOST_PATHS[@]}"; do
    _host="${SYMLINK_HOST_PATHS[$i]}"
    _container="${SYMLINK_CONTAINER_PATHS[$i]}"
    case "$_mounted_list" in *"|$_container|"*) continue ;; esac
    _mounted_list="${_mounted_list}|$_container|"
    RUN_FLAGS+=(-v "$_host:$_container")
done
RUN_FLAGS+=(-w "$SANDY_WORKSPACE")

# Protect sensitive files/dirs from modification inside the container by overlaying
# read-only bind mounts. Prevents shell config injection, git hook injection, and
# Claude command/agent directory tampering. Does not affect the host filesystem.
for _pf in .bashrc .bash_profile .zshrc .zprofile .profile .gitconfig .ripgreprc .mcp.json; do
    [ -e "$WORK_DIR/$_pf" ] && RUN_FLAGS+=(-v "$WORK_DIR/$_pf:$SANDY_WORKSPACE/$_pf:ro")
done
for _gpf in .git/config .gitmodules; do
    [ -f "$WORK_DIR/$_gpf" ] && RUN_FLAGS+=(-v "$WORK_DIR/$_gpf:$SANDY_WORKSPACE/$_gpf:ro")
done
for _pd in .git/hooks .vscode .idea; do
    [ -d "$WORK_DIR/$_pd" ] && RUN_FLAGS+=(-v "$WORK_DIR/$_pd:$SANDY_WORKSPACE/$_pd:ro")
done
# Mount sandbox copies of commands, agents, and plugins over the workspace.
# All three start empty — host content is hidden so it doesn't leak into the container.
# Claude can create/modify these freely; changes persist in the sandbox across sessions.
if [ "$SANDY_AGENT" = "claude" ] || [ "$SANDY_AGENT" = "both" ]; then
    for _sd in commands agents plugins; do
        if [ -d "$WORK_DIR/.claude/$_sd" ] || [ -d "$SANDBOX_DIR/workspace-$_sd" ]; then
            mkdir -p "$SANDBOX_DIR/workspace-$_sd"
            RUN_FLAGS+=(-v "$SANDBOX_DIR/workspace-$_sd:$SANDY_WORKSPACE/.claude/$_sd")
        fi
    done
fi
if [ "$SANDY_AGENT" = "gemini" ] || [ "$SANDY_AGENT" = "both" ]; then
    # Gemini: protect .gemini/extensions and .gemini/commands similarly
    for _sd in extensions commands; do
        if [ -d "$WORK_DIR/.gemini/$_sd" ] || [ -d "$SANDBOX_DIR/workspace-gemini-$_sd" ]; then
            mkdir -p "$SANDBOX_DIR/workspace-gemini-$_sd"
            RUN_FLAGS+=(-v "$SANDBOX_DIR/workspace-gemini-$_sd:$SANDY_WORKSPACE/.gemini/$_sd")
        fi
    done
fi
RUN_FLAGS+=(-e "SANDY_WORKSPACE=$SANDY_WORKSPACE")
RUN_FLAGS+=(-e "SANDY_PROJECT_NAME=$(basename "$WORK_DIR")")
# Validate SANDY_MODEL — only allow alphanumeric, hyphens, dots, underscores
if [ "$SANDY_AGENT" = "claude" ] || [ "$SANDY_AGENT" = "both" ]; then
    SANDY_MODEL="${SANDY_MODEL:-claude-opus-4-6}"
else
    SANDY_MODEL="${SANDY_MODEL:-}"
fi
if [ -n "$SANDY_MODEL" ] && ! [[ "$SANDY_MODEL" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    error "Invalid SANDY_MODEL: $SANDY_MODEL (only alphanumeric, hyphens, dots, underscores allowed)"
    exit 1
fi
RUN_FLAGS+=(-e "SANDY_AGENT=$SANDY_AGENT")
RUN_FLAGS+=(-e "SANDY_MODEL=$SANDY_MODEL")
RUN_FLAGS+=(-e "SANDY_SKIP_PERMISSIONS=${SANDY_SKIP_PERMISSIONS:-true}")
RUN_FLAGS+=(-e "SANDY_NEW_SESSION=$SANDY_NEW_SESSION")
RUN_FLAGS+=(-e "SANDY_REMOTE_CONTROL=$SANDY_REMOTE_CONTROL")
RUN_FLAGS+=(-e "SANDY_VERBOSE=$SANDY_VERBOSE")
if [ "$SANDY_AGENT" = "claude" ] || [ "$SANDY_AGENT" = "both" ]; then
    # Channels env vars: for 'claude' these drive the in-container plugin path;
    # for 'both' the host-side relay uses the host-side env vars directly, but
    # we still forward them in case plugins are also configured.
    if [ -n "${SANDY_CHANNELS:-}" ] && [ "$SANDY_AGENT" = "claude" ]; then
        RUN_FLAGS+=(-e "SANDY_CHANNELS=$SANDY_CHANNELS")
    fi
    if [ -n "${TELEGRAM_BOT_TOKEN:-}" ]; then
        RUN_FLAGS+=(-e "TELEGRAM_BOT_TOKEN=$TELEGRAM_BOT_TOKEN")
    fi
    if [ -n "${TELEGRAM_ALLOWED_SENDERS:-}" ]; then
        RUN_FLAGS+=(-e "TELEGRAM_ALLOWED_SENDERS=$TELEGRAM_ALLOWED_SENDERS")
    fi
    if [ -n "${DISCORD_BOT_TOKEN:-}" ]; then
        RUN_FLAGS+=(-e "DISCORD_BOT_TOKEN=$DISCORD_BOT_TOKEN")
    fi
    if [ -n "${DISCORD_ALLOWED_SENDERS:-}" ]; then
        RUN_FLAGS+=(-e "DISCORD_ALLOWED_SENDERS=$DISCORD_ALLOWED_SENDERS")
    fi
    RUN_FLAGS+=(-e "CLAUDE_CODE_MAX_OUTPUT_TOKENS=${CLAUDE_CODE_MAX_OUTPUT_TOKENS:-128000}")
    if [ "${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-0}" = "1" ]; then
        RUN_FLAGS+=(-e "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1")
    fi
fi
# Forward git identity from host
GIT_USER_NAME="${GIT_USER_NAME:-$(git config user.name 2>/dev/null || true)}"
GIT_USER_EMAIL="${GIT_USER_EMAIL:-$(git config user.email 2>/dev/null || true)}"
if [ -n "$GIT_USER_NAME" ]; then
    RUN_FLAGS+=(-e "GIT_USER_NAME=$GIT_USER_NAME")
fi
if [ -n "$GIT_USER_EMAIL" ]; then
    RUN_FLAGS+=(-e "GIT_USER_EMAIL=$GIT_USER_EMAIL")
fi
# Pass host UID/GID so entrypoint can remap claude user (fixes bind-mount permissions on Linux)
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"
RUN_FLAGS+=(-e "HOST_UID=$HOST_UID")
RUN_FLAGS+=(-e "HOST_GID=$HOST_GID")
# If host UID/GID differs from the image default (1001), overlay /etc/passwd and /etc/group
# so tools that need username resolution (git, SSH, etc.) work correctly.
if [ "$HOST_UID" != "1001" ] || [ "$HOST_GID" != "1001" ]; then
    SANDY_PASSWD="$SANDY_HOME/passwd"
    SANDY_GROUP="$SANDY_HOME/group"
    # Generate passwd/group with correct UID/GID for the claude user.
    # Only root and claude exist in the container; other system users are
    # from the base image and only needed at build time.
    if [ ! -f "$SANDY_PASSWD" ] \
        || ! grep -q "^claude:x:${HOST_UID}:${HOST_GID}:" "$SANDY_PASSWD" 2>/dev/null; then
        docker run --rm --entrypoint cat "$IMAGE_NAME" /etc/passwd \
            | sed "s/^claude:x:1001:1001:/claude:x:${HOST_UID}:${HOST_GID}:/" > "$SANDY_PASSWD"
        docker run --rm --entrypoint cat "$IMAGE_NAME" /etc/group \
            | sed "s/^claude:x:1001:/claude:x:${HOST_GID}:/" > "$SANDY_GROUP"
    fi
    RUN_FLAGS+=(-v "$SANDY_PASSWD:/etc/passwd:ro")
    RUN_FLAGS+=(-v "$SANDY_GROUP:/etc/group:ro")
fi
if [ "$SANDY_AGENT" = "claude" ] || [ "$SANDY_AGENT" = "both" ]; then
    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
        RUN_FLAGS+=(-e "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
    fi
    # CLAUDE_CODE_OAUTH_TOKEN: pass through if explicitly configured (long-lived token from
    # `claude setup-token`), otherwise clear to prevent accidental host env leakage.
    if [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
        RUN_FLAGS+=(-e "CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN")
    else
        RUN_FLAGS+=(-e "CLAUDE_CODE_OAUTH_TOKEN=")
    fi
fi
if [ "$SANDY_AGENT" = "gemini" ] || [ "$SANDY_AGENT" = "both" ]; then
    # Disable Gemini's per-tool sandbox — sandy provides whole-session isolation.
    RUN_FLAGS+=(-e "GEMINI_SANDBOX=false")
    if [ -n "${GEMINI_API_KEY:-}" ]; then
        RUN_FLAGS+=(-e "GEMINI_API_KEY=$GEMINI_API_KEY")
    fi
    if [ -n "${GEMINI_MODEL:-}" ]; then
        RUN_FLAGS+=(-e "GEMINI_MODEL=$GEMINI_MODEL")
    fi
    if [ -n "${SANDY_GEMINI_EXTENSIONS:-}" ]; then
        RUN_FLAGS+=(-e "SANDY_GEMINI_EXTENSIONS=$SANDY_GEMINI_EXTENSIONS")
    fi
    if [ -n "${SANDY_GEMINI_AUTH:-}" ]; then
        RUN_FLAGS+=(-e "SANDY_GEMINI_AUTH=$SANDY_GEMINI_AUTH")
    fi
    # Google Cloud / Vertex AI passthrough
    for _gv in GOOGLE_CLOUD_PROJECT GOOGLE_CLOUD_LOCATION GOOGLE_GENAI_USE_VERTEXAI GOOGLE_API_KEY; do
        _gval="${!_gv:-}"
        [ -n "$_gval" ] && RUN_FLAGS+=(-e "$_gv=$_gval")
    done
fi

# --- Git authentication ---
# Default (SANDY_SSH=token): use GitHub CLI token with HTTPS — scoped, no SSH agent exposure.
# Opt-in (SANDY_SSH=agent): forward host SSH agent via TCP relay — full agent access.
SANDY_SSH="${SANDY_SSH:-token}"
SSH_RELAY_PID=""

# Mount ~/.ssh/known_hosts for either mode (needed for SSH host verification)
if [ -f "$HOME/.ssh/known_hosts" ]; then
    RUN_FLAGS+=(-v "$HOME/.ssh/known_hosts:/tmp/host-ssh-known_hosts:ro")
fi

if [[ "$SANDY_SSH" == "agent" ]]; then
    # --- SSH agent forwarding (opt-in) ---
    # Mount ~/.ssh read-only at a staging path; entrypoint copies to ~/.ssh with correct ownership.
    if [ -d "$HOME/.ssh" ]; then
        RUN_FLAGS+=(-v "$HOME/.ssh:/tmp/host-ssh:ro")
    fi
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ]; then
        if [[ "$OS" == "Linux" ]]; then
            # Linux: direct socket mount works
            RUN_FLAGS+=(-v "$SSH_AUTH_SOCK:/tmp/ssh-agent.sock")
            RUN_FLAGS+=(-e "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
        else
            # macOS: start a TCP relay on the host, container connects back via host.docker.internal
            SSH_RELAY_PORTFILE="$(mktemp)"
            python3 -c "import socket; s=socket.socket(); s.bind(('127.0.0.1',0)); print(s.getsockname()[1]); s.close()" > "$SSH_RELAY_PORTFILE"
            SSH_RELAY_PORT="$(cat "$SSH_RELAY_PORTFILE")"
            rm -f "$SSH_RELAY_PORTFILE"
            socat TCP-LISTEN:"$SSH_RELAY_PORT",bind=127.0.0.1,fork,reuseaddr \
                  UNIX-CONNECT:"$SSH_AUTH_SOCK" &
            SSH_RELAY_PID=$!
            RUN_FLAGS+=(-e "SSH_RELAY_PORT=$SSH_RELAY_PORT")
            info "SSH agent relay on localhost:$SSH_RELAY_PORT (PID $SSH_RELAY_PID)"
        fi
    else
        warn "SANDY_SSH=agent but no SSH agent found (SSH_AUTH_SOCK not set)"
    fi
    RUN_FLAGS+=(-e "SANDY_SSH=agent")
else
    RUN_FLAGS+=(-e "SANDY_SSH=token")
fi

# Collect gh CLI tokens for all authenticated accounts.
# GIT_TOKEN carries the active account's token (fallback for gh auth when GH_ACCOUNTS is empty).
# GH_ACCOUNTS carries all accounts as "user:token" pairs (used for gh CLI auth).
GIT_TOKEN=""
GH_ACCOUNTS=""
if command -v gh &>/dev/null; then
    GIT_TOKEN="$(gh auth token 2>/dev/null || true)"
    # Enumerate all accounts from gh auth status
    while IFS= read -r _acct; do
        _acct="$(echo "$_acct" | tr -d '[:space:]')"
        [ -z "$_acct" ] && continue
        _tok="$(gh auth token --user "$_acct" 2>/dev/null || true)"
        [ -z "$_tok" ] && continue
        [ -n "$GH_ACCOUNTS" ] && GH_ACCOUNTS="${GH_ACCOUNTS},"
        GH_ACCOUNTS="${GH_ACCOUNTS}${_acct}:${_tok}"
    done < <(gh auth status 2>&1 | grep 'account ' | sed 's/.*account //;s/ .*//')
fi
if [ -n "$GIT_TOKEN" ]; then
    RUN_FLAGS+=(-e "GIT_TOKEN=$GIT_TOKEN")
    if [[ "$SANDY_SSH" != "agent" ]]; then
        info "Git auth: GitHub token via gh CLI (HTTPS)"
    fi
else
    if [[ "$SANDY_SSH" != "agent" ]]; then
        warn "No gh CLI token found. Git push/pull may not work."
        warn "Install gh (https://cli.github.com) and run 'gh auth login', or use SANDY_SSH=agent."
    fi
fi
[ -n "$GH_ACCOUNTS" ] && RUN_FLAGS+=(-e "GH_ACCOUNTS=$GH_ACCOUNTS")

# --- Launch ---
case "$SANDY_AGENT" in
    gemini) info "Launching Gemini CLI sandbox..." ;;
    both)   info "Launching Claude Code + Gemini CLI sandbox (dual-pane)..." ;;
    *)      info "Launching Claude Code sandbox..." ;;
esac
info "  Working directory: $WORK_DIR"
info "  Sandbox:           $SANDBOX_DIR"
info "  Resources:         ${SANDY_CPUS} CPUs, ${SANDY_MEM} memory"
info "  Network:           Public internet only (LAN blocked)"
echo ""

if [ "$SANDY_VERBOSE" -ge 3 ]; then
    info "Docker run flags:"
    printf '  %s\n' "${RUN_FLAGS[@]}"
    echo ""
fi

# Launch host-side channel relay for gemini/both (Claude uses in-container plugin path)
CHANNEL_RELAY_PID=""
if [ "$SANDY_AGENT" != "claude" ] && [ -n "${SANDY_CHANNELS:-}" ]; then
    case ",$SANDY_CHANNELS," in
        *,telegram,*)
            if [ -n "${TELEGRAM_BOT_TOKEN:-}" ]; then
                SANDY_CONTAINER_NAME="$CONTAINER_NAME" \
                TELEGRAM_BOT_TOKEN="$TELEGRAM_BOT_TOKEN" \
                TELEGRAM_ALLOWED_SENDERS="${TELEGRAM_ALLOWED_SENDERS:-}" \
                SANDY_CHANNEL_TARGET_PANE="${SANDY_CHANNEL_TARGET_PANE:-0}" \
                bash "$SANDY_HOME/channel-relay.sh" &
                CHANNEL_RELAY_PID=$!
                info "Telegram channel relay started (PID $CHANNEL_RELAY_PID → $CONTAINER_NAME pane ${SANDY_CHANNEL_TARGET_PANE:-0})"
            else
                warn "SANDY_CHANNELS=telegram but TELEGRAM_BOT_TOKEN is not set"
            fi
            ;;
    esac
fi

docker run "${RUN_FLAGS[@]}" "$IMAGE_NAME" "$@"
