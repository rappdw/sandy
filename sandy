#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# sandy — Claude's isolated sibling
#
# Runs Claude Code in a Docker container with:
#   - Filesystem: read/write limited to current directory only
#   - Network: public internet only, NO LAN access
#   - Resources: capped CPU and memory
#   - Per-project sandbox: isolated ~/.claude per working directory
#
# Usage:
#   sandy                     Resume last session (or start new)
#   sandy --new               Start a fresh session
#   sandy -p "prompt"         One-shot prompt
# =============================================================================

SANDY_VERSION="0.7.8"

SANDY_HOME="${SANDY_HOME:-$HOME/.sandy}"
# Validate SANDY_HOME — reject shell metacharacters
if [[ "$SANDY_HOME" =~ [\;\$\`\&\|\<\>] ]]; then
    echo "[sandy] ERROR: Invalid SANDY_HOME: contains shell metacharacters" >&2
    exit 1
fi
BASE_IMAGE_NAME="sandy-base"
IMAGE_NAME="sandy-claude-code"
# Per-instance network names keyed on PID to avoid concurrent iptables races
BRIDGE_NAME="br-sdy-$$"
NETWORK_NAME="sandy_net_$$"

# --- Colors (disabled when not a terminal) ---
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' NC=''
fi

info()  { echo -e "${GREEN}[sandy]${NC} $*"; }
warn()  { echo -e "${YELLOW}[sandy]${NC} $*"; }
error() { echo -e "${RED}[sandy]${NC} $*" >&2; }
sha256() { shasum -a 256 2>/dev/null || sha256sum; }

SANDY_REPO_URL="https://raw.githubusercontent.com/rappdw/sandy/main/sandy"
SANDY_API_URL="https://api.github.com/repos/rappdw/sandy/releases/latest"

# Self-update: download latest sandy from GitHub and replace the running script
sandy_self_update() {
    local script_path
    script_path="$(readlink -f "${BASH_SOURCE[0]}")"
    local tmp
    tmp="$(mktemp)"
    info "Downloading latest sandy..."
    if ! curl -fsSL "$SANDY_REPO_URL" -o "$tmp"; then
        error "Failed to download update."
        rm -f "$tmp"
        exit 1
    fi
    local new_ver
    new_ver="$(grep -m1 '^SANDY_VERSION=' "$tmp" | cut -d'"' -f2)"
    if [ -z "$new_ver" ]; then
        error "Downloaded file does not look like sandy."
        rm -f "$tmp"
        exit 1
    fi
    if [ "$new_ver" = "$SANDY_VERSION" ]; then
        info "Already on latest version ($SANDY_VERSION)."
        rm -f "$tmp"
        exit 0
    fi
    chmod +x "$tmp"
    mv "$tmp" "$script_path"
    info "Updated sandy: $SANDY_VERSION → $new_ver"
    # Clear update cache
    rm -f "$SANDY_HOME/.update_check"
}

# Check for newer version (cached, non-blocking)
sandy_check_update() {
    mkdir -p "$SANDY_HOME"
    local cache="$SANDY_HOME/.update_check"
    local now
    now=$(date +%s)
    if [ -f "$cache" ]; then
        local cached_time cached_ver
        read -r cached_time cached_ver < "$cache" 2>/dev/null || true
        if [ -n "$cached_time" ] && (( now - cached_time < 86400 )); then
            if [ -n "$cached_ver" ] && [ "$cached_ver" != "v$SANDY_VERSION" ]; then
                warn "Update available: $SANDY_VERSION → ${cached_ver#v}. Run 'sandy --upgrade' to update."
            fi
            return
        fi
    fi
    local latest
    latest="$(curl -fsSL --max-time 3 "$SANDY_API_URL" 2>/dev/null \
        | grep -o '"tag_name":"[^"]*"' | cut -d'"' -f4)" || true
    if [ -n "$latest" ]; then
        echo "$now $latest" > "$cache"
        if [ "$latest" != "v$SANDY_VERSION" ]; then
            warn "Update available: $SANDY_VERSION → ${latest#v}. Run 'sandy --upgrade' to update."
        fi
    fi
}

# Merge JSON keys into a file. Usage: json_merge <file> '{"key":"value"}'
json_merge() {
    command -v node &>/dev/null || return 0
    node -e '
        const fs=require("fs"), f=process.argv[1], m=JSON.parse(process.argv[2]);
        let s;
        try { s=JSON.parse(fs.readFileSync(f,"utf8")); }
        catch { console.error("[sandy] WARN: could not parse "+f+", starting fresh"); s={}; }
        Object.assign(s,m);
        fs.writeFileSync(f, JSON.stringify(s,null,2)+"\n");
    ' "$1" "$2"
}

# --- Version ---
if [[ "${1:-}" == "-v" || "${1:-}" == "--version" ]]; then
    echo "sandy $SANDY_VERSION"
    exit 0
fi

# --- Help ---
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    cat <<EOF
sandy $SANDY_VERSION — Claude's isolated sibling

Run Claude Code in a Docker container with filesystem isolation,
network isolation, resource limits, and per-project credential sandboxes.

Usage:
  sandy                          Resume last session (or start new)
  sandy --new                    Start a fresh session
  sandy -p "prompt"              One-shot prompt
  sandy --resume                 Open session picker
  sandy --remote                 Start in remote-control server mode
  sandy --help                   Show this help

Environment variables:
  SANDY_MODEL        Model to use (default: claude-opus-4-6)
  ANTHROPIC_API_KEY  API key (not needed with Claude Max / OAuth)
  SANDY_HOME         Sandy config directory (default: ~/.sandy)
  SANDY_SSH          Git SSH method: "token" (default) uses gh CLI token
                     with HTTPS; "agent" forwards host SSH agent via relay
  SANDY_SKIP_PERMISSIONS  Set to "false" to keep Claude Code's permission
                     system active (default: "true" — bypasses permissions)
  SANDY_ALLOW_NO_ISOLATION  Set to "1" to allow launch when iptables
                     rules cannot be applied (Linux only)
  SANDY_CPUS         CPU limit for container (default: auto-detected)
  SANDY_MEM          Memory limit for container (default: auto-detected)
  SANDY_GPU          GPU passthrough: "all" for all GPUs, or device IDs
                     like "0" or "0,1" (requires NVIDIA Container Toolkit)
  CLAUDE_CODE_MAX_OUTPUT_TOKENS  Max output tokens per response (default: 128000)

Per-project config:
  .sandy/config      Parsed on launch (allowlisted KEY=VALUE lines only)

Flags:
  --help             Show this help
  --version          Show version
  --rebuild          Force rebuild of the sandbox Docker image
  --build-only       Build images and exit (for CI)
  --new              Start a fresh session (default: resume last)
  --resume           Open session picker
  --remote           Start in remote-control server mode
  --upgrade          Update sandy to the latest version

All other arguments are forwarded to claude.
EOF
    exit 0
fi

# --- Parse sandy flags (order-independent, consumed before forwarding to claude) ---
SANDY_REBUILD=false
SANDY_BUILD_ONLY=false
SANDY_NEW_SESSION=false
SANDY_REMOTE_CONTROL=false
REMAINING_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --rebuild)    SANDY_REBUILD=true ;;
        --build-only) SANDY_BUILD_ONLY=true ;;
        --new)        SANDY_NEW_SESSION=true ;;
        --remote)     SANDY_REMOTE_CONTROL=true ;;
        --upgrade)    sandy_self_update; exit 0 ;;
        *)            REMAINING_ARGS+=("$arg") ;;
    esac
done
set -- ${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}

# --- Check for sandy updates (non-blocking, cached 24h) ---
sandy_check_update

# --- Preflight checks ---
if ! command -v docker &>/dev/null; then
    error "Docker is not installed or not in PATH."
    exit 1
fi

# --- Build file generators ---
generate_dockerfile_base() {
    cat > "$SANDY_HOME/Dockerfile.base.new" <<'DOCKERFILE_BASE'
FROM debian:bookworm-slim

# System tools + C/C++ toolchain
RUN apt-get update && apt-get install -y \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        git \
        git-lfs \
        gosu \
        jq \
        less \
        libcairo2 \
        libgdk-pixbuf-2.0-0 \
        libpango1.0-0 \
        libssl-dev \
        ncurses-term \
        openssh-client \
        pkg-config \
        python3 \
        python3-pip \
        python3-venv \
        ripgrep \
        socat \
        tmux \
        unzip \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Go (arch-aware)
ARG GO_VERSION=1.24.1
RUN ARCH="$(dpkg --print-architecture)" \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${ARCH}.tar.gz" \
       | tar -C /usr/local -xz

# Rust stable (system-wide)
ENV RUSTUP_HOME=/usr/local/rustup
ENV CARGO_HOME=/usr/local/cargo
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --no-modify-path --default-toolchain stable \
    && chmod -R a+rX /usr/local/rustup /usr/local/cargo

# Bun
RUN curl -fsSL https://bun.sh/install | BUN_INSTALL=/usr/local bash

# uv — fast Python package/version manager
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_UNMANAGED_INSTALL=/usr/local/bin sh

# User
RUN useradd -m -s /bin/bash -u 1001 claude

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PATH="/home/claude/.local/bin:/usr/local/cargo/bin:/usr/local/go/bin:$PATH"
DOCKERFILE_BASE
}

generate_dockerfile() {
    cat > "$SANDY_HOME/Dockerfile.new" <<DOCKERFILE
FROM ${BASE_IMAGE_NAME}
# Install Claude Code natively. The installer places files under
# /home/claude/.local/{bin,share}/claude.  Since /home/claude gets a
# tmpfs overlay at runtime, we relocate the binary to /usr/local/bin
# and the data directory to /opt/claude-code.  The entrypoint symlinks
# them back into the expected paths.
RUN HOME=/home/claude su -s /bin/bash claude -c "curl -fsSL https://claude.ai/install.sh | bash" \\
 && cp -L /home/claude/.local/bin/claude /usr/local/bin/claude \\
 && mv /home/claude/.local/share/claude /opt/claude-code \\
 && { /usr/local/bin/claude --version 2>/dev/null | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' > /opt/claude-code/.version || true; }
COPY tmux.conf /etc/tmux.conf
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY user-setup.sh /usr/local/bin/user-setup.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/user-setup.sh
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
DOCKERFILE
}

generate_entrypoint() {
    cat > "$SANDY_HOME/entrypoint.sh.new" <<'ENTRYPOINT'
#!/bin/bash
# --- Root-only setup (runs before dropping to user claude) ---

# Determine runtime UID/GID (match host user for bind-mount permissions on Linux)
RUN_UID="${HOST_UID:-1001}"
RUN_GID="${HOST_GID:-1001}"

# Fix ownership of tmpfs home directory (mounted with uid=1001, may differ from host)
chown "$RUN_UID:$RUN_GID" /home/claude

# Seed known_hosts from host if available
if [ -f "/tmp/host-ssh-known_hosts" ]; then
    mkdir -p /home/claude/.ssh
    cp /tmp/host-ssh-known_hosts /home/claude/.ssh/known_hosts
    chown -R "$RUN_UID:$RUN_GID" /home/claude/.ssh
    chmod 700 /home/claude/.ssh
    chmod 644 /home/claude/.ssh/known_hosts
fi

if [ "${SANDY_SSH:-token}" = "agent" ]; then
    # --- SSH agent mode ---
    # SSH agent relay: create a Unix socket that relays to the host's TCP relay
    if [ -n "${SSH_RELAY_PORT:-}" ]; then
        rm -f /tmp/ssh-agent.sock
        socat UNIX-LISTEN:/tmp/ssh-agent.sock,fork,mode=0600,uid="$RUN_UID" \
              TCP:host.docker.internal:${SSH_RELAY_PORT} &
        # Wait for socket to appear
        for i in $(seq 1 50); do [ -S /tmp/ssh-agent.sock ] && break; sleep 0.1; done
        export SSH_AUTH_SOCK=/tmp/ssh-agent.sock
    elif [ -S "/tmp/ssh-agent.sock" ]; then
        # Linux: socket was mounted directly
        chmod 600 /tmp/ssh-agent.sock && chown "$RUN_UID:$RUN_GID" /tmp/ssh-agent.sock
    fi

    # Copy host SSH config/keys with correct ownership and permissions
    if [ -d "/tmp/host-ssh" ]; then
        mkdir -p /home/claude/.ssh
        cp -a /tmp/host-ssh/. /home/claude/.ssh/
        chown -R "$RUN_UID:$RUN_GID" /home/claude/.ssh
        chmod 700 /home/claude/.ssh
        chmod 600 /home/claude/.ssh/* 2>/dev/null || true
        chmod 644 /home/claude/.ssh/*.pub 2>/dev/null || true
        chmod 644 /home/claude/.ssh/known_hosts 2>/dev/null || true
        chmod 644 /home/claude/.ssh/config 2>/dev/null || true
    fi
fi

# Fix ownership of persistent package mounts
for d in /home/claude/.pip-packages /home/claude/.local/share/uv \
         /home/claude/.npm-global /home/claude/go /home/claude/.cargo; do
    chown "$RUN_UID:$RUN_GID" "$d" 2>/dev/null || true
done

# Restore native install layout so Claude Code finds its binary and data at the
# expected paths (the real files live outside /home/claude to survive the tmpfs overlay)
mkdir -p /home/claude/.local/bin /home/claude/.local/share
ln -sf /usr/local/bin/claude /home/claude/.local/bin/claude
ln -sf /opt/claude-code /home/claude/.local/share/claude
# chown the tmpfs dirs individually — avoid -R which would recurse into
# the bind-mounted uv directory at .local/share/uv
chown "$RUN_UID:$RUN_GID" /home/claude/.local /home/claude/.local/bin \
    /home/claude/.local/share /home/claude/.local/share/claude 2>/dev/null || true

# Create pip/pip3 wrappers that auto-add --user for install commands when NOT
# inside a virtualenv. Created here (root section) because the user section is
# inside bash -c '...' where heredoc quoting breaks.
cat > /home/claude/.local/bin/pip <<'PIPWRAP'
#!/bin/bash
if [ -z "$VIRTUAL_ENV" ] && [ "${1:-}" = "install" ]; then
    shift
    exec python3 -m pip install --user "$@"
fi
exec python3 -m pip "$@"
PIPWRAP
cp /home/claude/.local/bin/pip /home/claude/.local/bin/pip3
chmod +x /home/claude/.local/bin/pip /home/claude/.local/bin/pip3
chown "$RUN_UID:$RUN_GID" /home/claude/.local/bin/pip /home/claude/.local/bin/pip3

# Drop privileges to host user's UID/GID
exec gosu "$RUN_UID:$RUN_GID" /usr/local/bin/user-setup.sh "$@"
ENTRYPOINT
}

generate_user_setup() {
    cat > "$SANDY_HOME/user-setup.sh.new" <<'USERSETUP'
#!/bin/bash
set -e
export HOME=/home/claude
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS="${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-0}"
export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${CLAUDE_CODE_MAX_OUTPUT_TOKENS:-128000}"
export DISABLE_AUTOUPDATER=1
export ENABLE_CLAUDEAI_MCP_SERVERS=false

# Cargo: writable registry cache + cargo-install binaries
export CARGO_HOME="$HOME/.cargo"
mkdir -p "$CARGO_HOME/bin"
for bin in /usr/local/cargo/bin/*; do
    ln -sf "$bin" "$CARGO_HOME/bin/$(basename "$bin")"
done

# Go: writable GOPATH
export GOPATH="$HOME/go"
mkdir -p "$GOPATH/bin"

# npm: global installs to writable location
export NPM_CONFIG_PREFIX="$HOME/.npm-global"
mkdir -p "$NPM_CONFIG_PREFIX/bin"

# Python: persistent user-scoped pip installs via PYTHONUSERBASE
# pip/pip3 wrapper scripts are created in the root section above (heredoc
# quoting breaks inside bash -c single quotes).
export PIP_BREAK_SYSTEM_PACKAGES=1
export PYTHONUSERBASE="$HOME/.pip-packages"
mkdir -p "$PYTHONUSERBASE/bin"

# Writable bin dirs on PATH
export PATH="$HOME/.local/bin:$PYTHONUSERBASE/bin:$NPM_CONFIG_PREFIX/bin:$GOPATH/bin:$CARGO_HOME/bin:$PATH"

# Remap ANSI dark blue (color 4) to a readable bright blue
printf "\033]4;4;rgb:61/8f/ff\033\\"
trap "printf \"\033]104;4\033\\\\\"" EXIT

# Ensure project-level settings exist
WORKSPACE="${SANDY_WORKSPACE:-/workspace}"
mkdir -p "$WORKSPACE/.claude" 2>/dev/null || true

# Ensure plugin marketplaces are configured in settings.json (idempotent)
SETTINGS_FILE="$HOME/.claude/settings.json"
if [ -f "$SETTINGS_FILE" ]; then
    node -e '
        const fs = require("fs");
        const f = process.argv[1];
        let s;
        try { s = JSON.parse(fs.readFileSync(f, "utf8")); } catch { s = {}; }
        if (!s.extraKnownMarketplaces) s.extraKnownMarketplaces = {};
        const required = {
            "claude-plugins-official": { source: { source: "github", repo: "anthropics/claude-plugins-official" } },
            "sandy-plugins": { source: { source: "github", repo: "rappdw/sandy-plugins" } }
        };
        let changed = false;
        for (const [name, cfg] of Object.entries(required)) {
            if (!s.extraKnownMarketplaces[name]) {
                s.extraKnownMarketplaces[name] = cfg;
                changed = true;
            }
        }
        if (changed) fs.writeFileSync(f, JSON.stringify(s, null, 2) + "\n");
    ' "$SETTINGS_FILE"
fi

# Trust all directories (host UID differs from container UID; container is sandboxed)
git config --global --add safe.directory "*"

# Set git identity from host
if [ -n "${GIT_USER_NAME:-}" ]; then
    git config --global user.name "$GIT_USER_NAME"
fi
if [ -n "${GIT_USER_EMAIL:-}" ]; then
    git config --global user.email "$GIT_USER_EMAIL"
fi

# --- Dev environment checks ---
# Set up git-lfs filters if the workspace is a git repo using LFS (home is tmpfs, so config is lost each session)
if [ -d "$WORKSPACE/.git" ] || [ -f "$WORKSPACE/.git" ]; then
    if find "$WORKSPACE" -name .gitattributes -maxdepth 3 -exec grep -ql "filter=lfs" {} + 2>/dev/null; then
        git lfs install 2>/dev/null || true
    fi
fi

# Auto-install Python version if .python-version exists (uv is idempotent & fast)
if [ -f "$WORKSPACE/.python-version" ]; then
    PY_WANT="$(cat "$WORKSPACE/.python-version" | tr -d "[:space:]")"
    if [ -n "$PY_WANT" ] && command -v uv &>/dev/null; then
        printf "\033[0;36m● Installing Python %s via uv...\033[0m\n" "$PY_WANT"
        uv python install "$PY_WANT" 2>/dev/null && \
            printf "\033[0;36m● Python %s ready\033[0m\n" "$PY_WANT" || true
    fi
fi

# If .venv exists but its python symlink is broken, auto-install the needed version
if [ -L "$WORKSPACE/.venv/bin/python" ] && [ ! -e "$WORKSPACE/.venv/bin/python" ]; then
    VENV_TARGET="$(readlink "$WORKSPACE/.venv/bin/python")"
    # Extract version from symlink (e.g. /usr/bin/python3.12 → 3.12, .pyenv/versions/3.10.4/... → 3.10)
    PY_VER="$(echo "$VENV_TARGET" | grep -oE '[0-9]+\.[0-9]+' | head -1)"
    if [ -n "$PY_VER" ] && command -v uv &>/dev/null; then
        printf "\033[0;36m● Installing Python %s via uv (.venv needs it)...\033[0m\n" "$PY_VER"
        if uv python install "$PY_VER" 2>/dev/null; then
            printf "\033[0;36m● Python %s ready\033[0m\n" "$PY_VER"
        else
            printf "\033[0;33m⚠ .venv needs Python %s but uv could not install it\033[0m\n" "$PY_VER"
        fi
    else
        printf "\033[0;33m⚠ .venv/bin/python → %s (not found in container)\033[0m\n" "$VENV_TARGET"
    fi
fi

# Warn if node_modules contains native addons built for a different platform
if [ -d "$WORKSPACE/node_modules" ]; then
    # Check for .node files — if any exist, verify they are Linux ELF binaries
    BAD_NATIVE="$(find "$WORKSPACE/node_modules" -name "*.node" -type f 2>/dev/null | head -1)"
    if [ -n "$BAD_NATIVE" ] && ! file "$BAD_NATIVE" 2>/dev/null | grep -q "ELF"; then
        printf "\033[0;33m⚠ node_modules/ contains native addons built for a different platform\033[0m\n"
        printf "\033[0;33m  Fix: npm rebuild\033[0m\n"
    fi
fi

# Configure git auth: GitHub token (default) or SSH agent
if [ "${SANDY_SSH:-token}" = "token" ] && [ -n "${GIT_TOKEN:-}" ]; then
    git config --global url."https://oauth2:${GIT_TOKEN}@github.com/".insteadOf "git@github.com:"
    git config --global --add url."https://oauth2:${GIT_TOKEN}@github.com/".insteadOf "ssh://git@github.com/"
    # Authenticate gh CLI so PR/issue/release commands work
    if command -v gh &>/dev/null; then
        echo "${GIT_TOKEN}" | gh auth login --with-token 2>/dev/null || true
    fi
fi

# Auto-install channel plugins if referenced in SANDY_CHANNELS and not yet installed
for _chan in telegram discord; do
    if [[ "${SANDY_CHANNELS:-}" == *"$_chan"* ]]; then
        if ! claude plugin list 2>/dev/null | grep -q "${_chan}@claude-plugins-official"; then
            printf "\033[0;36m● Installing %s channel plugin...\033[0m\n" "$_chan"
            claude plugin install "${_chan}@claude-plugins-official" 2>/dev/null || true
        fi
    fi
done

# Seed channel config from env vars (token + allowlist per channel)
_seed_channel() {
    local chan="$1" token_var="$2" senders_var="$3"
    local token="${!token_var:-}"
    local senders="${!senders_var:-}"
    [ -z "$token" ] && return
    mkdir -p "$HOME/.claude/channels/$chan"
    echo "${token_var}=$token" > "$HOME/.claude/channels/$chan/.env"
    chmod 600 "$HOME/.claude/channels/$chan/.env"
    [ -f "$HOME/.claude/channels/$chan/access.json" ] && return
    if [ -n "$senders" ]; then
        ALLOW_JSON=$(echo "$senders" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | awk 'NR>1{printf ","}{printf "\"%s\"",$0}')
        cat > "$HOME/.claude/channels/$chan/access.json" <<CHACCESS
{
  "dmPolicy": "allowlist",
  "allowFrom": [$ALLOW_JSON],
  "groups": {},
  "pending": {}
}
CHACCESS
    else
        cat > "$HOME/.claude/channels/$chan/access.json" <<'CHACCESS'
{
  "dmPolicy": "pairing",
  "allowFrom": [],
  "groups": {},
  "pending": {}
}
CHACCESS
    fi
}
_seed_channel telegram TELEGRAM_BOT_TOKEN TELEGRAM_ALLOWED_SENDERS
_seed_channel discord DISCORD_BOT_TOKEN DISCORD_ALLOWED_SENDERS

# Build the claude command with any passed args
if [ "${SANDY_REMOTE_CONTROL:-false}" = "true" ]; then
    # Remote-control server mode — no tmux wrapper, no auto-resume
    CLAUDE_CMD="claude remote-control --name \"sandy: ${SANDY_PROJECT_NAME:-$(basename "$WORKSPACE")}\""
    for arg in "$@"; do
        CLAUDE_CMD+=" $(printf "%q" "$arg")"
    done
    cd "$WORKSPACE"
    exec bash -c "$CLAUDE_CMD 2>&1"
else
    CLAUDE_CMD="claude --model ${SANDY_MODEL:-claude-opus-4-6} --teammate-mode tmux"
    if [ "${SANDY_SKIP_PERMISSIONS:-true}" = "true" ]; then
        CLAUDE_CMD+=" --dangerously-skip-permissions"
    fi
    if [ -n "${SANDY_CHANNELS:-}" ]; then
        CLAUDE_CMD+=" --channels $SANDY_CHANNELS"
    fi

    # Auto-resume: inject --continue unless user passed --new, -p, --resume, or --continue
    # Also skip if there are no prior sessions to continue (first run in this sandbox)
    SANDY_AUTO_CONTINUE=true
    if [ "${SANDY_NEW_SESSION:-false}" = "true" ]; then
        SANDY_AUTO_CONTINUE=false
    fi
    for arg in "$@"; do
        case "$arg" in
            -p|--resume|--continue) SANDY_AUTO_CONTINUE=false ;;
        esac
    done
    if [ "$SANDY_AUTO_CONTINUE" = "true" ]; then
        # Check if any session files exist (path encodes SANDY_WORKSPACE)
        SESSION_DIR="$HOME/.claude/projects/$(echo "$WORKSPACE" | tr '/' '-')/"
        if ls "$SESSION_DIR"*.jsonl &>/dev/null; then
            CLAUDE_CMD+=" --continue"
        fi
    fi

    for arg in "$@"; do
        CLAUDE_CMD+=" $(printf "%q" "$arg")"
    done

    cd "$WORKSPACE"
    tmux new-session -s sandy -n "sandy: ${SANDY_PROJECT_NAME:-$(basename "$WORKSPACE")}" -- bash -c "$CLAUDE_CMD 2>&1"
fi
USERSETUP
}

generate_tmux_conf() {
