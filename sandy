generate_channel_relay() {
    cat > "$SANDY_HOME/channel-relay.sh.new" <<'RELAY'
#!/usr/bin/env bash
# sandy channel-relay — host-side Telegram → tmux injection bridge.
# Long-polls the Telegram Bot API and injects messages into the container's
# tmux session via `docker exec ... tmux send-keys`. Stateless, agent-agnostic.
#
# Required env: TELEGRAM_BOT_TOKEN, SANDY_CONTAINER_NAME
# Optional:     TELEGRAM_ALLOWED_SENDERS (csv of user IDs), SANDY_CHANNEL_TARGET_PANE (default 0)
set -u
: "${TELEGRAM_BOT_TOKEN:?}"
: "${SANDY_CONTAINER_NAME:?}"
TARGET_PANE="${SANDY_CHANNEL_TARGET_PANE:-0}"
ALLOWED="${TELEGRAM_ALLOWED_SENDERS:-}"
API="https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}"
OFFSET=0

_is_allowed() {
    local uid="$1"
    [ -z "$ALLOWED" ] && return 0
    case ",$ALLOWED," in *,"$uid",*) return 0 ;; esac
    return 1
}

_inject() {
    local text="$1"
    # Wait for container tmux session to exist (up to 30s)
    local tries=0
    while [ $tries -lt 60 ]; do
        if docker exec "$SANDY_CONTAINER_NAME" tmux has-session -t sandy 2>/dev/null; then
            break
        fi
        sleep 0.5
        tries=$((tries+1))
    done
    docker exec "$SANDY_CONTAINER_NAME" tmux send-keys -t "sandy.${TARGET_PANE}" "$text" Enter 2>/dev/null || true
}

# Drain stale updates once at startup
_init="$(curl -sS --max-time 5 "${API}/getUpdates?timeout=0&offset=-1" 2>/dev/null || true)"
if [ -n "$_init" ]; then
    OFFSET="$(echo "$_init" | python3 -c 'import json,sys
try:
    d=json.load(sys.stdin)
    r=d.get("result",[])
    print(r[-1]["update_id"]+1 if r else 0)
except Exception:
    print(0)' 2>/dev/null || echo 0)"
fi

while :; do
    resp="$(curl -sS --max-time 60 "${API}/getUpdates?timeout=50&offset=${OFFSET}" 2>/dev/null || true)"
    [ -z "$resp" ] && { sleep 2; continue; }
    # Parse updates; emit: update_id\tuser_id\ttext
    parsed="$(echo "$resp" | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(0)
if not d.get("ok"): sys.exit(0)
for u in d.get("result", []):
    uid = u.get("update_id", 0)
    m = u.get("message") or u.get("edited_message") or {}
    text = m.get("text") or m.get("caption") or ""
    sender = (m.get("from") or {}).get("id", "")
    if not text:
        print(f"{uid}\t\t")
        continue
    # strip control chars; flatten newlines into spaces
    text = text.replace("\r"," ").replace("\n"," ")
    print(f"{uid}\t{sender}\t{text}")
' 2>/dev/null || true)"
    [ -z "$parsed" ] && continue
    while IFS=$'\t' read -r uid sender text; do
        [ -z "$uid" ] && continue
        OFFSET=$((uid+1))
        [ -z "$text" ] && continue
        if _is_allowed "$sender"; then
            _inject "$text"
        fi
    done <<< "$parsed"
done
RELAY
    chmod +x "$SANDY_HOME/channel-relay.sh.new"
}

generate_skill_pack_dockerfiles() {
    local packs="$1"
    local base_outfile="$SANDY_HOME/Dockerfile.skills-base.new"
    local outfile="$SANDY_HOME/Dockerfile.skills.new"
    local needs_base=false

    local pack
    IFS=',' read -ra _pack_list <<< "$packs"

    # --- Generate base image (heavy deps: Playwright, Chromium, system libs) ---
    cat > "$base_outfile" <<'SKILLS_BASE_HEADER'
FROM sandy-claude-code
SKILLS_BASE_HEADER

    for pack in "${_pack_list[@]}"; do
        pack="$(echo "$pack" | tr -d '[:space:]')"
        case "$pack" in
            gstack)
                needs_base=true
                cat >> "$base_outfile" <<'GSTACK_BASE_BLOCK'

# --- gstack base: Playwright + Chromium (rarely changes) ---
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/skills/gstack/.browsers

# Bootstrap gstack just enough to install Playwright
RUN mkdir -p /opt/skills/gstack \
 && cd /opt/skills/gstack \
 && npm init -y >/dev/null 2>&1 \
 && npm install playwright@latest --save >/dev/null 2>&1 \
 && npx playwright install-deps chromium \
 && npx playwright install chromium \
 && rm -rf node_modules package.json package-lock.json
GSTACK_BASE_BLOCK
                ;;
        esac
    done
    echo "" >> "$base_outfile"

    if [ "$needs_base" != true ]; then
        rm -f "$base_outfile"
    fi

    # --- Generate code image (gstack source, bun build — changes frequently) ---
    local skills_base_name
    skills_base_name="sandy-skills-base-$(echo "$packs" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sort | tr '\n' '-' | sed 's/-$//' | tr '[:upper:]' '[:lower:]')"

    if [ "$needs_base" = true ]; then
        cat > "$outfile" <<SKILLS_HEADER
FROM ${skills_base_name}
SKILLS_HEADER
    else
        cat > "$outfile" <<'SKILLS_HEADER'
FROM sandy-claude-code
SKILLS_HEADER
    fi

    for pack in "${_pack_list[@]}"; do
        pack="$(echo "$pack" | tr -d '[:space:]')"
        local version repo
        version="$(skill_pack_lookup "$pack" version)" || true
        repo="$(skill_pack_lookup "$pack" repo)" || true
        if [ -z "$version" ] || [ -z "$repo" ]; then
            error "Unknown skill pack: $pack"
            exit 1
        fi
        case "$pack" in
            gstack)
                cat >> "$outfile" <<GSTACK_BLOCK

# --- gstack skill pack ($version) ---
# Download gstack at pinned version
RUN mkdir -p /opt/skills/gstack \\
 && curl -fsSL "${repo}/archive/${version}.tar.gz" \\
    | tar -xz --strip-components=1 -C /opt/skills/gstack

# Install dependencies and build (browse binary + skill docs)
RUN cd /opt/skills/gstack \\
 && (bun install --frozen-lockfile 2>/dev/null || bun install) \\
 && bun run build \\
 && echo "${version}" > browse/dist/.version \\
 && rm -rf node_modules/.cache

# Make all bin/ scripts executable
RUN chmod +x /opt/skills/gstack/bin/*
GSTACK_BLOCK
                ;;
            *)
                error "No build recipe for skill pack: $pack"
                exit 1
                ;;
        esac
    done

    # No USER directive — entrypoint runs as root and drops privileges via gosu
    echo "" >> "$outfile"
}

ensure_build_files() {
    mkdir -p "$SANDY_HOME"
    generate_dockerfile_base
    generate_entrypoint
    generate_user_setup
    generate_tmux_conf
    generate_channel_relay

    # Only update on-disk files if content has changed
    local changed=false
    for f in Dockerfile.base entrypoint.sh user-setup.sh tmux.conf channel-relay.sh; do
        if [ ! -f "$SANDY_HOME/$f" ] || ! diff -q "$SANDY_HOME/$f.new" "$SANDY_HOME/$f" &>/dev/null; then
            mv "$SANDY_HOME/$f.new" "$SANDY_HOME/$f"
            changed=true
        else
            rm "$SANDY_HOME/$f.new"
        fi
    done

    # Empty fixtures for bind-mount-as-ro fallback targets (S1.0).
    # When a protected host path is absent, we still want to overlay an empty
    # ro fixture at that container path — blocks in-container creation and
    # closes the existence-gated protection bypass. --tmpfs X:ro is not
    # reliably honored across Docker versions, so we use bind-mount of a known
    # empty host path instead. Idempotent, created once.
    [ -f "$SANDY_HOME/.empty-ro-file" ] || : > "$SANDY_HOME/.empty-ro-file"
    [ -d "$SANDY_HOME/.empty-ro-dir" ]  || mkdir -p "$SANDY_HOME/.empty-ro-dir"

    if [ "$changed" = true ]; then
        info "Build files updated."
    fi
}

# Generate the agent-specific Dockerfile after SANDY_AGENT is known.
ensure_agent_dockerfile() {
    local f
    if [ "$_SANDY_IS_MULTI" = true ]; then
        generate_dockerfile_full; f="Dockerfile.full"
    else
        case "$SANDY_AGENT" in
            gemini) generate_dockerfile_gemini; f="Dockerfile.gemini" ;;
            codex)  generate_dockerfile_codex;  f="Dockerfile.codex" ;;
            *)      generate_dockerfile;        f="Dockerfile" ;;
        esac
    fi
    if [ ! -f "$SANDY_HOME/$f" ] || ! diff -q "$SANDY_HOME/$f.new" "$SANDY_HOME/$f" &>/dev/null; then
        mv "$SANDY_HOME/$f.new" "$SANDY_HOME/$f"
    else
        rm "$SANDY_HOME/$f.new"
    fi
}

# --- Initialize ---
ensure_build_files

# --- Per-project sandbox directory ---
WORK_DIR="$(pwd)"

# Safe key-value config parser (no arbitrary code execution).
#
# tier is either "privileged" (host-level ~/.sandy/{config,.secrets}) or
# "passive" (workspace-level .sandy/{config,.secrets}). Privileged keys like
# SANDY_SKIP_PERMISSIONS, SANDY_ALLOW_NO_ISOLATION, SANDY_ALLOW_LAN_HOSTS,
# SANDY_SSH, and API keys/tokens are dropped with a warning when loaded from
# a passive source — a compromised session must not be able to weaken sandy's
# own isolation on the next launch by writing to workspace config.
# Accumulator for privileged keys encountered in passive (workspace) sources.
# These are not exported immediately — they are resolved against a persistent
# per-workspace approval list after all config files have been loaded. See
# _resolve_passive_privileged_approval() below.
_PASSIVE_PRIVILEGED_PENDING=()
_PASSIVE_PRIVILEGED_SOURCES=()

_load_sandy_config() {
    local file="$1"
    local tier="${2:-privileged}"
    [ -f "$file" ] || return 0
    while IFS='=' read -r key value; do
        value="${value#\"}" ; value="${value%\"}"
        value="${value#\'}" ; value="${value%\'}"
        case "$tier" in
            privileged)
                # Full allowlist — all keys permitted
                case "$key" in
                    SANDY_SSH|SANDY_MODEL|SANDY_SKILL_PACKS|SANDY_SKIP_PERMISSIONS|\
                    SANDY_ALLOW_NO_ISOLATION|SANDY_ALLOW_LAN_HOSTS|\
                    SANDY_ALLOW_WORKFLOW_EDIT|\
                    SANDY_CPUS|SANDY_MEM|SANDY_GPU|SANDY_CHANNELS|SANDY_VERBOSE|\
                    SANDY_AGENT|SANDY_VENV_OVERLAY|\
                    CLAUDE_CODE_OAUTH_TOKEN|\
                    TELEGRAM_BOT_TOKEN|TELEGRAM_ALLOWED_SENDERS|\
                    DISCORD_BOT_TOKEN|DISCORD_ALLOWED_SENDERS|\
                    ANTHROPIC_API_KEY|CLAUDE_CODE_MAX_OUTPUT_TOKENS|\
                    CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS|\
                    GEMINI_API_KEY|GEMINI_MODEL|SANDY_GEMINI_EXTENSIONS|SANDY_GEMINI_AUTH|\
                    GOOGLE_CLOUD_PROJECT|GOOGLE_CLOUD_LOCATION|GOOGLE_GENAI_USE_VERTEXAI|GOOGLE_API_KEY|\
                    OPENAI_API_KEY|CODEX_MODEL|SANDY_CODEX_AUTH|CODEX_HOME|\
                    SANDY_CHANNEL_TARGET_PANE)
                        export "$key=$value" ;;
                esac
                ;;
            passive)
                # Privileged keys from passive sources: collect for later
                # approval prompt. Do NOT export yet.
                case "$key" in
                    SANDY_SSH|SANDY_SKIP_PERMISSIONS|SANDY_ALLOW_NO_ISOLATION|\
                    SANDY_ALLOW_LAN_HOSTS|\
                    ANTHROPIC_API_KEY|CLAUDE_CODE_OAUTH_TOKEN|\
                    GEMINI_API_KEY|OPENAI_API_KEY|GOOGLE_API_KEY|\
                    CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS)
                        _PASSIVE_PRIVILEGED_PENDING+=("$key=$value")
                        _PASSIVE_PRIVILEGED_SOURCES+=("$file")
                        ;;
                    # Passive (workspace-settable) keys — allow
                    SANDY_MODEL|SANDY_SKILL_PACKS|\
                    SANDY_ALLOW_WORKFLOW_EDIT|\
                    SANDY_CPUS|SANDY_MEM|SANDY_GPU|SANDY_CHANNELS|SANDY_VERBOSE|\
                    SANDY_AGENT|SANDY_VENV_OVERLAY|\
                    TELEGRAM_BOT_TOKEN|TELEGRAM_ALLOWED_SENDERS|\
                    DISCORD_BOT_TOKEN|DISCORD_ALLOWED_SENDERS|\
                    CLAUDE_CODE_MAX_OUTPUT_TOKENS|\
                    GEMINI_MODEL|SANDY_GEMINI_EXTENSIONS|SANDY_GEMINI_AUTH|\
                    GOOGLE_CLOUD_PROJECT|GOOGLE_CLOUD_LOCATION|GOOGLE_GENAI_USE_VERTEXAI|\
                    CODEX_MODEL|SANDY_CODEX_AUTH|CODEX_HOME|\
                    SANDY_CHANNEL_TARGET_PANE)
                        export "$key=$value" ;;
                esac
                ;;
        esac
    done < <(grep -E '^[A-Z_]+=.+' "$file" 2>/dev/null)
}

# Load config/secrets: host-level is privileged, workspace-level is passive.
# Passive sources are parsed by a tampering container between sessions, so
# privileged keys (API keys, SANDY_SSH, isolation toggles) must not be honored
# from them.
_load_sandy_config "$SANDY_HOME/config"            privileged
_load_sandy_config "$SANDY_HOME/.secrets"          privileged
_load_sandy_config "$WORK_DIR/.sandy/config"       passive
_load_sandy_config "$WORK_DIR/.sandy/.secrets"     passive

# Resolve any privileged keys collected from workspace (passive) config sources
# against a per-workspace approval list. First encounter → interactive prompt;
# subsequent launches with the same set → silent; changed set → re-prompt;
# headless mode → drop with a pointer to "launch interactively to approve".
#
# Approval is keyed on the absolute workspace path AND the exact KEY=VALUE set,
# so editing .sandy/config always re-triggers the prompt.
_resolve_passive_privileged_approval() {
    [ ${#_PASSIVE_PRIVILEGED_PENDING[@]} -eq 0 ] && return 0

    # Sort + dedupe the KEY=VALUE set for deterministic hashing.
    local sorted
    sorted="$(printf '%s\n' "${_PASSIVE_PRIVILEGED_PENDING[@]}" | sort -u)"

    local set_hash wd_hash
    set_hash="$(printf '%s' "$sorted" | sha256 | awk '{print $1}')"
    wd_hash="$(printf '%s' "$WORK_DIR" | sha256 | awk '{print $1}' | cut -c1-16)"

    local approvals_dir="$SANDY_HOME/approvals"
    local approval_file="$approvals_dir/passive-$wd_hash.list"
    mkdir -p "$approvals_dir"

    # Escape hatch for CI / test harnesses: SANDY_AUTO_APPROVE_PRIVILEGED=1
    # bypasses the prompt and exports the collected keys without writing an
    # approval file. This is intentionally an env-only knob — the config
    # loader's passive allowlist does not include it, so a committed
    # .sandy/config cannot set it. Only a trusted shell or test harness can.
    if [ "${SANDY_AUTO_APPROVE_PRIVILEGED:-0}" = "1" ]; then
        while IFS= read -r _kv; do
            [ -z "$_kv" ] && continue
            export "$_kv"
        done <<< "$sorted"
        return 0
    fi

    # Already approved? First line of the file is the hash.
    if [ -f "$approval_file" ]; then
        local stored
        stored="$(head -n1 "$approval_file" 2>/dev/null)"
        if [ "$stored" = "$set_hash" ]; then
            while IFS= read -r _kv; do
                [ -z "$_kv" ] && continue
                export "$_kv"
            done <<< "$sorted"
            return 0
        fi
    fi

    # Not approved (or set changed) — surface the request.
    local _src
    _src="$(printf '%s\n' "${_PASSIVE_PRIVILEGED_SOURCES[@]}" | sort -u | head -n1)"
    echo "[sandy]" >&2
    echo "[sandy] Workspace config ($_src) wants to set privileged keys:" >&2
    while IFS= read -r _kv; do
        [ -z "$_kv" ] && continue
        echo "[sandy]   $_kv" >&2
    done <<< "$sorted"
    echo "[sandy]" >&2
    echo "[sandy] These affect security boundaries (SSH agent forwarding, permission" >&2
    echo "[sandy] prompts, LAN allowlist, credentials). Sandy refuses to honor them" >&2
    echo "[sandy] from workspace config by default because a committed .sandy/config" >&2
    echo "[sandy] from a cloned repo could exploit them to escape isolation or" >&2
    echo "[sandy] exfiltrate credentials." >&2
    echo "[sandy]" >&2
    echo "[sandy] If this is your own workspace and you trust this config, you can" >&2
    echo "[sandy] approve it once for $WORK_DIR." >&2
    echo "[sandy] The approval is tied to the exact set above — any edit re-prompts." >&2
    echo "[sandy]" >&2

    # Headless / non-interactive: fail closed.
    if [ "${_sandy_is_headless:-false}" = "true" ] || [ ! -t 0 ]; then
        echo "[sandy] Non-interactive session — dropping these keys." >&2
        echo "[sandy] Launch sandy interactively once from this directory to approve." >&2
        echo "[sandy]" >&2
        return 0
    fi

    local _ans
    printf '[sandy] Approve these keys for this workspace? [y/N] ' >&2
    IFS= read -r _ans </dev/tty || _ans=""
    case "$_ans" in
        y|Y|yes|YES|Yes)
            {
                printf '%s\n' "$set_hash"
                printf '# workspace: %s\n' "$WORK_DIR"
                printf '# approved:  %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)"
                printf '%s\n' "$sorted"
            } > "$approval_file"
            chmod 600 "$approval_file" 2>/dev/null || true
            while IFS= read -r _kv; do
                [ -z "$_kv" ] && continue
                export "$_kv"
            done <<< "$sorted"
            echo "[sandy] Approved. Future launches from this directory will proceed silently" >&2
            echo "[sandy] unless you edit the set. Revoke via: rm $approval_file" >&2
            ;;
        *)
            echo "[sandy] Not approved — dropping these keys for this launch." >&2
            echo "[sandy] (Edit $_src and relaunch to re-prompt.)" >&2
            ;;
    esac
}
_resolve_passive_privileged_approval

# Sanity: reject world-open SANDY_ALLOW_LAN_HOSTS values. Even from a
# privileged source, "0.0.0.0/0" negates the whole point of LAN isolation and
# is almost certainly a mistake, not a feature request.
if [ -n "${SANDY_ALLOW_LAN_HOSTS:-}" ]; then
    IFS=',' read -ra _sanity_hosts <<< "$SANDY_ALLOW_LAN_HOSTS"
    for _h in "${_sanity_hosts[@]}"; do
        _h="$(echo "$_h" | tr -d '[:space:]')"
        [ -z "$_h" ] && continue
        case "$_h" in
            0.0.0.0/0|::/0)
                echo "[sandy] ERROR: SANDY_ALLOW_LAN_HOSTS contains a world-open entry: $_h" >&2
                echo "[sandy]   This would negate sandy's LAN isolation. Refusing to start." >&2
                exit 1 ;;
        esac
    done
fi

# --- Resolve agent ---
# CLI --agent flag wins over all config sources (per-project, user, env)
[ -n "$SANDY_AGENT_OVERRIDE" ] && SANDY_AGENT="$SANDY_AGENT_OVERRIDE"
SANDY_AGENT="${SANDY_AGENT:-claude}"
# Aliases for common combos
case "$SANDY_AGENT" in
    all)  SANDY_AGENT="claude,gemini,codex" ;;
    both)
        error "SANDY_AGENT=both is no longer supported."
        error "  Use SANDY_AGENT=claude,gemini (or any comma-separated combo) instead."
        exit 1
        ;;
esac
# Parse comma-separated agent list and validate
IFS=',' read -ra _SANDY_AGENTS <<< "$SANDY_AGENT"
_SANDY_AGENT_COUNT="${#_SANDY_AGENTS[@]}"
for _a in "${_SANDY_AGENTS[@]}"; do
    case "$_a" in
        claude|gemini|codex) ;;
        *) echo "[sandy] ERROR: Invalid agent '$_a' in SANDY_AGENT='$SANDY_AGENT' (valid: claude, gemini, codex, or comma-separated combo)" >&2; exit 1 ;;
    esac
done
# Detect duplicates
if [ "$_SANDY_AGENT_COUNT" -ge 2 ]; then
    _seen=""
    for _a in "${_SANDY_AGENTS[@]}"; do
        case ",$_seen," in *,"$_a",*) echo "[sandy] ERROR: Duplicate agent '$_a' in SANDY_AGENT='$SANDY_AGENT'" >&2; exit 1 ;; esac
        _seen="$_seen,$_a"
    done
fi
_SANDY_IS_MULTI=false
[ "$_SANDY_AGENT_COUNT" -gt 1 ] && _SANDY_IS_MULTI=true
# Image selection: single agent gets its own image, multi-agent uses sandy-full
if [ "$_SANDY_IS_MULTI" = true ]; then
    IMAGE_NAME="sandy-full"
else
    case "$SANDY_AGENT" in
        claude) IMAGE_NAME="sandy-claude-code" ;;
        gemini) IMAGE_NAME="sandy-gemini-cli" ;;
        codex)  IMAGE_NAME="sandy-codex" ;;
    esac
fi
# Helper: check if a specific agent is in the resolved agent list
_sandy_agent_has() { case ",$SANDY_AGENT," in *,"$1",*) return 0 ;; esac; return 1; }
if ! _sandy_agent_has claude && [ -n "${SANDY_SKILL_PACKS:-}" ]; then
    echo "[sandy] ERROR: SANDY_SKILL_PACKS requires claude in SANDY_AGENT (got '$SANDY_AGENT')" >&2
    exit 1
fi
# Channels on non-Claude agents use the host-side tmux-inject relay. Only
# Telegram is supported; Discord still requires the Claude plugin path.
if [ -n "${SANDY_CHANNELS:-}" ]; then
    case ",$SANDY_CHANNELS," in
        *,discord,*)
            if ! _sandy_agent_has claude || [ "$_SANDY_IS_MULTI" = true ]; then
                echo "[sandy] ERROR: SANDY_CHANNELS=discord is only supported with SANDY_AGENT=claude (solo)" >&2
                exit 1
            fi ;;
    esac
fi
if [ "$SANDY_REMOTE_CONTROL" = true ]; then
    if ! _sandy_agent_has claude || [ "$_SANDY_IS_MULTI" = true ]; then
        echo "[sandy] ERROR: --remote is only supported with SANDY_AGENT=claude (solo)" >&2
        exit 1
    fi
fi
export SANDY_AGENT

ensure_agent_dockerfile
if [ "$_SANDY_IS_MULTI" = true ]; then
    DOCKERFILE_PATH="$SANDY_HOME/Dockerfile.full"
    BUILD_HASH_FILE_NAME=".build_hash_full"
else
    case "$SANDY_AGENT" in
        gemini)
            DOCKERFILE_PATH="$SANDY_HOME/Dockerfile.gemini"
            BUILD_HASH_FILE_NAME=".build_hash_gemini" ;;
        codex)
            DOCKERFILE_PATH="$SANDY_HOME/Dockerfile.codex"
            BUILD_HASH_FILE_NAME=".build_hash_codex" ;;
        *)
            DOCKERFILE_PATH="$SANDY_HOME/Dockerfile"
            BUILD_HASH_FILE_NAME=".build_hash" ;;
    esac
fi

SHORT_HASH="$(printf '%s' "$WORK_DIR" | sha256)"
SHORT_HASH="${SHORT_HASH%% *}"
SHORT_HASH="${SHORT_HASH:0:8}"
DIR_BASE="$(basename "$WORK_DIR" | tr -cd 'a-zA-Z0-9._-')"
DIR_BASE="${DIR_BASE:-project}"
SANDBOX_NAME="${DIR_BASE}-${SHORT_HASH}"
SANDBOX_DIR="$SANDY_HOME/sandboxes/${SANDBOX_NAME}"

# Compute container workspace path
if [[ "$WORK_DIR" == "$HOME"/* ]]; then
    SANDY_WORKSPACE="/home/claude/${WORK_DIR#$HOME/}"
else
    SANDY_WORKSPACE="$WORK_DIR"
fi

# Apply --rebuild flag (must come after ensure_build_files creates SANDY_HOME)
if [ "$SANDY_REBUILD" = true ]; then
    rm -f "$SANDY_HOME/.base_build_hash" "$SANDY_HOME/.build_hash" "$SANDY_HOME/.build_hash_gemini" "$SANDY_HOME/.build_hash_codex" "$SANDY_HOME/.build_hash_full" "$SANDY_HOME/.skills_build_hash"
    info "Build cache cleared. Images will be rebuilt."
fi

# --- Build images (two-phase: base + final) ---

# Phase 1: Base image (language runtimes — rebuilds rarely)
BASE_HASH="$(cat "$SANDY_HOME/Dockerfile.base" | sha256 | cut -d' ' -f1)"
BASE_HASH_FILE="$SANDY_HOME/.base_build_hash"
BASE_REBUILT=false
if [ ! -f "$BASE_HASH_FILE" ] || [ "$(cat "$BASE_HASH_FILE")" != "$BASE_HASH" ] || ! docker image inspect "$BASE_IMAGE_NAME" &>/dev/null; then
    info "Building base image (language runtimes) — this may take several minutes on first run..."
    docker build --no-cache -t "$BASE_IMAGE_NAME" -f "$SANDY_HOME/Dockerfile.base" "$SANDY_HOME"
    echo "$BASE_HASH" > "$BASE_HASH_FILE"
    BASE_REBUILT=true
else
    info "Base image up to date."
fi

# Phase 2: Final image (agent — rebuilds on agent updates or base change)
BUILD_HASH="$(cat "$DOCKERFILE_PATH" "$SANDY_HOME/entrypoint.sh" "$SANDY_HOME/user-setup.sh" "$SANDY_HOME/tmux.conf" | sha256 | cut -d' ' -f1)"
HASH_FILE="$SANDY_HOME/$BUILD_HASH_FILE_NAME"
NEEDS_BUILD=false
if [ ! -f "$HASH_FILE" ] || [ "$(cat "$HASH_FILE")" != "$BUILD_HASH" ] || [ "$BASE_REBUILT" = true ] || ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    NEEDS_BUILD=true
fi

# Check for newer agent version (skip if already rebuilding)
_check_claude_update() {
    local inst latest
    inst="$(docker run --rm --entrypoint cat "$IMAGE_NAME" /opt/claude-code/.version 2>/dev/null || true)"
    latest="$(curl -fsSL --max-time 5 https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/latest 2>/dev/null || true)"
    if [ -n "$latest" ] && [ -n "$inst" ] && [ "$latest" != "$inst" ]; then
        info "Claude Code update available: $inst → $latest"
        return 0
    fi
    return 1
}
_check_gemini_update() {
    local inst latest
    inst="$(docker run --rm --entrypoint cat "$IMAGE_NAME" /opt/gemini-cli/.version 2>/dev/null || true)"
    latest="$(curl -fsSL --max-time 5 'https://registry.npmjs.org/@google/gemini-cli/latest' 2>/dev/null \
        | grep -oE '"version"[[:space:]]*:[[:space:]]*"[^"]+"' | head -1 \
        | sed -E 's/.*"([^"]+)"$/\1/' || true)"
    if [ -n "$latest" ] && [ -n "$inst" ] && [ "$latest" != "$inst" ]; then
        info "Gemini CLI update available: $inst → $latest"
        return 0
    fi
    return 1
}
_check_codex_update() {
    local inst latest
    inst="$(docker run --rm --entrypoint cat "$IMAGE_NAME" /opt/codex/.version 2>/dev/null || true)"
    # Use /releases/latest — upstream flags the stable release; codex ships
    # 30+ releases/month, most marked as prereleases, and /releases/latest
    # filters them correctly without sandy inventing its own policy.
    latest="$(curl -fsSL --max-time 5 'https://api.github.com/repos/openai/codex/releases/latest' 2>/dev/null \
        | grep -oE '"tag_name"[[:space:]]*:[[:space:]]*"[^"]+"' | head -1 \
        | sed -E 's/.*"rust-v?([0-9][^"]*)"$/\1/' || true)"
    if [ -n "$latest" ] && [ -n "$inst" ] && [ "$latest" != "$inst" ]; then
        info "Codex CLI update available: $inst → $latest"
        return 0
    fi
    return 1
}
if [ "$NEEDS_BUILD" = false ]; then
    _sandy_agent_has claude && _check_claude_update && NEEDS_BUILD=true
    _sandy_agent_has gemini && [ "$NEEDS_BUILD" = false ] && _check_gemini_update && NEEDS_BUILD=true
    _sandy_agent_has codex  && [ "$NEEDS_BUILD" = false ] && _check_codex_update  && NEEDS_BUILD=true
fi

if [ "$NEEDS_BUILD" = true ]; then
    info "Building sandbox image (may take a few minutes)..."
    docker build -q --no-cache -t "$IMAGE_NAME" -f "$DOCKERFILE_PATH" "$SANDY_HOME"
    echo "$BUILD_HASH" > "$HASH_FILE"
else
    info "Sandbox image up to date."
fi

SKILLS_REBUILT=false

if [ "$SANDY_BUILD_ONLY" = true ]; then
    info "Build complete. Exiting (--build-only)."
    exit 0
fi

# --- Ensure the per-instance isolated network exists ---
CONTAINER_SUBNET=""
ensure_network() {
    info "Creating isolated network..."
    docker network create \
        --driver bridge \
        --ipv6=false \
        -o com.docker.network.bridge.name="$BRIDGE_NAME" \
        "$NETWORK_NAME" >/dev/null
    # Query the dynamically-assigned subnet and bridge name
    CONTAINER_SUBNET="$(docker network inspect "$NETWORK_NAME" --format '{{(index .IPAM.Config 0).Subnet}}')"
    BRIDGE_NAME="$(docker network inspect "$NETWORK_NAME" --format '{{index .Options "com.docker.network.bridge.name"}}')"
}

ensure_network

# --- Phase 2.5: Skill pack image (after config so SANDY_SKILL_PACKS is available) ---
if [ -n "${SANDY_SKILL_PACKS:-}" ]; then
    # Resolve latest versions from GitHub (caches locally for offline fallback)
    skill_pack_resolve_versions "$SANDY_SKILL_PACKS"

    # (Re)generate skill pack Dockerfiles (base + code) with resolved versions
    generate_skill_pack_dockerfiles "$SANDY_SKILL_PACKS"

    _pack_suffix="$(echo "$SANDY_SKILL_PACKS" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sort | tr '\n' '-' | sed 's/-$//' | tr '[:upper:]' '[:lower:]')"

    # --- Phase 2.5a: Skills base image (Playwright, Chromium — rarely changes) ---
    if [ -f "$SANDY_HOME/Dockerfile.skills-base.new" ]; then
        SKILLS_BASE_IMAGE="sandy-skills-base-${_pack_suffix}"
        if [ ! -f "$SANDY_HOME/Dockerfile.skills-base" ] || ! diff -q "$SANDY_HOME/Dockerfile.skills-base.new" "$SANDY_HOME/Dockerfile.skills-base" &>/dev/null; then
            mv "$SANDY_HOME/Dockerfile.skills-base.new" "$SANDY_HOME/Dockerfile.skills-base"
        else
            rm -f "$SANDY_HOME/Dockerfile.skills-base.new"
        fi

        SKILLS_BASE_HASH="$(cat "$SANDY_HOME/Dockerfile.skills-base" | sha256 | cut -d' ' -f1)"
        SKILLS_BASE_HASH_FILE="$SANDY_HOME/.skills_base_build_hash"

        SKILLS_BASE_NEEDS_BUILD=false
        if [ ! -f "$SKILLS_BASE_HASH_FILE" ] \
                || [ "$(cat "$SKILLS_BASE_HASH_FILE")" != "$SKILLS_BASE_HASH" ] \
                || [ "$NEEDS_BUILD" = true ] \
                || ! docker image inspect "$SKILLS_BASE_IMAGE" &>/dev/null; then
            SKILLS_BASE_NEEDS_BUILD=true
        fi

        if [ "$SKILLS_BASE_NEEDS_BUILD" = true ]; then
            info "Building skill pack base image (Playwright + Chromium)..."
            docker build -t "$SKILLS_BASE_IMAGE" \
                -f "$SANDY_HOME/Dockerfile.skills-base" "$SANDY_HOME"
            echo "$SKILLS_BASE_HASH" > "$SKILLS_BASE_HASH_FILE"
        else
            info "Skill pack base image up to date."
        fi
    fi

    # --- Phase 2.5b: Skills code image (gstack source + build — changes frequently) ---
    SKILLS_IMAGE_NAME="sandy-skills-${_pack_suffix}"
    if [ ! -f "$SANDY_HOME/Dockerfile.skills" ] || ! diff -q "$SANDY_HOME/Dockerfile.skills.new" "$SANDY_HOME/Dockerfile.skills" &>/dev/null; then
        mv "$SANDY_HOME/Dockerfile.skills.new" "$SANDY_HOME/Dockerfile.skills"
    else
        rm -f "$SANDY_HOME/Dockerfile.skills.new"
    fi

    SKILLS_BUILD_HASH="$(cat "$SANDY_HOME/Dockerfile.skills" | sha256 | cut -d' ' -f1)"
    SKILLS_HASH_FILE="$SANDY_HOME/.skills_build_hash"

    SKILLS_NEEDS_BUILD=false
    if [ ! -f "$SKILLS_HASH_FILE" ] \
            || [ "$(cat "$SKILLS_HASH_FILE")" != "$SKILLS_BUILD_HASH" ] \
            || [ "${SKILLS_BASE_NEEDS_BUILD:-false}" = true ] \
            || [ "$NEEDS_BUILD" = true ] \
            || ! docker image inspect "$SKILLS_IMAGE_NAME" &>/dev/null; then
        SKILLS_NEEDS_BUILD=true
    fi

    if [ "$SKILLS_NEEDS_BUILD" = true ]; then
        info "Building skill pack image (${SANDY_SKILL_PACKS})..."
        docker build --no-cache -t "$SKILLS_IMAGE_NAME" \
            -f "$SANDY_HOME/Dockerfile.skills" "$SANDY_HOME"
        echo "$SKILLS_BUILD_HASH" > "$SKILLS_HASH_FILE"
        SKILLS_REBUILT=true
    else
        info "Skill pack image up to date."
    fi
    IMAGE_NAME="$SKILLS_IMAGE_NAME"
elif [ -f "$SANDY_HOME/Dockerfile.skills" ]; then
    # Clean up stale skill pack Dockerfiles if packs were disabled
    rm -f "$SANDY_HOME/Dockerfile.skills" "$SANDY_HOME/Dockerfile.skills-base"
fi

# --- Detect available resources (after config sourcing so overrides work) ---
AVAILABLE_CPUS="$(docker info --format '{{.NCPU}}' 2>/dev/null || echo 2)"
AVAILABLE_MEM_GB="$(docker info --format '{{.MemTotal}}' 2>/dev/null | awk '{printf "%d", $1/1073741824}')"
# Validate: must be a positive integer, default to 4 on parse failure
if ! [[ "$AVAILABLE_MEM_GB" =~ ^[0-9]+$ ]] || [ "$AVAILABLE_MEM_GB" -eq 0 ]; then
    AVAILABLE_MEM_GB=4
fi
SANDY_CPUS="${SANDY_CPUS:-$AVAILABLE_CPUS}"
SANDY_MEM="${SANDY_MEM:-$(( AVAILABLE_MEM_GB > 2 ? AVAILABLE_MEM_GB - 1 : 2 ))g}"

# Preflight: SSH agent mode on macOS requires socat and python3 for the relay
if [ "${SANDY_SSH:-token}" = "agent" ] && [ "$(uname -s)" != "Linux" ]; then
    for _dep in socat python3; do
        if ! command -v "$_dep" &>/dev/null; then
            error "SANDY_SSH=agent requires $_dep on macOS."
            error "Install it: brew install $_dep"
            exit 1
        fi
    done
fi

# Workspace mutex. Only one sandy may run against a given workspace at a
# time — two concurrent agents editing the same codebase would step on each
# other's edits, and the sandbox-seeding / venv-materialization code paths
# assume exclusive ownership. `mkdir` is used as the lock primitive because
# it's atomic on every POSIX filesystem and needs no external dependency
# (unlike flock, which macOS doesn't ship by default). The lock is released
# by the cleanup trap on normal exit, Ctrl-C, or sandy crash. A SIGKILL
# (OOM, `kill -9`) leaves the lock dir behind — the error message on the
# next launch tells the user how to clear it.
mkdir -p "$SANDY_HOME/sandboxes"
SANDY_WORKSPACE_LOCK="$SANDY_HOME/sandboxes/.${SANDBOX_NAME}.lock"
if ! mkdir "$SANDY_WORKSPACE_LOCK" 2>/dev/null; then
    _holder_pid="$(cat "$SANDY_WORKSPACE_LOCK/pid" 2>/dev/null || echo unknown)"
    error "Another sandy is already running in this workspace (pid $_holder_pid)"
    error "  Workspace: $WORK_DIR"
    error "  If that process is dead, remove the stale lock:"
    error "    rm -rf '$SANDY_WORKSPACE_LOCK'"
    exit 1
fi
echo "$$" > "$SANDY_WORKSPACE_LOCK/pid"

SANDBOX_IS_NEW=false
if [ ! -d "$SANDBOX_DIR" ]; then
    info "Creating new sandbox: $SANDBOX_DIR"
    mkdir -p "$SANDBOX_DIR"
    SANDBOX_IS_NEW=true
fi

# Sandbox version marker. Written once on creation so future sandy launches
# can detect sandboxes that pre-date breaking changes to the container layout.
# .sandy_last_version is refreshed on every launch (useful for `sandy --doctor`
# style tooling, and for telling users exactly how stale their sandbox is).
_sandbox_created_ver_file="$SANDBOX_DIR/.sandy_created_version"
_sandbox_last_ver_file="$SANDBOX_DIR/.sandy_last_version"
if [ "$SANDBOX_IS_NEW" = "true" ]; then
    echo "$SANDY_VERSION" > "$_sandbox_created_ver_file"
elif [ ! -f "$_sandbox_created_ver_file" ]; then
    # Existing sandbox with no marker: created by a sandy that didn't write
    # the marker (i.e. pre-0.10.1). Treat as "unknown old" — warn against
    # the conservative threshold below.
    _sandbox_created_ver="unknown"
    warn "Sandbox predates version tracking (no .sandy_created_version file)."
    warn "  If this sandbox was created before sandy $SANDY_SANDBOX_MIN_COMPAT"
    warn "  (workspace path changed from /workspace → /home/claude/<rel>),"
    warn "  cached absolute paths (venv, .pth files, editable installs) may be broken."
    warn "  Recreate with:  rm -rf \"$SANDBOX_DIR\" && sandy --rebuild"
else
    _sandbox_created_ver="$(head -n1 "$_sandbox_created_ver_file" 2>/dev/null | tr -d '[:space:]')"
    if [ -n "$_sandbox_created_ver" ] && _ver_lt "$_sandbox_created_ver" "$SANDY_SANDBOX_MIN_COMPAT"; then
        warn "Sandbox was created by sandy $_sandbox_created_ver, which predates"
        warn "  the workspace mount path change in $SANDY_SANDBOX_MIN_COMPAT."
        warn "  Cached absolute paths (venv, .pth files, editable installs) may reference"
        warn "  /workspace/... and break silently. Recreate with:"
        warn "    rm -rf \"$SANDBOX_DIR\" && sandy --rebuild"
    fi
fi
echo "$SANDY_VERSION" > "$_sandbox_last_ver_file"

# Auto-migrate v1 layout → v1.5 layout: v1 used $SANDBOX_DIR itself as the
# Claude .claude/ root. v1.5 uses $SANDBOX_DIR/claude/ and $SANDBOX_DIR/gemini/
# as siblings so multi-agent mode can mount both. Idempotent: the sweep only
# moves entries that are still at the top level. The allowlist covers every
# known Claude-owned entry so partial migrations from earlier v1.5 builds get
# cleaned up on next launch.
_v1_claude_entries="settings.json projects plugins statsig channels hooks todos history.jsonl shell-snapshots backups cache commands file-history paste-cache plans sessions session-env tasks telemetry agents skills ide mcp-servers"
_v1_leftovers=""
for _e in $_v1_claude_entries; do
    [ -e "$SANDBOX_DIR/$_e" ] && _v1_leftovers="$_v1_leftovers $_e"
done
if [ -n "$_v1_leftovers" ]; then
    info "Migrating sandbox to v1.5 layout (claude/ subdir)...$_v1_leftovers"
    mkdir -p "$SANDBOX_DIR/claude"
    for _e in $_v1_leftovers; do
        if [ ! -e "$SANDBOX_DIR/claude/$_e" ]; then
            # Clean move — nothing in the way.
            mv "$SANDBOX_DIR/$_e" "$SANDBOX_DIR/claude/" 2>/dev/null || true
        else
            # Conflict: claude/$_e already exists (Claude Code has been writing
            # there since the partial migration). The top-level copy is stale —
            # quarantine it under .v1-backup/ rather than risk a deep merge.
            mkdir -p "$SANDBOX_DIR/.v1-backup"
            _ts="$(date +%s)"
            mv "$SANDBOX_DIR/$_e" "$SANDBOX_DIR/.v1-backup/${_e}.${_ts}" 2>/dev/null || true
            info "  Stale $_e quarantined to .v1-backup/${_e}.${_ts} (claude/$_e is authoritative)"
        fi
    done
fi

# Ensure per-agent config dirs exist so bind mounts always land on real dirs.
if _sandy_agent_has claude; then
    mkdir -p "$SANDBOX_DIR/claude"
fi
if _sandy_agent_has codex; then
    mkdir -p "$SANDBOX_DIR/codex"
    # Clean up empty auth.json left by a previous codex session. Codex creates
    # this file on first run but leaves it empty when using API key auth. On
    # subsequent launches, codex crashes trying to parse the empty JSON.
    if [ -f "$SANDBOX_DIR/codex/auth.json" ] && [ ! -s "$SANDBOX_DIR/codex/auth.json" ]; then
        rm -f "$SANDBOX_DIR/codex/auth.json"
    fi
    # Seed config.toml with sandy-required defaults (first run only). Without
    # this, codex's Landlock sandbox would try to initialize inside sandy's
    # Docker container and either fail weirdly or over-restrict the agent.
    # sandbox_mode here plus --sandbox danger-full-access on the CLI is
    # belt-and-suspenders. The [notice] block suppresses all first-run prompts.
    if [ ! -f "$SANDBOX_DIR/codex/config.toml" ] || [ ! -s "$SANDBOX_DIR/codex/config.toml" ] \
       || ! grep -q 'sandbox_mode' "$SANDBOX_DIR/codex/config.toml" 2>/dev/null; then
        cat > "$SANDBOX_DIR/codex/config.toml" <<'CODEX_TOML'
# Written by sandy on first launch. Safe to edit, but sandbox_mode must stay
# "danger-full-access" — sandy provides outer isolation; codex's Landlock
# sandbox does not nest cleanly in Docker containers.
model = "gpt-5.4"
sandbox_mode = "danger-full-access"

[notice]
hide_full_access_warning = true
hide_gpt5_1_migration_prompt = true
"hide_gpt-5.1-codex-max_migration_prompt" = true
hide_rate_limit_model_nudge = true
hide_world_writable_warning = true

# [projects."<workspace>"] trust_level = "trusted" is appended at session
# start by user-setup.sh, where $SANDY_WORKSPACE is known.
CODEX_TOML
        info "  Seeded .codex/config.toml"
    fi
fi

if _sandy_agent_has gemini; then
    mkdir -p "$SANDBOX_DIR/gemini"
    # Remove files that become stale/corrupted across container rebuilds.
    # gemini-credentials.json: created by gemini without keychain access, becomes
    #   "corrupted" on next launch. Sandy provides credentials via env vars and
    #   ephemeral mounts, so this file is never needed.
    # extension_integrity.json: integrity hashes tied to a specific container's
    #   filesystem; invalid after image rebuild.
    rm -f "$SANDBOX_DIR/gemini/gemini-credentials.json" \
          "$SANDBOX_DIR/gemini/extension_integrity.json"
    # Seed settings.json from host's ~/.gemini/ if present (first run only)
    if [ ! -f "$SANDBOX_DIR/gemini/settings.json" ]; then
        if [ -f "$HOME/.gemini/settings.json" ]; then
            cp "$HOME/.gemini/settings.json" "$SANDBOX_DIR/gemini/settings.json"
            info "  Seeded .gemini/settings.json"
        else
            echo '{}' > "$SANDBOX_DIR/gemini/settings.json"
        fi
        # Merge sandy defaults: disable Gemini's own sandbox (sandy provides isolation)
        if command -v node &>/dev/null; then
            node -e '
                const fs = require("fs");
                const f = process.argv[1];
                let s;
                try { s = JSON.parse(fs.readFileSync(f, "utf8")); } catch(e) { s = {}; }
                if (!s.tools) s.tools = {};
                if (!("sandbox" in s.tools)) s.tools.sandbox = "none";
                fs.writeFileSync(f, JSON.stringify(s, null, 2) + "\n");
            ' "$SANDBOX_DIR/gemini/settings.json" 2>/dev/null || true
        fi
    fi
fi

# Seed Claude settings.json directly into $SANDBOX_DIR/claude/settings.json
# (rw via the parent $SANDBOX_DIR/claude mount — no :ro overlay). Regenerated
# on every launch with merge-preserving semantics:
#
#   - Sandy-managed keys are re-derived from host settings.json + defaults
#     every launch (so host changes propagate, and deprecated marketplaces
#     are scrubbed). This partially mitigates F6: if the agent tampers with
#     these keys mid-session, the next launch resets them.
#   - Agent-owned keys like `enabledPlugins` are preserved across launches
#     so `/plugin install` persists. These are read from the previous
#     sandbox settings.json if present.
#
# The settings.json mount is rw so Claude Code can write to it at runtime
# (e.g. during `/plugin install`). The trade-off vs a strict :ro overlay is
# that the agent *can* modify its own settings within a session, but those
# modifications are partially overwritten on the next launch. Full
# reset-on-launch is not feasible without breaking plugin installs.
if _sandy_agent_has claude; then
    SEED_SETTINGS="$SANDBOX_DIR/claude/settings.json"
    # Clean up the stale pre-0.11.3 sidecar if it exists. Pre-0.11.3 sandy wrote
    # a :ro sidecar at $SANDBOX_DIR/.seed-settings.json; 0.11.3+ writes directly
    # to the rw sandbox settings.json. The old sidecar is dead state.
    [ -f "$SANDBOX_DIR/.seed-settings.json" ] && rm -f "$SANDBOX_DIR/.seed-settings.json"
    SEED_HOST_SRC=""
    if [ -f "$HOME/.claude/settings.json" ]; then
        SEED_HOST_SRC="$HOME/.claude/settings.json"
    fi
    # Merge sandy-required defaults into settings.json (idempotent, runs every
    # launch). Base = host settings.json (re-read every launch so host edits
    # propagate). Overlay = `enabledPlugins` preserved from previous sandbox
    # settings.json (so plugin installs survive across launches).
    if command -v node &>/dev/null; then
        SEED_HOST_SRC="$SEED_HOST_SRC" node -e "
            const fs = require('fs');
            const dst = process.argv[1];
            const hostSrc = process.env.SEED_HOST_SRC || '';
            function readJson(path) {
                if (!path) return {};
                try {
                    let raw = fs.readFileSync(path, 'utf8');
                    raw = raw.replace(/,(\s*[}\]])/g, '\$1');
                    raw = raw.replace(/(\"[^\"]*\")\s*\n(\s*\")/g, '\$1,\n\$2');
                    return JSON.parse(raw);
                } catch (e) { return {}; }
            }
            // Base: fresh host snapshot every launch.
            let s = readJson(hostSrc);
            // Preserve agent-owned keys from the previous sandbox settings.json.
            const prev = readJson(dst);
            if (prev.enabledPlugins) s.enabledPlugins = prev.enabledPlugins;
            const skip = (process.env.SANDY_SKIP_PERMISSIONS || 'true') !== 'false';
            const defaults = {teammateMode:'tmux', spinnerTipsEnabled:false, skipDangerousModePermissionPrompt:skip};
            for (const [k,v] of Object.entries(defaults)) { if (!(k in s)) s[k]=v; }
            // Configure plugin marketplaces (idempotent); drop deprecated ones.
            if (!s.extraKnownMarketplaces) s.extraKnownMarketplaces = {};
            const required = {
                'claude-plugins-official': { source: { source: 'github', repo: 'anthropics/claude-plugins-official' } },
                'sandy-plugins': { source: { source: 'github', repo: 'rappdw/sandy-plugins' } }
            };
            const deprecated = ['thinkkit', 'ait', 'pka-skills'];
            for (const name of deprecated) { delete s.extraKnownMarketplaces[name]; }
            for (const [name, cfg] of Object.entries(required)) {
                if (!s.extraKnownMarketplaces[name]) s.extraKnownMarketplaces[name] = cfg;
            }
            fs.writeFileSync(dst, JSON.stringify(s, null, 2) + '\n');
        " "$SEED_SETTINGS"
    elif command -v jq &>/dev/null; then
        # jq fallback: preserve enabledPlugins from existing sandbox settings
        # (if any), overlay onto fresh host snapshot.
        skip_perm="true"
        [ "${SANDY_SKIP_PERMISSIONS:-true}" = "false" ] && skip_perm="false"
        _prev_plugins='null'
        if [ -f "$SEED_SETTINGS" ]; then
            _prev_plugins="$(jq -c '.enabledPlugins // null' "$SEED_SETTINGS" 2>/dev/null || echo 'null')"
        fi
        _base_src="$SEED_HOST_SRC"
        [ -z "$_base_src" ] && _base_src=/dev/null
        jq --arg skip "$skip_perm" --argjson prev "$_prev_plugins" '
            (if . == null then {} else . end) |
            .teammateMode //= "tmux" |
            .spinnerTipsEnabled //= false |
            .skipDangerousModePermissionPrompt //= ($skip == "true") |
            (if $prev != null then .enabledPlugins = $prev else . end) |
            del(.extraKnownMarketplaces.thinkkit) |
            del(.extraKnownMarketplaces.ait) |
            del(.extraKnownMarketplaces["pka-skills"]) |
            .extraKnownMarketplaces["claude-plugins-official"] //= {"source":{"source":"github","repo":"anthropics/claude-plugins-official"}} |
            .extraKnownMarketplaces["sandy-plugins"] //= {"source":{"source":"github","repo":"rappdw/sandy-plugins"}}
        ' "$_base_src" > "$SEED_SETTINGS.tmp" 2>/dev/null && mv "$SEED_SETTINGS.tmp" "$SEED_SETTINGS"
    else
        # Last resort: write defaults only if no file exists yet.
        if [ ! -f "$SEED_SETTINGS" ]; then
            skip_perm="true"
            [ "${SANDY_SKIP_PERMISSIONS:-true}" = "false" ] && skip_perm="false"
            printf '{"teammateMode":"tmux","spinnerTipsEnabled":false,"skipDangerousModePermissionPrompt":%s}\n' "$skip_perm" > "$SEED_SETTINGS"
        fi
    fi
    if [ "$SANDBOX_IS_NEW" = "true" ]; then
        [ -f "$HOME/.claude/settings.json" ] && info "  Seeded settings.json"
        # Seed statsig cache for feature flags on first run (refreshed every launch below)
        if [ -d "$HOME/.claude/statsig" ]; then
            cp -r "$HOME/.claude/statsig" "$SANDBOX_DIR/claude/statsig"
            info "  Seeded statsig/"
        fi
        # NOTE: Plugin marketplace catalogs are NOT seeded from host — the sandy-plugins
        # marketplace is configured via extraKnownMarketplaces in user-setup.sh (baked into
        # the image). Claude Code fetches the catalog on first /plugin browse.
    fi
fi  # end Claude settings seeding
if [ "$SANDBOX_IS_NEW" = "false" ]; then
    info "Reusing sandbox: $SANDBOX_DIR"
fi

# Ensure persistent package directories exist (created once, reused across sessions)
mkdir -p "$SANDBOX_DIR/pip"                 # PYTHONUSERBASE (pip install --user)
mkdir -p "$SANDBOX_DIR/uv"                 # uv-managed Python versions
mkdir -p "$SANDBOX_DIR/npm-global"         # npm -g installs
mkdir -p "$SANDBOX_DIR/go"                 # GOPATH (go install)
mkdir -p "$SANDBOX_DIR/cargo"              # cargo install

# Workspace .venv overlay. If the host workspace has a .venv/, we shadow it
# with a sandbox-owned venv so (a) the host venv is never touched and
# (b) the in-container venv uses a Linux interpreter that actually works.
# Opt out with SANDY_VENV_OVERLAY=0. Skipped for symlinked .venv (too risky —
# could point anywhere) and for projects with no .venv (no overlay needed).
SANDY_VENV_OVERLAY_ACTIVE=false
SANDY_VENV_PYTHON_VERSION=""
if [ "${SANDY_VENV_OVERLAY:-1}" != "0" ] \
   && [ -d "$WORK_DIR/.venv" ] \
   && [ ! -L "$WORK_DIR/.venv" ]; then
    SANDY_VENV_OVERLAY_ACTIVE=true
    # Learn the host's wanted Python version. Precedence:
    #   1. .python-version (explicit, user-maintained)
    #   2. .venv/pyvenv.cfg (what uv actually used when the host venv was built)
    # If both are present, .python-version wins — it's the authoritative source
    # the user edits; pyvenv.cfg is a by-product of whichever uv run happened to
    # create the venv and can drift if the user changed .python-version afterward.
    if [ -f "$WORK_DIR/.python-version" ]; then
        SANDY_VENV_PYTHON_VERSION="$(tr -d '[:space:]' < "$WORK_DIR/.python-version" | cut -d. -f1-2)"
    elif [ -f "$WORK_DIR/.venv/pyvenv.cfg" ]; then
        # Newer uv writes both `version = 3.10.16` and `version_info = 3.10.16.final.0`;
        # either works. cut -d. -f1-2 normalizes to major.minor. Guarded with
        # `|| true` so a malformed cfg (no version line → grep exits 1) doesn't
        # abort sandy under set -euo pipefail.
        SANDY_VENV_PYTHON_VERSION="$( { grep -E '^version(_info)?[[:space:]]*=' "$WORK_DIR/.venv/pyvenv.cfg" \
            | head -1 | sed -E 's/.*=[[:space:]]*//' | cut -d. -f1-2 | tr -d '[:space:]'; } || true )"
    fi
    # Validate: if what we parsed doesn't look like major.minor, drop it and let
    # the container fall back to its default. Prevents garbage like "3.10.16.final.0"
    # or a stray shell fragment from reaching `uv venv --python`.
    if [ -n "$SANDY_VENV_PYTHON_VERSION" ] && [[ ! "$SANDY_VENV_PYTHON_VERSION" =~ ^[0-9]+\.[0-9]+$ ]]; then
        warn "Ignoring unparseable Python version '$SANDY_VENV_PYTHON_VERSION' — using container default"
        SANDY_VENV_PYTHON_VERSION=""
    fi
    mkdir -p "$SANDBOX_DIR/venv"               # sandbox-owned venv overlay
    if [ "$SANDBOX_IS_NEW" = "true" ] || [ -z "$(ls -A "$SANDBOX_DIR/venv" 2>/dev/null)" ]; then
        if [ -n "$SANDY_VENV_PYTHON_VERSION" ]; then
            info "Detected host .venv (Python $SANDY_VENV_PYTHON_VERSION) — will materialize sandbox overlay on launch"
        else
            info "Detected host .venv — will materialize sandbox overlay on launch"
        fi
    fi
elif [ "${SANDY_VENV_OVERLAY:-1}" != "0" ] && [ -L "$WORK_DIR/.venv" ]; then
    # Symlinked .venv (e.g. pointing into a monorepo-shared venv or a workdir
    # above $WORK_DIR). Too risky to overlay — the symlink target may be a real
    # host path that our bind mount would shadow unpredictably. User sees a
    # clear signal instead of silently wondering why the overlay didn't engage.
    info "Skipping .venv overlay — $WORK_DIR/.venv is a symlink"
fi
# Skill pack persistent state directories
case ",${SANDY_SKILL_PACKS:-}," in
    *,gstack,*) mkdir -p "$SANDBOX_DIR/gstack" ;;  # ~/.gstack (project state, analytics)
esac

# Always refresh statsig cache (feature flags may have changed since sandbox was created)
if _sandy_agent_has claude && [ -d "$HOME/.claude/statsig" ]; then
    rm -rf "$SANDBOX_DIR/claude/statsig"
    cp -r "$HOME/.claude/statsig" "$SANDBOX_DIR/claude/statsig"
fi

# cmux auto-setup: if running inside cmux, install notification hook (Claude-only)
if _sandy_agent_has claude && [ -n "${CMUX_WORKSPACE_ID:-}" ] && [ ! -d "$HOME/.claude/hooks" ]; then
    info "cmux detected — installing notification hook"
    mkdir -p "$SANDBOX_DIR/claude/hooks"
    cat > "$SANDBOX_DIR/claude/hooks/cmux-notify.sh" <<'CMUXHOOK'
#!/bin/bash
# Auto-generated by sandy for cmux terminal notification support.
# Emits OSC 777 escape sequences that cmux renders as notification rings,
# sidebar badges, and macOS desktop alerts.
INPUT=$(cat)
EVENT_TYPE=$(echo "$INPUT" | jq -r '.type // "unknown"')
case "$EVENT_TYPE" in
    permission_prompt)
        printf '\e]777;notify;Claude Code;Permission needed\a' ;;
    idle_prompt)
        printf '\e]777;notify;Claude Code;Waiting for input\a' ;;
esac
CMUXHOOK
    chmod +x "$SANDBOX_DIR/claude/hooks/cmux-notify.sh"
    # Merge notification hook into the sandbox settings.json (now rw). The seed
    # block above is idempotent, and this runs every launch so the hook is
    # always registered if cmux is detected.
    if [ -f "$SEED_SETTINGS" ] && command -v node &>/dev/null; then
        node -e '
            const fs = require("fs");
            const f = process.argv[1];
            let s;
            try { s = JSON.parse(fs.readFileSync(f, "utf8")); } catch(e) { s = {}; }
            if (!s.hooks) s.hooks = {};
            if (!s.hooks.Notification) s.hooks.Notification = [];
            // Only add if not already configured
            const hasCmux = s.hooks.Notification.some(h =>
                h.hooks && h.hooks.some(hh => hh.command && hh.command.includes("cmux-notify"))
            );
            if (!hasCmux) {
                s.hooks.Notification.push({
                    matcher: "",
                    hooks: [{
                        type: "command",
                        command: "/home/claude/.claude/hooks/cmux-notify.sh"
                    }]
                });
            }
            fs.writeFileSync(f, JSON.stringify(s, null, 2) + "\n");
        ' "$SEED_SETTINGS"
    fi
fi

