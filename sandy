# --- Ephemeral credential loading (fresh each launch, never persisted in sandbox) ---
# Helper: read credentials JSON from file or macOS Keychain
load_credentials() {
    if [ -f "$HOME/.claude/.credentials.json" ]; then
        cat "$HOME/.claude/.credentials.json"
    elif [[ "$(uname -s)" == "Darwin" ]]; then
        security find-generic-password -s "Claude Code-credentials" -a "$(whoami)" -w 2>/dev/null || true
    fi
}

# Helper: check if OAuth token is expired or expiring within 5 minutes
token_needs_refresh() {
    local creds="$1"
    [ -z "$creds" ] && return 1  # no credentials → nothing to refresh
    if command -v node &>/dev/null; then
        node -e "
            try {
                const c = JSON.parse(process.argv[1]);
                const exp = c.claudeAiOauth?.expiresAt;
                if (!exp) process.exit(1);  // no OAuth token
                const bufferMs = 5 * 60 * 1000;  // 5 minute buffer
                process.exit(Date.now() + bufferMs > exp ? 0 : 1);
            } catch(e) { process.exit(1); }
        " "$creds"
    elif command -v python3 &>/dev/null; then
        python3 -c "
import json, sys, time
try:
    c = json.loads(sys.argv[1])
    exp = c.get('claudeAiOauth', {}).get('expiresAt')
    if not exp:
        sys.exit(1)
    buffer_ms = 5 * 60 * 1000
    sys.exit(0 if time.time() * 1000 + buffer_ms > exp else 1)
except Exception:
    sys.exit(1)
" "$creds"
    else
        warn "Neither node nor python3 found; cannot check token expiry"
        return 1
    fi
}

# --- Credential setup ---
# Long-lived token (from `claude setup-token`) takes precedence over OAuth credentials.
# When set via .sandy/config or .sandy/.secrets, skip the entire credential file flow.
CRED_TMPDIR=""
GEMINI_CRED_TMPDIR=""
GEMINI_ADC_MOUNT=""

# Gemini credentials: priority is GEMINI_API_KEY → ephemeral OAuth tokens.json →
# Google Application Default Credentials. OAuth and ADC are not mutually
# exclusive — both can be mounted.
load_gemini_credentials() {
    local mode="${SANDY_GEMINI_AUTH:-auto}"
    GEMINI_SELECTED_AUTH=""
    if [ "$mode" = "api_key" ] || [ "$mode" = "auto" ]; then
        if [ -n "${GEMINI_API_KEY:-}" ]; then
            info "Using GEMINI_API_KEY"
            GEMINI_SELECTED_AUTH="gemini-api-key"
            [ "$mode" = "api_key" ] && _gemini_write_auth_type && return 0
        fi
    fi
    if [ "$mode" = "oauth" ] || [ "$mode" = "auto" ]; then
        if [ -f "$HOME/.gemini/tokens.json" ]; then
            GEMINI_CRED_TMPDIR="$(mktemp -d)"
            cp "$HOME/.gemini/tokens.json" "$GEMINI_CRED_TMPDIR/tokens.json"
            chmod 600 "$GEMINI_CRED_TMPDIR/tokens.json"
            info "Loaded Gemini OAuth tokens from host"
            [ -z "$GEMINI_SELECTED_AUTH" ] && GEMINI_SELECTED_AUTH="oauth-personal"
        fi
    fi
    if [ "$mode" = "adc" ] || [ "$mode" = "auto" ]; then
        if [ -f "$HOME/.config/gcloud/application_default_credentials.json" ]; then
            GEMINI_ADC_MOUNT="$HOME/.config/gcloud/application_default_credentials.json"
            info "Loaded Google Application Default Credentials"
            [ -z "$GEMINI_SELECTED_AUTH" ] && GEMINI_SELECTED_AUTH="vertex-ai"
        fi
    fi
    if [ -z "${GEMINI_API_KEY:-}" ] && [ -z "$GEMINI_CRED_TMPDIR" ] && [ -z "$GEMINI_ADC_MOUNT" ]; then
        warn "No Gemini credentials found. Set GEMINI_API_KEY, run 'gemini auth' on host, or run 'gcloud auth application-default login'"
    fi
    _gemini_write_auth_type
}

# Write selectedAuthType into the sandbox's .gemini/settings.json so Gemini CLI
# skips its first-run auth picker. Called from load_gemini_credentials().
_gemini_write_auth_type() {
    [ -z "$GEMINI_SELECTED_AUTH" ] && return 0
    local f="$SANDBOX_DIR/gemini/settings.json"
    [ -f "$f" ] || echo '{}' > "$f"
    if command -v node &>/dev/null; then
        SANDY_GEMINI_AUTH_TYPE="$GEMINI_SELECTED_AUTH" node -e '
            const fs = require("fs");
            const f = process.argv[1];
            let s;
            try { s = JSON.parse(fs.readFileSync(f, "utf8")); } catch(e) { s = {}; }
            s.selectedAuthType = process.env.SANDY_GEMINI_AUTH_TYPE;
            // Older Gemini CLI versions also look for the type under security.auth
            if (!s.security) s.security = {};
            if (!s.security.auth) s.security.auth = {};
            s.security.auth.selectedType = process.env.SANDY_GEMINI_AUTH_TYPE;
            fs.writeFileSync(f, JSON.stringify(s, null, 2) + "\n");
        ' "$f" 2>/dev/null || true
    fi
}

if [ "$SANDY_AGENT" = "gemini" ] || [ "$SANDY_AGENT" = "both" ]; then
    load_gemini_credentials
fi

if [ "$SANDY_AGENT" = "gemini" ]; then
    : # Claude credential flow skipped for pure-gemini sessions
elif [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    info "Using long-lived OAuth token"
else
    CRED_JSON="$(load_credentials)"

    # Refresh expired OAuth tokens before launching the container
    # Helper: detect if we can open a browser (headless servers cannot)
    can_open_browser() {
        # macOS: `open` always works and the user is local
        [[ "$(uname -s)" == "Darwin" ]] && return 0
        # Linux: too many false positives (DISPLAY set by NoMachine/X server on
        # headless servers, remote sessions via mosh/SSH). The /login flow inside
        # the session works everywhere, so don't attempt browser auth on Linux.
        return 1
    }

    if token_needs_refresh "$CRED_JSON"; then
        if can_open_browser && command -v claude &>/dev/null; then
            warn "OAuth token expired or expiring soon. Refreshing..."
            claude auth login
            CRED_JSON="$(load_credentials)"
            if token_needs_refresh "$CRED_JSON"; then
                error "Token still expired after login. Continuing anyway..."
            else
                info "OAuth token refreshed successfully."
            fi
        else
            warn "OAuth token expired. Use /login inside the session to re-authenticate."
        fi
    fi

    if [ -n "$CRED_JSON" ]; then
        CRED_TMPDIR="$(mktemp -d)"
        printf '%s\n' "$CRED_JSON" > "$CRED_TMPDIR/.credentials.json"
        chmod 600 "$CRED_TMPDIR/.credentials.json"
        info "Loaded credentials"
    fi
fi

