# Look up a metadata field (type|default|pattern|description) for a key.
# Usage: _sandy_key_meta_field SANDY_MODEL type → "string"
_sandy_key_meta_field() {
    local key="$1" field="$2"
    local line
    line="$(_sandy_key_metadata | awk -F'|' -v k="$key" '$1==k {print; exit}')"
    [ -z "$line" ] && return 0
    case "$field" in
        type)        echo "$line" | awk -F'|' '{print $2}' ;;
        default)     echo "$line" | awk -F'|' '{print $3}' ;;
        pattern)     echo "$line" | awk -F'|' '{print $4}' ;;
        since)       echo "$line" | awk -F'|' '{print $5}' ;;
        stability)   echo "$line" | awk -F'|' '{print $6}' ;;
        description) echo "$line" | awk -F'|' '{print $7}' ;;
    esac
}

# Escape a string for JSON: backslash, quote, newline, carriage return, tab,
# plus wrapping double quotes. No external deps.
_json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '"%s"' "$s"
}

# Emit a `"key": <value>` pair (value already JSON-formatted — caller's job
# to wrap strings via _json_escape and pass booleans/nulls literally).
_json_kv() { printf '"%s":%s' "$1" "$2"; }

# Shared suffix pipeline for skill-pack image names (sandy-skills-base-<suffix>,
# sandy-skills-<suffix>): comma-separated pack list -> sorted, trimmed,
# hyphen-joined, lowercased suffix. Extracted (#36) from two build-path call
# sites (generate_skill_pack_dockerfiles's skills-base name, and the Phase 2.5
# SANDY_SKILL_PACKS build block) plus the orphaned-skills-image lister below,
# so all three compute the IDENTICAL suffix from the same pack list — DEC-4b
# single source of truth. Drift here would make the lister's in-use set
# silently diverge from what a real launch actually names an image. Defined
# early (well before both build call sites and the --gc listers) so every
# consumer — including --print-state's fast-path dispatch, which can exit
# before the script's linear execution reaches either build site — resolves
# it.
_sandy_skill_pack_suffix() {
    printf '%s' "$1" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sort | tr '\n' '-' | sed 's/-$//' | tr '[:upper:]' '[:lower:]'
}

# Emit a JSON array from lines on stdin (each line = one string element).
# Empty input → "[]". Used for string-list fields (choices, sources, etc.).
_json_str_array() {
    local first=1
    printf '['
    while IFS= read -r _line; do
        [ -z "$_line" ] && continue
        [ $first -eq 0 ] && printf ','
        first=0
        _json_escape "$_line"
    done
    printf ']'
}

# Emit a JSON string array from comma-separated input.
# "a,b,c" → ["a","b","c"]. Empty input → [].
_json_csv_array() {
    local csv="$1"
    [ -z "$csv" ] && { printf '[]'; return; }
    printf '['
    local first=1 _item
    IFS=',' read -ra _items <<< "$csv"
    for _item in "${_items[@]}"; do
        _item="${_item# }"; _item="${_item% }"
        [ $first -eq 0 ] && printf ','
        first=0
        _json_escape "$_item"
    done
    printf ']'
}

# Build the JSON object for one config key. Output goes to stdout with no
# trailing comma — caller handles separation.
# Args: $1=key  $2=tier (privileged|passive|env_only)
_emit_key_object() {
    local key="$1" tier="$2"
    local type default pattern since stability description
    type="$(_sandy_key_meta_field "$key" type)"
    default="$(_sandy_key_meta_field "$key" default)"
    pattern="$(_sandy_key_meta_field "$key" pattern)"
    since="$(_sandy_key_meta_field "$key" since)"
    stability="$(_sandy_key_meta_field "$key" stability)"
    description="$(_sandy_key_meta_field "$key" description)"
    [ -z "$type" ] && type="string"
    [ -z "$stability" ] && stability="stable"

    printf '{'
    _json_kv name "$(_json_escape "$key")"

    # type + choices: split enum:v1,v2 into separate fields
    case "$type" in
        enum:*)
            printf ','; _json_kv type '"enum"'
            printf ','; _json_kv choices "$(_json_csv_array "${type#enum:}")"
            ;;
        *)
            printf ','; _json_kv type "$(_json_escape "$type")"
            ;;
    esac

    [ -n "$default"     ] && { printf ','; _json_kv default     "$(_json_escape "$default")"; }
    [ -n "$pattern"     ] && { printf ','; _json_kv pattern     "$(_json_escape "$pattern")"; }
    [ -n "$since"       ] && { printf ','; _json_kv since       "$(_json_escape "$since")"; }
    printf ','; _json_kv stability "$(_json_escape "$stability")"
    [ -n "$description" ] && { printf ','; _json_kv description "$(_json_escape "$description")"; }

    # Sources by tier. Privileged keys read from home_config, home_secrets,
    # env and require approval if seen in workspace. Passive keys read from
    # any source. Env-only keys read only from the environment.
    printf ','
    case "$tier" in
        privileged)
            _json_kv sources '["home_config","home_secrets","env"]'
            printf ','; _json_kv passive_approval_required 'true'
            ;;
        passive)
            _json_kv sources '["home_config","workspace_config","env"]'
            ;;
        env_only)
            _json_kv sources '["env"]'
            ;;
    esac

    printf '}'
}

# Emit the static schema JSON.
_sandy_emit_schema() {
    local commit
    # sandy_full_version() is "<SANDY_VERSION>-<shorthash>" when a hash is known,
    # else just "<SANDY_VERSION>". Strip the version PREFIX to isolate the hash —
    # NOT `##*-`, which for a suffixed version with no hash (e.g. "1.0.0-rc1")
    # would yield the version's own suffix ("rc1") and report it as a commit.
    commit="$(sandy_full_version)"
    commit="${commit#"$SANDY_VERSION"}"   # "" when no hash, "-<hash>" otherwise
    commit="${commit#-}"                  # drop the leading separator

    printf '{'
    _json_kv schema_version "$SANDY_SCHEMA_VERSION"

    printf ',"sandy":{'
    _json_kv version "$(_json_escape "$SANDY_VERSION")"
    printf ','; _json_kv commit "$(_json_escape "$commit")"
    printf ','; _json_kv sandbox_min_compat "$(_json_escape "$SANDY_SANDBOX_MIN_COMPAT")"
    printf '}'

    # config {privileged_keys, passive_keys, env_only_keys}
    printf ',"config":{'
    local first=1 k
    printf '"privileged_keys":['
    first=1
    for k in "${SANDY_PRIVILEGED_KEYS[@]}"; do
        [ $first -eq 0 ] && printf ','
        first=0
        _emit_key_object "$k" privileged
    done
    printf ']'

    printf ',"passive_keys":['
    first=1
    for k in "${SANDY_PASSIVE_KEYS[@]}"; do
        [ $first -eq 0 ] && printf ','
        first=0
        _emit_key_object "$k" passive
    done
    printf ']'

    printf ',"env_only_keys":['
    first=1
    for k in "${SANDY_ENV_ONLY_KEYS[@]}"; do
        [ $first -eq 0 ] && printf ','
        first=0
        _emit_key_object "$k" env_only
    done
    printf ']'
    printf '}'

    # cli_flags — hand-curated; intentionally limited to the user-visible set.
    printf ',"cli_flags":['
    printf '{'; _json_kv name '"--rebuild"';      printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Force rebuild of sandy images."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--build-only"';   printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Build images and exit (for CI)."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--new"';          printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Start a fresh session (default: resume last)."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--resume"';       printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Open session picker."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--remote"';       printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Run as a remote-controlled Claude session."';     printf ','; _json_kv agents '["claude"]'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--upgrade"';      printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Self-update sandy to the latest release."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--agent"';        printf ','; _json_kv type '"string"'; printf ','; _json_kv arg_name '"LIST"'; printf ','; _json_kv description '"Agent(s) for this run (overrides SANDY_AGENT)."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--help"';         printf ','; _json_kv short '"-h"';    printf ','; _json_kv type '"flag"'; printf ','; _json_kv description '"Show help."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--version"';      printf ','; _json_kv short '"-v"';    printf ','; _json_kv type '"flag"'; printf ','; _json_kv description '"Show version."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--print-schema"'; printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Emit the static introspection schema as JSON."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--print-state"';  printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Emit runtime state (sandboxes, approvals, containers) as JSON."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--validate-config"'; printf ','; _json_kv type '"string"'; printf ','; _json_kv arg_name '"PATH"'; printf ','; _json_kv description '"Validate a config file against the schema; emit JSON."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--start"';         printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Start a detached daemon session for the workspace and return once attachable."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--attach"';        printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Attach an interactive client to a running daemon session."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--stop"';          printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Stop a running daemon session (full teardown)."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--prune-orphans"'; printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"Reap orphaned sandy_* networks (dead-owner, no attached container) and exit."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--gc"';            printf ','; _json_kv type '"flag"';   printf ','; _json_kv description '"One-shot global reclaim: dead-owner containers, orphaned sandy_* networks, orphaned per-project/skill images, and dangling sandy images. Sub-options: --dry-run, --yes."'; printf '}'
    printf ','
    printf '{'; _json_kv name '"--update-sessions"'; printf ','; _json_kv type '"flag"'; printf ','; _json_kv description '"Fleet image refresh + rolling restart across every daemon session on the host; scope to one session with --workspace PATH. Sub-options: --dry-run, --yes, --idle-for <minutes>, --rebuild, --workspace."'; printf '}'
    printf ']'

    # agents — each with image, features, credential probe order
    printf ',"agents":['
    printf '{'
    _json_kv name '"claude"'; printf ','; _json_kv image '"sandy-claude-code"'
    printf ','; _json_kv features '["skills","channels_telegram","channels_discord","remote","synthkit"]'
    printf ','; _json_kv credentials '{"probe_order":["CLAUDE_CODE_OAUTH_TOKEN","ANTHROPIC_API_KEY","host_credentials_file"]}'
    printf '}'
    printf ','
    printf '{'
    _json_kv name '"gemini"'; printf ','; _json_kv image '"sandy-gemini-cli"'
    printf ','; _json_kv features '["synthkit_toml","extensions"]'
    printf ','; _json_kv credentials '{"probe_order":["GEMINI_API_KEY","host_tokens_json","host_adc"]}'
    printf '}'
    printf ','
    printf '{'
    _json_kv name '"codex"'; printf ','; _json_kv image '"sandy-codex"'
    printf ','; _json_kv features '["skills_context"]'
    printf ','; _json_kv credentials '{"probe_order":["OPENAI_API_KEY","host_auth_json"]}'
    printf '}'
    printf ','
    printf '{'
    _json_kv name '"opencode"'; printf ','; _json_kv image '"sandy-opencode"'
    printf ','; _json_kv features '["local_llm_passthrough","provider_choice"]'
    printf ','; _json_kv credentials '{"probe_order":["provider_env_keys","host_auth_json"]}'
    printf '}'
    printf ']'

    # protected_paths — sourced from the heredocs to stay in lockstep with
    # the RUN_FLAGS construction. Reads SANDY_ALLOW_WORKFLOW_EDIT from the
    # env (not from config — introspection is pre-config-load).
    printf ',"protected_paths":{'
    printf '"files":';     _sandy_protected_files     | _json_str_array
    printf ',"git_files":'; _sandy_protected_git_files | _json_str_array
    printf ',"dirs_always_mount":'; _sandy_protected_dirs | _json_str_array
    printf ',"dirs_workflow_edit_conditional":[".github/workflows"]'
    printf '}'

    # skill_packs — read from the SKILL_PACK_* arrays at the top of sandy.
    printf ',"skill_packs":['
    first=1
    local i
    for i in "${!SKILL_PACK_NAMES[@]}"; do
        [ $first -eq 0 ] && printf ','
        first=0
        printf '{'
        _json_kv name "$(_json_escape "${SKILL_PACK_NAMES[$i]}")"
        printf ','; _json_kv repo "$(_json_escape "${SKILL_PACK_REPOS[$i]}")"
        printf '}'
    done
    printf ']'

    # compatibility — schema versioning declarations.
    printf ',"compatibility":{'
    _json_kv current_schema_version "$SANDY_SCHEMA_VERSION"
    printf ','; _json_kv supported_schema_versions "[$SANDY_SCHEMA_VERSION]"
    printf ','; _json_kv deprecated_schema_versions '[]'
    printf '}'

    printf '}\n'
}

# Emit the `sandbox`/`daemon`/`attached_clients` fields for one
# running_containers[] entry (#17 DEC-3b). Args: container id, container
# name, "sandy.daemon" label value, "sandy.session" label value. Callable
# from both --print-state modes so they stay in sync.
_sandy_emit_container_daemon_fields() {
    local _cid="$1" _cname="$2" _cdaemon="$3" _csession="$4" _cupdated="${5:-}"
    local _sandbox _isdaemon _ac

    # sandbox: the sandy.session label when present (daemon containers),
    # else a best-effort strip of the sandy-proxy-/sandy- prefix from the
    # container name so bare/proxy containers still join to sandboxes[].
    if [ -n "$_csession" ]; then
        _sandbox="$_csession"
    else
        _sandbox="${_cname#sandy-proxy-}"
        _sandbox="${_sandbox#sandy-}"
    fi

    if [ "$_cdaemon" = "true" ]; then
        _isdaemon="true"
        # -u: docker exec defaults to the IMAGE's user (root — no USER
        # directive; the entrypoint drops to the host uid via gosu), and a
        # root tmux client looks in /tmp/tmux-0 while the server's socket is
        # /tmp/tmux-<host-uid> — so an un-`-u`'d probe can never see the
        # session. The host user running --print-state is the one who ran
        # --start, so `id -u` here matches the forwarded HOST_UID.
        # `|| _ac=""`: the probe legitimately fails (container mid-startup,
        # session gone, foreign labeled container) — without the guard that
        # non-zero status hits the introspection ERR trap under set -eE and
        # kills the whole emission (host regression: one broken daemon
        # container failed every --print-state consumer).
        _ac="$(docker exec -u "$(id -u)" "$_cid" tmux display -p -t sandy '#{session_attached}' 2>/dev/null)" || _ac=""
        if ! [[ "$_ac" =~ ^[0-9]+$ ]]; then
            _ac="null"
        fi
    else
        _isdaemon="false"
        _ac="null"
    fi

    printf ','; _json_kv sandbox "$(_json_escape "$_sandbox")"
    printf ','; printf '"daemon":%s' "$_isdaemon"
    printf ','; printf '"attached_clients":%s' "$_ac"
    # updated_at (#44): the sandy.updated_at label, stamped by --update-sessions
    # on a container it restarted (DEC-U3). Present only on update-restarted
    # containers; a normally-started daemon session has no such label → null.
    # Rides the existing `docker ps` label read — no extra docker spawn. Lets a
    # consumer (sandy-ui reconnect) tell "restarted for updates" from a session
    # the user stopped/started themselves.
    if [ -n "$_cupdated" ]; then
        printf ','; _json_kv updated_at "$(_json_escape "$_cupdated")"
    else
        printf ',"updated_at":null'
    fi
}

# #41 (milestone 1.2.0) — tri-state image-staleness check, shared by
# --print-state FULL mode (DEC-U6, `_sandy_emit_state`'s full-mode branch
# below) and `sandy --update-sessions`'s step-3 staleness check (dispatcher
# near --stop, much further down the file). Placed HERE — immediately after
# _sandy_emit_container_daemon_fields, well before the --print-schema/
# --print-state FAST-PATH dispatch (~line 1420) — for the exact reason
# _sandy_orphan_networks_list sits here too (see the comment just below):
# --print-state can dispatch and exit before the script's linear execution
# ever reaches a definition placed "near --update-sessions" further down, and
# bash only resolves a function call against whatever has already been
# DEFINED (executed as a top-level `name() { ... }` statement) earlier in the
# file — not against anything defined later. A mutation that moved this
# def down next to --update-sessions would make every full-mode
# `image_stale` assertion fail loudly (docker calls returning nothing /
# "command not found"), not silently pass.
#
# Arg: container id. Prints "true" (stale — the running image id differs from
# the current id of the image REFERENCE the container was created with),
# "false" (current), or "null" (can't be computed: reference no longer
# resolves, or an inspect failed) to stdout.
#
# The image reference is read from the container's own `.Config.Image` (the
# name/tag passed to `docker run`, stored at create time), NOT from
# `docker ps --format '{{.Image}}'`. This is load-bearing: once a rebuild
# reassigns a tag (sandy-claude-code: ID_old -> ID_new), `docker ps` reports
# a container still running ID_old by its raw SHA instead of the now-moved
# tag — so `docker image inspect <that-sha>` returns the same sha and the
# comparison becomes tautologically "current" for exactly the containers
# that ARE stale. `.Config.Image` keeps naming "sandy-claude-code", which
# resolves to the current tag, so a stale container is detected even after
# something else already moved the tag (the per-session `--update-sessions
# --workspace` path, and any UI polling `image_stale`, both hit this — a
# single unscoped fleet run masks it only because it enumerates before it
# builds). Found by test/acceptance-update-sessions.sh §3b (organic
# staleness across two scoped runs).
#
# `.Image` (running sha) and `.Config.Image` (reference) come from ONE
# `docker inspect`. Caches the CURRENT id per unique reference in the global
# _SANDY_IMAGE_ID_CACHE (newline "ref|id" pairs) so a caller checking many
# containers sharing one image (several daemon sessions on sandy-claude-code)
# pays one `docker image inspect` per unique reference, not per container
# (DEC-U6's cost model). Never caches a failed (empty) lookup.
_sandy_image_stale() {
    local _cid="$1" _pair _running_id _img_ref _current_id
    # #52: prefer the batched prefetch cache (one `docker inspect` for ALL sandy
    # containers, populated by _sandy_prefetch_container_inspect before the
    # full-mode loop). The cache key is the full `.Id`; the `docker ps` short id
    # passed here is a prefix of it. A miss (e.g. the update-sessions caller,
    # which never prefetches) falls back to the original per-cid inspect, so
    # behavior is unchanged for non-prefetched callers.
    _pair="$(printf '%s\n' "${_SANDY_CINSPECT_CACHE:-}" \
        | awk -F'|' -v c="$_cid" 'c!="" && index($1,c)==1{print $2"|"$3; exit}')" || _pair=""
    if [ -z "$_pair" ]; then
        _pair="$(docker inspect -f '{{.Image}}|{{.Config.Image}}' "$_cid" 2>/dev/null)" || _pair=""
    fi
    _running_id="${_pair%%|*}"
    _img_ref="${_pair#*|}"
    if [ -z "$_pair" ] || [ -z "$_running_id" ] || [ -z "$_img_ref" ]; then
        printf 'null'
        return 0
    fi
    _current_id="$(printf '%s\n' "${_SANDY_IMAGE_ID_CACHE:-}" | awk -F'|' -v n="$_img_ref" '$1==n{print $2; exit}')"
    if [ -z "$_current_id" ]; then
        _current_id="$(docker image inspect -f '{{.Id}}' "$_img_ref" 2>/dev/null)" || _current_id=""
        if [ -n "$_current_id" ]; then
            _SANDY_IMAGE_ID_CACHE="${_SANDY_IMAGE_ID_CACHE:-}
$_img_ref|$_current_id"
        fi
    fi
    if [ -z "$_current_id" ]; then
        printf 'null'
        return 0
    fi
    if [ "$_running_id" = "$_current_id" ]; then
        printf 'false'
    else
        printf 'true'
    fi
}

# #52 — batch-prefetch the (running-image-id, image-ref) pair for many
# containers in ONE `docker inspect`, collapsing image_stale's per-container
# inspect (was N docker spawns on an N-session host) to a single call. Populates
# the global _SANDY_CINSPECT_CACHE (newline "fullid|running_id|img_ref"); each
# output line self-identifies by `.Id`, so a container that vanishes mid-call
# (error to stderr, no stdout line) simply drops out rather than misaligning the
# rest. _sandy_image_stale consults this cache first. Guarded so an empty arg
# list is a no-op (bash 3.2 + set -u would choke on an empty "$@" expansion).
_sandy_prefetch_container_inspect() {
    [ "$#" -gt 0 ] || return 0
    local _line
    while IFS= read -r _line; do
        [ -n "$_line" ] || continue
        _SANDY_CINSPECT_CACHE="${_SANDY_CINSPECT_CACHE:-}
$_line"
    done < <(docker inspect -f '{{.Id}}|{{.Image}}|{{.Config.Image}}' "$@" 2>/dev/null || true)
}

# #26 (milestone 1.1.0, Batch 4) — pure lister: emits the names (one per line)
# of orphaned sandy_(sidecar|egress|net)_<pid> networks — the exact gate logic
# _sandy_reap_orphan_networks uses, extracted so print-state, --prune-orphans,
# and the reaper itself share ONE source of truth (DEC-4b) instead of three
# copies of the gate drifting apart. "Orphan" means: the trailing <pid> in the
# network name is dead (numeric + `! kill -0`) OR non-numeric, AND no
# container is currently attached. A live-PID network (incl. a launch that's
# mid-setup) or a container-attached network (incl. a D9 reboot-resurrected
# daemon session whose supervisor pid is gone but whose container is still
# running) is NOT an orphan and is never listed here.
#
# NOTE: defined here (well before the reaper at ~3216) rather than "just
# above the reaper" because --print-state is a FAST-PATH handler that can
# dispatch (and exit) before the script ever reaches line ~3216 in its linear
# top-to-bottom execution — a bash function called before its own `name() {`
# statement has executed is "command not found" (forward references don't
# work; only text further down in the file that RUNS later can see a function
# defined further up). Placed next to _sandy_emit_state, its only fast-path
# caller, so both fast-path consumers (print-state) and the later-defined
# reaper/`--prune-orphans` dispatcher can call it identically.
_sandy_orphan_networks_list() {
    local net net_pid _out _n attached
    local _candidates=()
    for net in $(docker network ls --format '{{.Name}}' 2>/dev/null \
            | grep -E '^sandy_(sidecar|egress|net)_' || true); do
        net_pid="${net##*_}"   # trailing field: sandy_<kind>_<pid> → <pid>
        # Owner still alive? numeric PID + kill -0. If so, skip — never touch a
        # live/mid-setup session's network. Non-numeric → fall through to the
        # container check (can't prove liveness).
        if [ -n "$net_pid" ] && [ "$net_pid" -eq "$net_pid" ] 2>/dev/null \
           && kill -0 "$net_pid" 2>/dev/null; then
            continue
        fi
        _candidates+=("$net")
    done
    # #52 — batch the "any container still attached?" probe for all dead-owner
    # candidates into ONE `docker network inspect net1 net2 …` (was one spawn per
    # candidate). The kill -0 short-circuit above already means a healthy
    # all-live-PID host reaches here with zero candidates and makes no inspect
    # call at all. The template self-identifies each net by name, so a candidate
    # that vanishes mid-call just drops out. A network with no attached container
    # is an orphan (incl. a D9 reboot-resurrected session → has a container →
    # not listed). Guard the empty case (bash 3.2 + set -u empty "$@").
    [ "${#_candidates[@]}" -gt 0 ] || return 0
    _out="$(docker network inspect \
        -f '{{.Name}}|{{range .Containers}}{{.Name}} {{end}}' \
        "${_candidates[@]}" 2>/dev/null || true)"
    while IFS='|' read -r _n attached; do
        [ -n "$_n" ] || continue
        attached="$(printf '%s' "$attached" | tr -d '[:space:]')"
        [ -z "$attached" ] && printf '%s\n' "$_n"
    done <<< "$_out"
    return 0
}

# _sandy_reap_orphan_networks — remove every orphan network the lister reports.
#
# Self-heal for sandy's OWN orphaned Docker networks: a sandy_net_* (the isolated
# bridge in non-proxy mode) or sandy_sidecar_*/sandy_egress_* (the proxy topology)
# whose owning session is gone. A SIGKILL'd / OOM'd / closed-terminal sandy can't
# run its cleanup trap, leaking the network (and its subnet); enough orphans
# exhaust the candidate pools and new launches fail with "all predefined address
# pools have been fully subnetted" (accumulates fast under launch/close/relaunch,
# e.g. sandy-ui). The removal predicate lives in _sandy_orphan_networks_list()
# (DEC-4b single source of truth — the reaper, print-state's `orphan_networks`
# count, and `--prune-orphans` all consume it, so the gate can't drift): a net is
# reaped ONLY when its owning PID is dead AND no container is attached, so a live
# or mid-setup concurrent session is never disturbed (the PID gate is what makes
# eager per-launch reaping concurrent-safe). Defined here beside the lister so
# every consumer resolves it — including the positional `--prune-orphans`
# fast-path (which exits before the preflight) and the `--stop` / startup-prune
# dispatchers below. Returns 0 if it freed at least one network, 1 otherwise.
_sandy_reap_orphan_networks() {
    local net freed=1
    for net in $(_sandy_orphan_networks_list); do
        docker network rm "$net" >/dev/null 2>&1 && freed=0
    done
    return $freed
}

# --- sandy --gc (#36) — unified Docker-resource reclaim: pure listers +
# reapers. Placed here — immediately after _sandy_reap_orphan_networks, before
# _sandy_emit_state — for the SAME forward-reference reason the network
# lister sits here: --print-state is a FAST-PATH handler that can dispatch
# and exit before the script's linear execution ever reaches a definition
# placed further down (e.g. "near --gc's own dispatcher"), and bash only
# resolves a function call against whatever has already been DEFINED earlier
# in the file. DEC-4b single source of truth: the same listers back
# --print-state's new `dangling_images`/`orphaned_containers` counts, the
# `--gc` dispatcher's plan+reap, and (for networks) the pre-existing
# --prune-orphans path — one gate per resource kind, never three copies of it
# drifting apart.

# 2a — dangling (<none>:<none>) images carrying sandy's provenance label
# (§1: sandy.managed=1, stamped on every `docker build` sandy runs). Scoped
# to the label so a rebuild-orphaned image from some OTHER tool's build churn
# is never touched — the label is the only thing that tells a sandy dangling
# image apart from anyone else's. One spawn; no PID/liveness gate needed (a
# dangling image is referenced by no tag and is never "live" the way a
# network/container can be) — `docker rmi` without -f is itself the safety
# net for anything still referenced by a child image.
#
# NOTE (retroactive gap): images built by a pre-1.3.0 sandy never got this
# label, so a dangling image left over from a rebuild done before this
# feature shipped is invisible here. Those fall back to whatever manual
# cleanup already existed; the label only prevents new dangling images from
# accumulating going forward.
_sandy_dangling_images_list() {
    docker images -f dangling=true -f label=sandy.managed=1 --format '{{.ID}}' 2>/dev/null || true
}

# 2b — sandy-project-<x> images (per-.sandy/Dockerfile project layers) whose
# owning sandbox directory no longer exists. Candidates come from the same
# sandy.managed=1 label; the in-use set is a pure filesystem walk of
# $SANDY_HOME/sandboxes/*/ recomputing "sandy-project-<basename>" lowercased
# — the IDENTICAL transform the build path (PROJECT_IMAGE_NAME) applies, so
# this can never drift from what a launch actually names an image. No
# docker/config parsing beyond the one `docker images` spawn.
_sandy_orphaned_project_images_list() {
    local _candidates _inuse _cand _sb _base
    _candidates="$(docker images -f label=sandy.managed=1 --format '{{.Repository}}' 2>/dev/null \
        | grep -E '^sandy-project-' || true)"
    [ -n "$_candidates" ] || return 0
    _inuse=""
    if [ -d "$SANDY_HOME/sandboxes" ]; then
        for _sb in "$SANDY_HOME/sandboxes"/*/; do
            [ -d "$_sb" ] || continue
            _base="$(basename "${_sb%/}")"
            _inuse="${_inuse}
$(printf '%s' "sandy-project-${_base}" | tr '[:upper:]' '[:lower:]')"
        done
    fi
    while IFS= read -r _cand; do
        [ -n "$_cand" ] || continue
        printf '%s\n' "$_inuse" | grep -qxF "$_cand" || printf '%s\n' "$_cand"
    done <<< "$_candidates"
    return 0
}

# 2c — sandy-skills(-base)?-<suffix> images whose pack set is no longer
# configured by any sandbox whose workspace still exists, AND isn't the
# host-global default. Candidates from the sandy.managed=1 label; the in-use
# set is built from THREE sources (M4 fix — the first two are workspace-
# independent, since SANDY_SKILL_PACKS is passive-safe and commonly set ONCE
# globally rather than per-workspace):
#   1. SANDY_SKILL_PACKS already in THIS process's environment (env wins
#      over config, same precedence the config loader documents elsewhere).
#   2. Host $SANDY_HOME/config (~/.sandy/config) — the common "set it once,
#      globally" home for this passive-safe key. Last matching line wins
#      (mirrors the config loader's own last-match-wins iteration order).
#   3. Each sandbox's WORKSPACE.json -> still-existing workspace_path ->
#      that workspace's own .sandy/config SANDY_SKILL_PACKS= (the same
#      minimal inline idiom _sandy_validate_config uses — NOT
#      _load_sandy_config, which isn't defined yet at this point in the file
#      and has side effects this lister must avoid).
# All three recompute the suffix via the shared _sandy_skill_pack_suffix()
# helper (same one both build call sites use — DEC-4b, prevents drift) and
# are added to the SAME in-use set unconditionally — sources 1/2 aren't tied
# to any one sandbox, so they only WIDEN what counts as in-use, never narrow
# it. Without sources 1/2, a host-global `SANDY_SKILL_PACKS=gstack` with no
# per-workspace override would see an EMPTY in-use set and `docker rmi` the
# actively-used sandy-skills-gstack/sandy-skills-base-gstack on every
# `--gc` run — not data loss (a running container's image is still
# referenced, so a plain `rmi` no-ops), but it silently forces a full
# skills-base rebuild (Chromium + bun) on the next launch that needs it.
#
# Known imprecision (documented, not a bug): a workspace that's temporarily
# unmounted (removable drive, unmounted NFS share), whose .sandy/config was
# edited AFTER the image was built, or a host config sandy can't read for
# some other reason, under-detects as orphaned. A read/parse failure on
# either the host or a per-workspace config just contributes nothing to the
# in-use set (matches "when uncertain, keep" — it never actively marks an
# image as reap-safe, it can only fail to protect one) rather than crashing
# the lister. This residual imprecision is safe because skills/project
# images are reproducible artifacts — a false-positive reap costs a full
# skills-base (Chromium/bun) rebuild on the next launch that needs it, not
# data loss.
_sandy_orphaned_skills_images_list() {
    local _candidates _inuse _cand _sb _ws_path _packs _suffix
    _candidates="$(docker images -f label=sandy.managed=1 --format '{{.Repository}}' 2>/dev/null \
        | grep -E '^sandy-skills(-base)?-' || true)"
    [ -n "$_candidates" ] || return 0
    _inuse=""

    # Source 1: env var already set in this process's environment.
    if [ -n "${SANDY_SKILL_PACKS:-}" ]; then
        _suffix="$(_sandy_skill_pack_suffix "$SANDY_SKILL_PACKS")"
        if [ -n "$_suffix" ]; then
            _inuse="${_inuse}
sandy-skills-base-${_suffix}
sandy-skills-${_suffix}"
        fi
    fi

    # Source 2: host-global ~/.sandy/config. Not gated to any one sandbox —
    # this is the common "set it once, globally" home for this key.
    if [ -r "$SANDY_HOME/config" ]; then
        _packs="$(grep -E '^SANDY_SKILL_PACKS=' "$SANDY_HOME/config" 2>/dev/null | tail -n1 \
            | sed 's/^SANDY_SKILL_PACKS=//')"
        if [ -n "$_packs" ]; then
            _suffix="$(_sandy_skill_pack_suffix "$_packs")"
            if [ -n "$_suffix" ]; then
                _inuse="${_inuse}
sandy-skills-base-${_suffix}
sandy-skills-${_suffix}"
            fi
        fi
    fi

    # Source 3: per-workspace overrides, keyed off each sandbox's own
    # WORKSPACE.json -> .sandy/config.
    if [ -d "$SANDY_HOME/sandboxes" ]; then
        for _sb in "$SANDY_HOME/sandboxes"/*/; do
            [ -d "$_sb" ] || continue
            [ -f "${_sb}WORKSPACE.json" ] || continue
            _ws_path="$(grep -m1 '"workspace_path"' "${_sb}WORKSPACE.json" 2>/dev/null \
                | sed 's/.*"workspace_path"[[:space:]]*:[[:space:]]*"//; s/".*//')"
            [ -n "$_ws_path" ] && [ -d "$_ws_path" ] || continue
            _packs="$(grep -m1 '^SANDY_SKILL_PACKS=' "$_ws_path/.sandy/config" 2>/dev/null \
                | sed 's/^SANDY_SKILL_PACKS=//')"
            [ -n "$_packs" ] || continue
            _suffix="$(_sandy_skill_pack_suffix "$_packs")"
            [ -n "$_suffix" ] || continue
            _inuse="${_inuse}
sandy-skills-base-${_suffix}
sandy-skills-${_suffix}"
        done
    fi
    while IFS= read -r _cand; do
        [ -n "$_cand" ] || continue
        printf '%s\n' "$_inuse" | grep -qxF "$_cand" || printf '%s\n' "$_cand"
    done <<< "$_candidates"
    return 0
}

# Probe an inner tmux session's liveness for the container-liveness gate
# below. Arg 2 selects the mode: "reap" retries the SAME 5x/sleep-1 pattern
# --start's D6 idempotency check (~"_sandy_session_live=0") and bare-sandy's
# DEC-B check use, so a container that's merely mid-startup (the supervisor
# hasn't created the tmux session yet) is never misread as a zombie and
# reaped out from under a concurrent `sandy --start`. Any other mode (the
# --print-state COUNT path, where a momentarily-stale read is merely
# informational) is a single probe — --print-state must stay cheap, and a
# 5-second stall per mid-startup container would defeat that. Gating the
# retry to the destructive path only is deliberate: the expensive check is
# paid exactly where a wrong answer is irreversible.
_sandy_gc_probe_has_session() {
    local _cid="$1" _mode="$2" _i
    if [ "$_mode" = "reap" ]; then
        for _i in 1 2 3 4 5; do
            docker exec -u "$(id -u)" "$_cid" tmux has-session -t sandy >/dev/null 2>&1 && return 0
            sleep 1
        done
        return 1
    fi
    docker exec -u "$(id -u)" "$_cid" tmux has-session -t sandy >/dev/null 2>&1
}

# 2d — dead-owner sandy_* container NAMES (one per line). Reuses the D6/D9
# "the container is truth only with a LIVE inner tmux session" rule from
# --start/--stop — NEVER trusts sandy.daemon_pid liveness (the D9 lesson: a
# reboot can resurrect a --restart unless-stopped container on a dead
# supervisor pid, and that container is still a legitimate live session).
#
# Arg 1 (optional): passed straight through to _sandy_gc_probe_has_session as
# its mode — pass "reap" from the destructive reaper (_sandy_gc_reap_containers)
# so a mid-startup daemon gets the 5x/sleep-1 retry before being judged a
# zombie; leave unset for the --print-state COUNT path, which wants a single
# cheap probe.
#
# One `docker ps -a` enumerates every candidate; classification is a TWO-PASS
# walk over the captured output (not the live command), because a proxy
# sidecar's liveness is a function of its PAIRED AGENT's liveness, which is
# only known once every agent row has been classified:
#
#   Pass 1 — every AGENT container (image != sandy-proxy: sandy-base,
#   sandy-claude-code, sandy-gemini-cli, sandy-codex, sandy-opencode,
#   sandy-full, sandy-project-*, sandy-skills*). Any sandy-proxy-imaged row is
#   stashed for pass 2 instead of classified here. Agent-vs-proxy is decided
#   by IMAGE, never by name prefix — a workspace whose sanitized basename
#   happens to be "proxy" produces a container literally named
#   "sandy-proxy-<hash>" running a real agent image, and a name-prefix test
#   would misclassify it as a proxy sidecar (the fixed #36 regression, "B2").
#   Per agent row:
#     1. Image-name gate (best-effort, mirrors print-state's existing filter):
#        skip rows already excluded by the case above. This gate is scoped by
#        container NAMING (matched against `docker ps -a --filter
#        name=^/sandy-`), deliberately NOT the sandy.managed label — the label
#        is only stamped on images (§1), so this predicate stays operative
#        (retroactive) even for containers a pre-1.3.0 sandy started.
#     2. Daemon-labeled (sandy.daemon=true):
#          not running -> dead, reap
#          running      -> probe tmux has-session (mode-gated retry above):
#                             success -> ALIVE, KEPT — never touch, regardless
#                                        of daemon_pid liveness (the D9 defense)
#                             failure -> zombie, reap
#     3. Not daemon-labeled (foreground/interactive agent): SANDBOX_NAME is
#        derived by stripping ONLY the "sandy-" prefix (never "sandy-proxy-"
#        — that branch is for images, this is always a real agent image) —
#        this alone fixes B2, since the "proxy"-named workspace's agent
#        strips to the correct "proxy-<hash>" sandbox name, not an empty
#        string. Check $SANDY_HOME/sandboxes/.<name>.lock/pid:
#          missing/non-numeric/dead -> dead-owner, reap
#          live pid                  -> KEPT, skip
#        (Reuses the exact lock_holder_alive liveness test #14/--print-state
#        already use.)
#     Every KEPT agent's sandbox name is recorded in a set for pass 2.
#
#   Pass 2 — every PROXY container (image == sandy-proxy, sandy-proxy-<name>).
#   A proxy's own running state and any lock file are IGNORED — proxy
#   liveness is entirely a function of its paired agent (sandy-<name>):
#     paired agent's sandbox name is in the pass-1 KEPT set -> KEPT, skip
#     otherwise (paired agent absent, dead, or reaped)      -> reap
#   This closes the other #36 regression ("B1"): a daemon session's proxy is
#   never sandy.daemon-labeled, so a naive single-branch reading of its own
#   lock file (which holds the SUPERVISOR's pid) would misjudge it dead the
#   moment a live session's supervisor is SIGKILL/OOM-killed (the #47 zombie-
#   supervisor case) even though the agent container (and its tmux session)
#   is still perfectly healthy — reaping the proxy would then strand that
#   live agent on a routeless --internal sidecar (the exact failure the
#   atomic agent+proxy teardown in cleanup() exists to prevent).
#
# The dedicated reaper (_sandy_gc_reap_containers) re-invokes THIS lister
# (with "reap" mode) at call time (not a cached earlier list) immediately
# before each destructive `docker rm -f` — its own authoritative re-probe,
# since the op is destructive. This lister is also used by --print-state's
# `orphaned_containers` COUNT (default mode, single probe), where a
# momentarily-stale read is merely informational.
_sandy_dead_owner_containers_list() {
    local _mode="${1:-}"
    local _ps_out
    _ps_out="$(docker ps -a --filter 'name=^/sandy-' \
        --format '{{.ID}}|{{.Names}}|{{.State}}|{{.Label "sandy.daemon"}}|{{.Image}}' 2>/dev/null)" || _ps_out=""
    [ -n "$_ps_out" ] || return 0

    local _cid _cname _cstate _cdaemon _cimg _img_base _sbname _lock _lpid
    local _kept_agents="" _proxy_rows=""

    # Pass 1: agents.
    while IFS='|' read -r _cid _cname _cstate _cdaemon _cimg; do
        [ -n "$_cid" ] || continue
        _img_base="${_cimg%%:*}"
        if [ "$_img_base" = "sandy-proxy" ]; then
            _proxy_rows="${_proxy_rows}
${_cname}"
            continue
        fi
        case "$_img_base" in
            sandy-base|sandy-claude-code|sandy-gemini-cli|sandy-codex|sandy-opencode|sandy-full|sandy-project-*|sandy-skills*) : ;;
            *) continue ;;
        esac
        _sbname="${_cname#sandy-}"
        if [ "$_cdaemon" = "true" ]; then
            if [ "$_cstate" != "running" ]; then
                printf '%s\n' "$_cname"
                continue
            fi
            if _sandy_gc_probe_has_session "$_cid" "$_mode"; then
                _kept_agents="${_kept_agents}
${_sbname}"
                continue   # ALIVE — never touch, regardless of daemon_pid (D9)
            fi
            printf '%s\n' "$_cname"
            continue
        fi
        # Not daemon-labeled: foreground/interactive agent container.
        if [ "$_cstate" != "running" ]; then
            printf '%s\n' "$_cname"
            continue
        fi
        _lock="$SANDY_HOME/sandboxes/.${_sbname}.lock"
        _lpid=""
        [ -d "$_lock" ] && _lpid="$(cat "$_lock/pid" 2>/dev/null || true)"
        if [ -n "$_lpid" ] && [ "$_lpid" -eq "$_lpid" ] 2>/dev/null && kill -0 "$_lpid" 2>/dev/null; then
            _kept_agents="${_kept_agents}
${_sbname}"
            continue   # live lock owner — skip
        fi
        printf '%s\n' "$_cname"
    done <<< "$_ps_out"

    # Pass 2: proxies, judged solely by their paired agent's KEPT status.
    while IFS= read -r _cname; do
        [ -n "$_cname" ] || continue
        _sbname="${_cname#sandy-proxy-}"
        printf '%s\n' "$_kept_agents" | grep -qxF "$_sbname" && continue   # paired agent KEPT — skip
        printf '%s\n' "$_cname"
    done <<< "$_proxy_rows"

    return 0
}

# 2e — thin reapers: `for x in $(_list); do docker action; done`, mirroring
# _sandy_reap_orphan_networks. Each re-invokes its lister at CALL time (not a
# cached snapshot from an earlier plan step), so the --gc dispatcher's
# plan -> confirm -> reap flow always acts on a fresh read — closing the same
# TOCTOU window _sandy_reap_orphan_networks already tolerates for networks (a
# candidate that raced back to life between plan and reap is simply not
# caught by the NEXT list either, so nothing is force-removed out from under
# a legitimately-revived resource).
_sandy_gc_reap_containers() {
    local _cname
    # "reap" mode: retries the mid-startup has-session probe (5x/sleep-1)
    # before judging a running daemon container a zombie — this destructive
    # path is exactly where a wrong answer is irreversible.
    for _cname in $(_sandy_dead_owner_containers_list reap); do
        # docker stop (graceful) then rm -f — mirrors --stop's own teardown
        # sequence for a dead-session daemon zombie.
        docker stop "$_cname" >/dev/null 2>&1 || true
        docker rm -f "$_cname" >/dev/null 2>&1 || true
    done
}

_sandy_gc_reap_project_images() {
    local _img
    for _img in $(_sandy_orphaned_project_images_list); do
        docker rmi "$_img" >/dev/null 2>&1 || true
    done
}

_sandy_gc_reap_skills_images() {
    local _img
    for _img in $(_sandy_orphaned_skills_images_list); do
        docker rmi "$_img" >/dev/null 2>&1 || true
    done
}

_sandy_gc_reap_dangling_images() {
    local _id
    for _id in $(_sandy_dangling_images_list); do
        docker rmi "$_id" >/dev/null 2>&1 || true
    done
}

# Emit runtime state JSON: sandboxes, approvals, running containers.
_sandy_emit_state() {
    # Mode: "full" (default) or "light". Light mode (#18) makes exactly TWO
    # docker spawns instead of nine, so pollers (e.g. sandy-ui) don't spike
    # CPU: it skips installed_images (which has no consumer) and derives
    # docker_reachable from a single `docker ps`'s exit status instead of the
    # two docker-info gates; the second spawn is the `docker network ls`
    # behind orphan_networks (#26 — light was ONE spawn before 1.1.0). Any
    # arg other than "light" (incl. none) selects full mode, whose
    # output/logic is unchanged — so a consumer can pass "light"
    # unconditionally and older/other sandy just ignores it.
    local _mode="${1:-full}"
    # Detect which stat flavor we have once. GNU stat (Linux) takes -c;
    # BSD stat (macOS) takes -f. We can't rely on either failing cleanly on
    # the wrong OS — GNU's `stat -f` is a valid different command (filesystem
    # info) rather than a usage error — so probe `stat -c` first.
    # File-mtime helper. Must ALWAYS exit 0 (even for a missing file) because
    # under `set -euo pipefail` a non-zero exit from a command substitution
    # (`x="$(_stat_mtime_iso ...)"`) aborts the caller and trips the ERR trap.
    # Sandboxes frequently have .sandy_created_version but no .sandy_last_version
    # (first launch), so stat failure for one field is a normal expected case.
    local _stat_mtime_iso
    if stat -c '%y' / >/dev/null 2>&1; then
        # GNU stat: %y is "2006-01-02 15:04:05.000000000 -0700"; take date/time and append Z.
        _stat_mtime_iso() { [ -e "$1" ] || return 0; stat -c '%y' "$1" 2>/dev/null | awk '{print $1"T"$2"Z"}' || true; }
    elif stat -f '%Sm' -t '%Y-%m-%dT%H:%M:%SZ' / >/dev/null 2>&1; then
        _stat_mtime_iso() { [ -e "$1" ] || return 0; stat -f '%Sm' -t '%Y-%m-%dT%H:%M:%SZ' "$1" 2>/dev/null || true; }
    else
        _stat_mtime_iso() { return 0; }
    fi

    printf '{'
    _json_kv schema_version "$SANDY_SCHEMA_VERSION"
    printf ','; _json_kv sandy_home "$(_json_escape "$SANDY_HOME")"

    # installed_images: sandy-{base,claude-code,gemini-cli,codex,opencode,full}.
    # Skipped in light mode (no consumer; costs 6 of the 9 docker spawns). The
    # key stays present (empty array) so the schema shape is identical.
    printf ',"installed_images":['
    if [ "$_mode" != "light" ] && command -v docker >/dev/null 2>&1; then
        local first=1 img _ii_line _ii_tag _ii_rest
        # One batched inspect (was 6 + a docker-info gate). RepoTags[0] maps each
        # result back to its name; missing images produce no line (docker skips
        # them), same as the old per-image `|| continue`. Iterating the known
        # names below in original order keeps output byte-identical.
        local _ii_map=""   # newline-joined "name|id|created"
        _ii_map="$(docker image inspect \
            sandy-base sandy-claude-code sandy-gemini-cli sandy-codex sandy-opencode sandy-full \
            --format '{{index .RepoTags 0}}|{{.Id}}|{{.Created}}' 2>/dev/null || true)"
        for img in sandy-base sandy-claude-code sandy-gemini-cli sandy-codex sandy-opencode sandy-full; do
            # find the map line whose tag is "<img>:..." (strip the :tag)
            _ii_line="$(printf '%s\n' "$_ii_map" | awk -F'|' -v n="$img" \
                '{t=$1; sub(/:[^:]*$/,"",t)} t==n {print $2"|"$3; exit}')"
            [ -z "$_ii_line" ] && continue
            local img_id img_created
            img_id="${_ii_line%%|*}"
            img_created="${_ii_line#*|}"
            [ $first -eq 0 ] && printf ','
            first=0
            printf '{'
            _json_kv name    "$(_json_escape "$img")"
            printf ','; _json_kv id      "$(_json_escape "$img_id")"
            printf ','; _json_kv created "$(_json_escape "$img_created")"
            printf '}'
        done
    fi
    printf ']'

    # sandboxes: walk $SANDY_HOME/sandboxes/*/. Locks live at
    # $SANDY_HOME/sandboxes/.<name>.lock (the mkdir-mutex from per-project concurrency guard).
    printf ',"sandboxes":['
    local first=1 sb
    if [ -d "$SANDY_HOME/sandboxes" ]; then
        for sb in "$SANDY_HOME/sandboxes"/*/; do
            [ -d "$sb" ] || continue
            sb="${sb%/}"
            local sb_name sb_created_ver sb_last_ver sb_created_at sb_last_at sb_lock_dir sb_lock_pid sb_ws_path
            sb_name="$(basename "$sb")"
            sb_created_ver="$(cat "$sb/.sandy_created_version" 2>/dev/null || true)"
            sb_last_ver="$(cat "$sb/.sandy_last_version" 2>/dev/null || true)"
            # workspace_path: read the WORKSPACE.json marker sandy writes into
            # every sandbox on launch (same lightweight parse the sibling-scan
            # uses). Empty string for a legacy sandbox with no marker. Fulfills
            # the SPEC_INTROSPECTION contract that each sandbox carries a stable
            # workspace_path (consumers like sandy-ui key their tree on it).
            sb_ws_path="$(grep -m1 '"workspace_path"' "$sb/WORKSPACE.json" 2>/dev/null \
                          | sed 's/.*"workspace_path"[[:space:]]*:[[:space:]]*"//; s/".*//' || true)"
            sb_created_at="$(_stat_mtime_iso "$sb/.sandy_created_version")"
            sb_last_at="$(_stat_mtime_iso "$sb/.sandy_last_version")"
            sb_lock_dir="$SANDY_HOME/sandboxes/.${sb_name}.lock"
            sb_lock_pid=""
            if [ -d "$sb_lock_dir" ]; then
                sb_lock_pid="$(cat "$sb_lock_dir/pid" 2>/dev/null || true)"
            fi

            [ $first -eq 0 ] && printf ','
            first=0
            printf '{'
            _json_kv name "$(_json_escape "$sb_name")"
            printf ','; _json_kv path "$(_json_escape "$sb")"
            printf ','; _json_kv workspace_path "$(_json_escape "$sb_ws_path")"
            printf ','; _json_kv created_version   "$(_json_escape "$sb_created_ver")"
            printf ','; _json_kv last_used_version "$(_json_escape "$sb_last_ver")"
            printf ','; _json_kv created_at        "$(_json_escape "$sb_created_at")"
            printf ','; _json_kv last_used_at      "$(_json_escape "$sb_last_at")"
            if [ -d "$sb_lock_dir" ]; then
                printf ','; _json_kv lock_held 'true'
                printf ','; _json_kv lock_holder_pid "$(_json_escape "$sb_lock_pid")"
                # lock_holder_alive: distinguishes "real lock" from "stale
                # lock waiting to be cleared on next launch". true/false when
                # we have a numeric PID; null when the file is missing or
                # corrupt (and thus liveness is unknowable).
                local sb_lock_alive='null'
                if [ -n "$sb_lock_pid" ] && [ "$sb_lock_pid" -eq "$sb_lock_pid" ] 2>/dev/null; then
                    if kill -0 "$sb_lock_pid" 2>/dev/null; then
                        sb_lock_alive='true'
                    else
                        sb_lock_alive='false'
                    fi
                fi
                printf ','; _json_kv lock_holder_alive "$sb_lock_alive"
            else
                printf ','; _json_kv lock_held 'false'
                printf ','; _json_kv lock_holder_pid 'null'
                printf ','; _json_kv lock_holder_alive 'null'
            fi
            printf '}'
        done
    fi
    printf ']'

    # approvals: parse $SANDY_HOME/approvals/passive-*.list. First line is the
    # sha256 of the sorted KEY=VALUE set. `# workspace:` and `# approved:` are
    # added by the approval writer.
    printf ',"approvals":['
    first=1
    local app
    if [ -d "$SANDY_HOME/approvals" ]; then
        for app in "$SANDY_HOME/approvals"/passive-*.list; do
            [ -f "$app" ] || continue
            local app_hash app_workspace app_time app_wd_hash
            app_hash="$(head -n1 "$app" 2>/dev/null || true)"
            # grep | sed under `set -eo pipefail`: a non-matching grep exits 1, pipefail
            # propagates, and the command substitution fails. `|| true` inside the subshell
            # absorbs that without masking real errors in the caller.
            app_workspace="$(grep -m1 '^# workspace:' "$app" 2>/dev/null | sed 's/^# workspace:[[:space:]]*//' || true)"
            app_time="$(grep -m1 '^# approved:' "$app" 2>/dev/null | sed 's/^# approved:[[:space:]]*//' || true)"
            app_wd_hash="$(basename "$app")"
            app_wd_hash="${app_wd_hash#passive-}"
            app_wd_hash="${app_wd_hash%.list}"

            [ $first -eq 0 ] && printf ','
            first=0
            printf '{'
            _json_kv workspace_hash       "$(_json_escape "$app_wd_hash")"
            printf ','; _json_kv workspace_path_hint  "$(_json_escape "$app_workspace")"
            printf ','; _json_kv approved_keys_sha256 "$(_json_escape "$app_hash")"
            printf ','; _json_kv approved_at          "$(_json_escape "$app_time")"
            printf '}'
        done
    fi
    printf ']'

    # running_containers + docker_reachable.
    # Light mode: a single `docker ps` — its exit status IS the reachability
    # signal (fails when the CLI is missing or the daemon is down), replacing
    # the two docker-info gates. Combined with the installed_images skip above,
    # the steady-state light budget is two docker spawns: this `docker ps`
    # plus the `docker network ls` behind orphan_networks (#26, below). The
    # `sandbox`/`daemon` fields ride the ps call for free; two bounded extras
    # apply only when the corresponding state exists — one `docker exec ...
    # tmux display` per DAEMON container (`attached_clients`) and one
    # `docker network inspect` per dead-owner orphan candidate — zero of
    # either on a host with no daemon sessions and no orphans. The full-mode
    # elif/else below follows the same per-entry logic; both stay in sync
    # because a light-mode poller needs these fields too (#17).
    if [ "$_mode" = "light" ]; then
        local _ps_out=""
        if command -v docker >/dev/null 2>&1 \
           && _ps_out="$(docker ps --format '{{.ID}}|{{.Names}}|{{.Image}}|{{.CreatedAt}}|{{.Label "sandy.daemon"}}|{{.Label "sandy.session"}}|{{.Label "sandy.updated_at"}}' 2>/dev/null)"; then
            printf ',"docker_reachable":true'
            printf ',"running_containers":['
            first=1
            while IFS= read -r _cline; do
                [ -z "$_cline" ] && continue
                local _cid _cname _cimg _cstarted _cdaemon _csession _cupdated
                _cid="$(echo "$_cline"      | awk -F'|' '{print $1}')"
                _cname="$(echo "$_cline"    | awk -F'|' '{print $2}')"
                _cimg="$(echo "$_cline"     | awk -F'|' '{print $3}')"
                _cstarted="$(echo "$_cline" | awk -F'|' '{print $4}')"
                _cdaemon="$(echo "$_cline"  | awk -F'|' '{print $5}')"
                _csession="$(echo "$_cline" | awk -F'|' '{print $6}')"
                _cupdated="$(echo "$_cline"  | awk -F'|' '{print $7}')"
                [ $first -eq 0 ] && printf ','
                first=0
                printf '{'
                _json_kv id         "$(_json_escape "$_cid")"
                printf ','; _json_kv name       "$(_json_escape "$_cname")"
                printf ','; _json_kv image      "$(_json_escape "$_cimg")"
                printf ','; _json_kv started_at "$(_json_escape "$_cstarted")"
                _sandy_emit_container_daemon_fields "$_cid" "$_cname" "$_cdaemon" "$_csession" "$_cupdated"
                printf '}'
            done < <(printf '%s\n' "$_ps_out" | grep -E '(^|[|])sandy[_-]|[|]sandy-' || true)
            printf ']'
            # #26 DEC-4c — orphan_networks: reap-eligible sandy_(sidecar|egress|
            # net)_* network count, via the SAME lister the reaper/--prune-orphans
            # use (DEC-4b). Cost: one extra `docker network ls` always, plus one
            # `docker network inspect` per dead/non-numeric-PID candidate ONLY —
            # the kill -0 short-circuit means a healthy all-live-PID host pays
            # zero extra inspects, so this stays cheap for the #25 poll-friendly
            # light path in the common case.
            local _orphans; _orphans="$(_sandy_orphan_networks_list | grep -c . || true)"
            printf ',"orphan_networks":%s' "${_orphans:-0}"
            # #36 DEC-U6-style — dangling_images/orphaned_containers are FULL
            # MODE ONLY (see the full-mode branch below for the real counts);
            # light mode always reports null,null to stay within the #25
            # two-spawn poll-friendly budget.
            printf ',"dangling_images":null'
            printf ',"orphaned_containers":null'
        else
            printf ',"docker_reachable":false'
            printf ',"running_containers":null'
            printf ',"orphan_networks":null'
            printf ',"dangling_images":null'
            printf ',"orphaned_containers":null'
        fi
    else   # full mode
        local _ps_out
        # #41 DEC-U6 — image_stale is FULL MODE ONLY (over the #25 light-mode
        # spawn budget, which is why light mode never touches this). #52: the
        # per-container inspect is now BATCHED — one `docker inspect` for ALL
        # sandy containers (via _sandy_prefetch_container_inspect below) instead
        # of one per container, plus one `docker image inspect` per UNIQUE image
        # name (cached in _SANDY_IMAGE_ID_CACHE). Both caches are reset per-call
        # so a process emitting both light and full doesn't leak stale ids.
        _SANDY_IMAGE_ID_CACHE=""
        _SANDY_CINSPECT_CACHE=""
        if command -v docker >/dev/null 2>&1 \
           && _ps_out="$(docker ps --format '{{.ID}}|{{.Names}}|{{.Image}}|{{.CreatedAt}}|{{.Label "sandy.daemon"}}|{{.Label "sandy.session"}}|{{.Label "sandy.updated_at"}}' 2>/dev/null)"; then
            printf ',"docker_reachable":true'
            # #52 — pre-pass: collect the filtered sandy container ids and
            # prefetch all their image inspects in ONE docker call, so each
            # per-entry image_stale below is a cache hit. The grep mirrors the
            # loop's own filter; the cost here is a grep/awk (no docker), and the
            # array guard keeps the empty case a no-op on bash 3.2 + set -u.
            local _pf_cids=()
            while IFS= read -r _pfl; do
                [ -n "$_pfl" ] && _pf_cids+=("$(printf '%s' "$_pfl" | awk -F'|' '{print $1}')")
            done < <(printf '%s\n' "$_ps_out" | grep -E '(^|[|])sandy[_-]|[|]sandy-' || true)
            [ "${#_pf_cids[@]}" -gt 0 ] && _sandy_prefetch_container_inspect "${_pf_cids[@]}"
            printf ',"running_containers":['
            first=1
            # Use labels for sandy-launched containers. Sandy doesn't label all its
            # containers today — best-effort filter by image name.
            while IFS= read -r _cline; do
                [ -z "$_cline" ] && continue
                # line format: id|name|image|started|daemon-label|session-label
                local _cid _cname _cimg _cstarted _cdaemon _csession _cupdated
                _cid="$(echo "$_cline"     | awk -F'|' '{print $1}')"
                _cname="$(echo "$_cline"   | awk -F'|' '{print $2}')"
                _cimg="$(echo "$_cline"    | awk -F'|' '{print $3}')"
                _cstarted="$(echo "$_cline" | awk -F'|' '{print $4}')"
                _cdaemon="$(echo "$_cline"  | awk -F'|' '{print $5}')"
                _csession="$(echo "$_cline" | awk -F'|' '{print $6}')"
                _cupdated="$(echo "$_cline"  | awk -F'|' '{print $7}')"
                [ $first -eq 0 ] && printf ','
                first=0
                printf '{'
                _json_kv id         "$(_json_escape "$_cid")"
                printf ','; _json_kv name       "$(_json_escape "$_cname")"
                printf ','; _json_kv image      "$(_json_escape "$_cimg")"
                printf ','; _json_kv started_at "$(_json_escape "$_cstarted")"
                _sandy_emit_container_daemon_fields "$_cid" "$_cname" "$_cdaemon" "$_csession" "$_cupdated"
                printf ','; printf '"image_stale":%s' "$(_sandy_image_stale "$_cid")"
                printf '}'
            done < <(printf '%s\n' "$_ps_out" | grep -E '(^|[|])sandy[_-]|[|]sandy-' || true)
            printf ']'
            # #26 DEC-4c — see the light-mode branch above for the cost note.
            local _orphans; _orphans="$(_sandy_orphan_networks_list | grep -c . || true)"
            printf ',"orphan_networks":%s' "${_orphans:-0}"
            # #36 — dangling_images/orphaned_containers, FULL MODE ONLY (same
            # DEC-U6-style budget reasoning as image_stale): one extra
            # `docker images` spawn (dangling_images) and one extra
            # `docker ps -a` + bounded `docker exec ... tmux has-session`
            # probes, ONE per running daemon-labeled container ONLY
            # (orphaned_containers — mirrors orphan_networks's "extra spawns
            # only for candidates that need them" cost model).
            local _dangling; _dangling="$(_sandy_dangling_images_list | grep -c . || true)"
            printf ',"dangling_images":%s' "${_dangling:-0}"
            local _orphan_containers; _orphan_containers="$(_sandy_dead_owner_containers_list | grep -c . || true)"
            printf ',"orphaned_containers":%s' "${_orphan_containers:-0}"
        else
            printf ',"docker_reachable":false'
            printf ',"running_containers":null'
            printf ',"orphan_networks":null'
            printf ',"dangling_images":null'
            printf ',"orphaned_containers":null'
        fi
    fi

    printf '}\n'
}

# Validate a config file against the schema. Emits JSON with errors, warnings,
# unknown keys, and (for passive sources with privileged keys) approval status.
_sandy_validate_config() {
    local path="$1"
    if [ -z "$path" ]; then
        echo "[sandy] ERROR: --validate-config requires a path argument" >&2
        exit 1
    fi

    # Determine source tier from the path. Anything under $SANDY_HOME (home
    # config/secrets) is privileged; anything else is treated as passive
    # (workspace config).
    local abs_path tier workspace=""
    abs_path="$(cd "$(dirname "$path")" 2>/dev/null && pwd -P)/$(basename "$path")" || abs_path="$path"
    # Compare against a pwd -P-canonicalized SANDY_HOME so a symlinked SANDY_HOME
    # (or /tmp→/private/tmp on macOS) still matches the now-canonical abs_path —
    # regression from the #15.4 pwd -P change, which only canonicalized abs_path.
    local _sh_canon
    _sh_canon="$(cd "$SANDY_HOME" 2>/dev/null && pwd -P || printf '%s' "$SANDY_HOME")"
    case "$abs_path" in
        "$_sh_canon"/config|"$_sh_canon"/.secrets)
            tier="privileged" ;;
        *)
            tier="passive"
            # workspace is the parent of the .sandy/ directory containing this file
            local parent
            parent="$(dirname "$abs_path")"
            if [ "$(basename "$parent")" = ".sandy" ]; then
                workspace="$(dirname "$parent")"
            else
                workspace="$parent"
            fi
            ;;
    esac

    local errors=() warnings=() unknown=() privileged_keys=() env_only_keys=()
    local fatal=0

    if [ ! -f "$abs_path" ]; then
        errors+=("file does not exist: $abs_path")
        fatal=1
    else
        local key value
        while IFS='=' read -r key value; do
            value="${value#\"}" ; value="${value%\"}"
            value="${value#\'}" ; value="${value%\'}"
            if _key_in_list "$key" "${SANDY_PRIVILEGED_KEYS[@]}" \
               || { [ "$tier" = "passive" ] && _sandy_passive_value_privileged "$key" "$value"; }; then
                privileged_keys+=("$key")
                if [ "$tier" = "passive" ]; then
                    warnings+=("$key|weakens isolation / privileged key set from workspace — requires explicit approval|warning")
                fi
            elif _key_in_list "$key" "${SANDY_PASSIVE_KEYS[@]}"; then
                :  # allowed in any tier
            elif _key_in_list "$key" "${SANDY_ENV_ONLY_KEYS[@]}"; then
                env_only_keys+=("$key")
                warnings+=("$key|env-only key set in a config file — ignored at load time|warning")
            else
                unknown+=("$key")
            fi
        done < <(grep -E '^[A-Z_]+=.+' "$abs_path" 2>/dev/null)
    fi

    # For passive sources with privileged keys, compute the same approval
    # hash and file path that _resolve_passive_privileged_approval uses.
    local approval_status="none_required" approval_file_path="null"
    if [ $fatal -eq 0 ] && [ "$tier" = "passive" ] && [ ${#privileged_keys[@]} -gt 0 ]; then
        local kv_set sorted set_hash wd_hash
        kv_set=""
        while IFS='=' read -r key value; do
            value="${value#\"}" ; value="${value%\"}"
            value="${value#\'}" ; value="${value%\'}"
            if _key_in_list "$key" "${SANDY_PRIVILEGED_KEYS[@]}" \
               || _sandy_passive_value_privileged "$key" "$value"; then
                kv_set+="$key=$value"$'\n'
            fi
        done < <(grep -E '^[A-Z_]+=.+' "$abs_path" 2>/dev/null)
        sorted="$(printf '%s' "$kv_set" | sort -u)"
        if command -v sha256sum >/dev/null 2>&1; then
            set_hash="$(printf '%s' "$sorted" | sha256sum | awk '{print $1}')"
            wd_hash="$(printf '%s' "$workspace" | sha256sum | awk '{print $1}' | cut -c1-16)"
        elif command -v shasum >/dev/null 2>&1; then
            set_hash="$(printf '%s' "$sorted" | shasum -a 256 | awk '{print $1}')"
            wd_hash="$(printf '%s' "$workspace" | shasum -a 256 | awk '{print $1}' | cut -c1-16)"
        else
            set_hash=""
            wd_hash=""
        fi
        local app_file="$SANDY_HOME/approvals/passive-$wd_hash.list"
        approval_file_path="$(_json_escape "$app_file")"
        if [ -f "$app_file" ] && [ "$(head -n1 "$app_file" 2>/dev/null)" = "$set_hash" ]; then
            approval_status="approved"
        else
            approval_status="pending"
        fi
    fi

    # Emit JSON.
    printf '{'
    _json_kv schema_version "$SANDY_SCHEMA_VERSION"
    printf ','; _json_kv path "$(_json_escape "$abs_path")"
    printf ','; _json_kv source_tier "$(_json_escape "$tier")"

    printf ',"errors":['
    local first=1 e
    for e in "${errors[@]+"${errors[@]}"}"; do
        [ $first -eq 0 ] && printf ','
        first=0
        _json_escape "$e"
    done
    printf ']'

    printf ',"warnings":['
    first=1
    local w k m s
    for w in "${warnings[@]+"${warnings[@]}"}"; do
        [ $first -eq 0 ] && printf ','
        first=0
        k="$(echo "$w" | awk -F'|' '{print $1}')"
        m="$(echo "$w" | awk -F'|' '{print $2}')"
        s="$(echo "$w" | awk -F'|' '{print $3}')"
        printf '{'
        _json_kv key      "$(_json_escape "$k")"
        printf ','; _json_kv message  "$(_json_escape "$m")"
        printf ','; _json_kv severity "$(_json_escape "$s")"
        printf '}'
    done
    printf ']'

    printf ',"unknown_keys":['
    first=1
    local u
    for u in "${unknown[@]+"${unknown[@]}"}"; do
        [ $first -eq 0 ] && printf ','
        first=0
        _json_escape "$u"
    done
    printf ']'

    printf ',"privileged_keys_requiring_approval":['
    first=1
    local p
    for p in "${privileged_keys[@]+"${privileged_keys[@]}"}"; do
        [ "$tier" = "passive" ] || continue
        [ $first -eq 0 ] && printf ','
        first=0
        _json_escape "$p"
    done
    printf ']'

    printf ',"approval_status":%s' "$(_json_escape "$approval_status")"
    printf ',"approval_file_path":%s' "$approval_file_path"

    printf '}\n'

    # Publish the exit code via a global so the caller can propagate it
    # without tripping the ERR trap (a `return 1` at the end of the function
    # would abort the set -E-scoped trap installed by the fast-path handler).
    _SANDY_VALIDATE_RC=$fatal
}

# Introspection fast-path handlers. Each is wrapped in an ERR trap so that
# if `set -euo pipefail` trips a subtle failure inside the emit function
# (which would otherwise produce silent partial output and a non-zero exit),
# the user sees the failing line number and command on stderr. This is the
# diagnostic surface we'd otherwise need to infer from 2>/dev/null output.
_sandy_introspect_err_trap() {
    local code=$?
    echo "[sandy] ERROR: introspection handler failed (exit $code)" >&2
    echo "[sandy]        line ${BASH_LINENO[0]:-?}: ${BASH_COMMAND:-?}" >&2
    echo "[sandy]        Report this at https://github.com/rappdw/sandy/issues" >&2
}

if [[ "${1:-}" == "--print-schema" ]]; then
    set -E; trap _sandy_introspect_err_trap ERR
    _sandy_emit_schema
    exit 0
fi
if [[ "${1:-}" == "--print-state" ]]; then
    set -E; trap _sandy_introspect_err_trap ERR
    # $2 selects the mode: "light" for the cheap single-spawn path (#18),
    # anything else (incl. absent) → full. Forward-compatible: a consumer can
    # pass "light" unconditionally; an older sandy ignored $2 entirely.
    _sandy_emit_state "${2:-}"
    exit 0
fi
if [[ "${1:-}" == "--validate-config" ]]; then
    set -E; trap _sandy_introspect_err_trap ERR
    _SANDY_VALIDATE_RC=0
    _sandy_validate_config "${2:-}"
    exit "$_SANDY_VALIDATE_RC"
fi
if [[ "${1:-}" == "--prune-orphans" ]]; then
    # DEC-4d (#26) — maintenance fast-path: reap orphaned sandy_* networks and
    # exit, in the same pre-preflight family as --print-state. It's a global,
    # workspace-independent op, so it deliberately runs BEFORE the docker-info /
    # SANDY_HOME-writable / update-check preflight below and before any config
    # load, mutex, or image build: it needs neither a writable SANDY_HOME nor the
    # update check, only a reachable Docker daemon. Human-readable stdout (an
    # action verb, symmetric with --rebuild/--build-only — not introspection
    # JSON). Exit 0 on success (including "found none"); exit 1 only when docker
    # itself is unreachable (nothing to prune without it).
    if ! command -v docker >/dev/null 2>&1 || ! docker ps >/dev/null 2>&1; then
        error "--prune-orphans requires a reachable Docker daemon."
        exit 1
    fi
    _sandy_prune_before="$(_sandy_orphan_networks_list | grep -c . || true)"
    _sandy_prune_before="${_sandy_prune_before:-0}"
    if [ "$_sandy_prune_before" -eq 0 ]; then
        echo "No orphaned sandy networks found."
        exit 0
    fi
    _sandy_reap_orphan_networks || true
    # Re-count after reap (rather than trusting the attempt count) so the reported
    # number is what actually freed — a network that raced back to life (e.g. a
    # concurrent launch claimed it) between the list and the rm isn't claimed.
    _sandy_prune_after="$(_sandy_orphan_networks_list | grep -c . || true)"
    _sandy_prune_after="${_sandy_prune_after:-0}"
    echo "Reaped $((_sandy_prune_before - _sandy_prune_after)) orphaned sandy network(s)."
    exit 0
fi

if [[ "${1:-}" == "--gc" ]]; then
    # #36 — unified maintenance fast-path: one-shot global reclaim of
    # dead-owner sandy_* containers, orphaned sandy_* networks (reusing
    # _sandy_reap_orphan_networks UNCHANGED — DEC-4b, so this can never drift
    # from --prune-orphans, which stays as a documented subset), orphaned
    # per-project/skill images, and dangling sandy images. Same
    # pre-preflight family as --print-state/--prune-orphans: global,
    # workspace-independent, runs BEFORE config load, mutex, or image build
    # — needs only a reachable Docker daemon.
    #
    # CRITICAL: --dry-run/--yes are normally parsed by the MAIN flag-parsing
    # loop, but that loop runs AFTER this fast-path dispatch (same reason
    # --prune-orphans never takes sub-flags through it either) — so --gc
    # parses its OWN trailing args right here, into separate locals
    # (deliberately NOT SANDY_UPDATE_DRY_RUN/SANDY_UPDATE_YES, which belong to
    # the unrelated --update-sessions dispatcher and are populated by the
    # main loop long after this fast path would already have exited).
    _sandy_gc_dry_run=false
    _sandy_gc_yes=false
    shift
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run) _sandy_gc_dry_run=true ;;
            --yes)     _sandy_gc_yes=true ;;
            *)
                error "--gc: unrecognized argument: $1"
                exit 1
                ;;
        esac
        shift
    done

    if ! command -v docker >/dev/null 2>&1 || ! docker ps >/dev/null 2>&1; then
        error "--gc requires a reachable Docker daemon."
        exit 1
    fi

    # Compute all five lists up front so the printed plan and the confirm
    # prompt reflect exactly what's about to be removed. Containers use
    # "reap" mode here too (not just inside the reaper itself) so the plan
    # matches what will actually happen — --gc is an occasional, user-invoked
    # command, not a poll path, so paying the mid-startup retry twice (once
    # for the plan, once for the reap's own authoritative re-probe) is a
    # non-issue.
    _sandy_gc_containers="$(_sandy_dead_owner_containers_list reap)"
    _sandy_gc_networks="$(_sandy_orphan_networks_list)"
    _sandy_gc_proj_images="$(_sandy_orphaned_project_images_list)"
    _sandy_gc_skills_images="$(_sandy_orphaned_skills_images_list)"
    _sandy_gc_dangling_images="$(_sandy_dangling_images_list)"

    _sandy_gc_n_containers="$(printf '%s\n' "$_sandy_gc_containers" | grep -c . || true)"
    _sandy_gc_n_containers="${_sandy_gc_n_containers:-0}"
    _sandy_gc_n_networks="$(printf '%s\n' "$_sandy_gc_networks" | grep -c . || true)"
    _sandy_gc_n_networks="${_sandy_gc_n_networks:-0}"
    _sandy_gc_n_proj="$(printf '%s\n' "$_sandy_gc_proj_images" | grep -c . || true)"
    _sandy_gc_n_proj="${_sandy_gc_n_proj:-0}"
    _sandy_gc_n_skills="$(printf '%s\n' "$_sandy_gc_skills_images" | grep -c . || true)"
    _sandy_gc_n_skills="${_sandy_gc_n_skills:-0}"
    _sandy_gc_n_dangling="$(printf '%s\n' "$_sandy_gc_dangling_images" | grep -c . || true)"
    _sandy_gc_n_dangling="${_sandy_gc_n_dangling:-0}"

    _sandy_gc_total=$((_sandy_gc_n_containers + _sandy_gc_n_networks + _sandy_gc_n_proj + _sandy_gc_n_skills + _sandy_gc_n_dangling))

    printf '\n'
    printf 'sandy --gc: reclaim plan\n'
    if [ "$_sandy_gc_n_containers" -gt 0 ]; then
        printf 'Would remove %d dead-owner container(s):\n' "$_sandy_gc_n_containers"
        printf '%s\n' "$_sandy_gc_containers" | grep . | sed 's/^/  - /'
    fi
    if [ "$_sandy_gc_n_networks" -gt 0 ]; then
        printf 'Would remove %d orphaned network(s):\n' "$_sandy_gc_n_networks"
        printf '%s\n' "$_sandy_gc_networks" | grep . | sed 's/^/  - /'
    fi
    if [ "$_sandy_gc_n_proj" -gt 0 ]; then
        printf 'Would remove %d orphaned project image(s):\n' "$_sandy_gc_n_proj"
        printf '%s\n' "$_sandy_gc_proj_images" | grep . | sed 's/^/  - /'
    fi
    if [ "$_sandy_gc_n_skills" -gt 0 ]; then
        printf 'Would remove %d orphaned skills image(s):\n' "$_sandy_gc_n_skills"
        printf '%s\n' "$_sandy_gc_skills_images" | grep . | sed 's/^/  - /'
    fi
    if [ "$_sandy_gc_n_dangling" -gt 0 ]; then
        printf 'Would remove %d dangling sandy image(s):\n' "$_sandy_gc_n_dangling"
        printf '%s\n' "$_sandy_gc_dangling_images" | grep . | sed 's/^/  - /'
    fi
    printf '\n'

    if [ "$_sandy_gc_total" -eq 0 ]; then
        info "Nothing to reclaim."
        exit 0
    fi

    if [ "$_sandy_gc_dry_run" = "true" ]; then
        info "--dry-run: no resources removed."
        exit 0
    fi

    if [ "$_sandy_gc_yes" != "true" ]; then
        if [ -t 0 ]; then
            _sandy_gc_confirm=""
            printf '[sandy] Reclaim %d resource(s)? [y/N] ' "$_sandy_gc_total" >&2
            IFS= read -r _sandy_gc_confirm </dev/tty || _sandy_gc_confirm=""
            case "$_sandy_gc_confirm" in
                y|Y|yes|YES|Yes) : ;;
                *) info "Aborted — nothing removed."; exit 0 ;;
            esac
        else
            error "Non-interactive; pass --yes to reclaim without a prompt."
            exit 1
        fi
    fi

    # Reap order: containers -> networks -> project images -> skills images ->
    # dangling images LAST. `docker rmi` without -f no-ops on anything still
    # referenced by a child image or a running container, so containers go
    # first (freeing any container reference), then networks (no image
    # dependency either way, but matches the --prune-orphans ordering
    # convention), then the more-specific image tiers, with plain dangling
    # images last since they're the least likely to be referenced by
    # anything else and the safest to clear unconditionally.
    _sandy_gc_reap_containers
    _sandy_reap_orphan_networks || true
    _sandy_gc_reap_project_images
    _sandy_gc_reap_skills_images
    _sandy_gc_reap_dangling_images

    # Before/after re-count discipline (mirrors --prune-orphans): report what
    # actually freed, not the attempt count — a candidate that raced back to
    # life between the plan and the reap isn't falsely claimed.
    _sandy_gc_after_containers="$(_sandy_dead_owner_containers_list | grep -c . || true)"
    _sandy_gc_after_containers="${_sandy_gc_after_containers:-0}"
    _sandy_gc_after_networks="$(_sandy_orphan_networks_list | grep -c . || true)"
    _sandy_gc_after_networks="${_sandy_gc_after_networks:-0}"
    _sandy_gc_after_proj="$(_sandy_orphaned_project_images_list | grep -c . || true)"
    _sandy_gc_after_proj="${_sandy_gc_after_proj:-0}"
    _sandy_gc_after_skills="$(_sandy_orphaned_skills_images_list | grep -c . || true)"
    _sandy_gc_after_skills="${_sandy_gc_after_skills:-0}"
    _sandy_gc_after_dangling="$(_sandy_dangling_images_list | grep -c . || true)"
    _sandy_gc_after_dangling="${_sandy_gc_after_dangling:-0}"

    info "Reclaimed: $((_sandy_gc_n_containers - _sandy_gc_after_containers)) container(s), $((_sandy_gc_n_networks - _sandy_gc_after_networks)) network(s), $((_sandy_gc_n_proj - _sandy_gc_after_proj)) project image(s), $((_sandy_gc_n_skills - _sandy_gc_after_skills)) skills image(s), $((_sandy_gc_n_dangling - _sandy_gc_after_dangling)) dangling image(s)."
    exit 0
fi

# --- Help ---
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    cat <<EOF
sandy $(sandy_full_version) — an isolated sibling for your coding agents

Run Claude Code, Gemini CLI, or Codex CLI (or any combo) in a Docker container
with filesystem isolation, network isolation, resource limits, and per-project
credential sandboxes.

Usage:
  sandy                          Resume last session (or start new)
  sandy --new                    Start a fresh session
  sandy -p "prompt"              One-shot prompt
  sandy --resume                 Open session picker
  sandy --remote                 Start in remote-control server mode
  sandy --agent claude,gemini    Launch specific agent(s) for this run
  sandy --help                   Show this help

Environment variables:
  SANDY_MODEL        Model to use (default: claude-opus-4-8)
  ANTHROPIC_API_KEY  API key (not needed with Claude Max / OAuth)
  SANDY_HOME         Sandy config directory (default: ~/.sandy)
  SANDY_SSH          Git SSH method: "token" (default) uses gh CLI token
                     with HTTPS; "agent" forwards host SSH agent via relay
  SANDY_SKIP_PERMISSIONS  Set to "false" to keep Claude Code's permission
                     system active (default: "true" — bypasses permissions)
  SANDY_ALLOW_LAN_HOSTS  Comma-separated IPs/CIDRs to allow through
                     LAN isolation (e.g. "192.168.1.50,10.0.0.0/24")
  SANDY_ALLOW_NO_ISOLATION  Set to "1" to allow launch when iptables
                     rules cannot be applied (Linux only)
  SANDY_CPUS         CPU limit for container (default: auto-detected)
  SANDY_MEM          Memory limit for container (default: auto-detected)
  SANDY_GPU          GPU passthrough: "all" for all GPUs, or device IDs
                     like "0" or "0,1" (requires NVIDIA Container Toolkit)
  SANDY_SKILL_PACKS  Comma-separated skill packs to install (e.g. "gstack")
  SANDY_AGENT        AI agent(s): "claude" (default), "gemini", "codex",
                     "opencode", or comma-separated combo
                     (e.g. "claude,gemini,codex"). Alias: "all" = all four.
  GEMINI_API_KEY     Google API key for Gemini CLI (SANDY_AGENT=gemini only)
  GEMINI_MODEL       Gemini model override (SANDY_AGENT=gemini only)
  OPENAI_API_KEY     OpenAI API key for Codex CLI
  CODEX_MODEL        Codex model override (SANDY_AGENT=codex only)
  OPENCODE_MODEL     OpenCode model override (provider/model format)
  SANDY_LOCAL_LLM_HOST  host:port to allow through LAN isolation, e.g.
                     "127.0.0.1:11434" for local Ollama. Inserts a single
                     iptables ACCEPT and (Linux) maps host.docker.internal.
  CLAUDE_CODE_MAX_OUTPUT_TOKENS  Max output tokens per response (default: 128000)

Per-project config:
  .sandy/config      Parsed on launch (allowlisted KEY=VALUE lines only)

Flags:
  --help             Show this help
  --version          Show version
  --rebuild          Force rebuild of the sandbox Docker image
  --build-only       Build images and exit (for CI)
  --new              Start a fresh session (default: resume last)
  --resume           Open session picker
  --remote           Start in remote-control server mode
  --upgrade          Update sandy to the latest version
  --agent <list>     Agent(s) to launch (overrides SANDY_AGENT and
                     .sandy/config). One of: claude, gemini, codex,
                     opencode. Comma-separated for multi-agent,
                     e.g. --agent claude,gemini or --agent=claude,opencode
  -v                 Verbose: show startup sections, pause on exit
  -vv                Debug: add bash trace to user-setup.sh
  -vvv               Full trace: also trace entrypoint.sh and show docker flags

Maintenance (no config/mutex/build — needs only a reachable Docker daemon):
  --prune-orphans    Reap orphaned sandy_* networks (dead-owner, no attached
                     container) and exit
  --gc               One-shot global reclaim: dead-owner containers, orphaned
                     sandy_* networks, orphaned per-project/skill images, and
                     dangling sandy images. Sub-options: --dry-run, --yes

Introspection (machine-readable JSON; no Docker required):
  --print-schema          Emit the static schema (config keys, flags, agents,
                          protected paths). See SPEC_INTROSPECTION.md.
  --print-state           Emit runtime state (sandboxes, approvals, running
                          containers). docker_reachable=false if docker absent.
  --validate-config PATH  Validate a config file against the schema; emit JSON
                          with errors, unknowns, and passive-approval status.

All other arguments are forwarded to the agent (claude or gemini).
EOF
    exit 0
fi

# --- Parse sandy flags (order-independent, consumed before forwarding to claude) ---
SANDY_REBUILD=false
SANDY_BUILD_ONLY=false
SANDY_NEW_SESSION=false
SANDY_REMOTE_CONTROL=false
# Daemon-mode (milestone 1.1.0, #17). SANDY_START=true, SANDY_ATTACH=true, and
# SANDY_STOP=true are set by their respective flags below; --workspace is
# shared across all three (and bare `sandy`). SANDY_DAEMON_SUPERVISOR is NOT a
# CLI flag — it's an internal env var the --start dispatcher sets when it
# re-execs "$0" as the detached supervisor (see the dispatcher block near
# WORK_DIR resolution).
SANDY_START=false
SANDY_ATTACH=false
SANDY_STOP=false
SANDY_WORKSPACE_ARG=""
# Fleet updates (milestone 1.2.0, #41). SANDY_UPDATE_SESSIONS=true plus its
# sub-option vars are set by their respective flags below. Global command —
# does NOT use SANDY_WORKSPACE_ARG (it ignores cwd and operates on every
# daemon session on the host; see the dispatcher block near --stop).
SANDY_UPDATE_SESSIONS=false
SANDY_UPDATE_DRY_RUN=false
SANDY_UPDATE_YES=false
SANDY_UPDATE_IDLE_FOR=""
# Capture whether SANDY_VERBOSE came from the real env BEFORE defaulting it: the
# env snapshot below can't otherwise distinguish a defaulted 0 from an env-set 0,
# so it would mark SANDY_VERBOSE "env-set" and skip a value set in a config file
# (it's a documented passive key). CLI -v/-vv/-vvv also set this flag, so env and
# CLI both correctly win over config; neither → the config value is honored.
_SANDY_VERBOSE_EXPLICIT=0; [ -n "${SANDY_VERBOSE+x}" ] && _SANDY_VERBOSE_EXPLICIT=1
SANDY_VERBOSE="${SANDY_VERBOSE:-0}"
# --agent's value is stashed here rather than assigned directly to SANDY_AGENT,
# because SANDY_AGENT is also set by _load_sandy_config() further down and we
# want the CLI flag to win over per-project and user config. The override is
# applied just before agent resolution.
SANDY_AGENT_OVERRIDE=""
REMAINING_ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --rebuild)    SANDY_REBUILD=true ;;
        --build-only) SANDY_BUILD_ONLY=true ;;
        --new)        SANDY_NEW_SESSION=true ;;
        --remote)     SANDY_REMOTE_CONTROL=true ;;
        --start)      SANDY_START=true ;;
        --workspace)
            if [ $# -lt 2 ] || [[ "$2" == -* ]]; then
                echo "[sandy] ERROR: --workspace requires a value (e.g. --workspace /path/to/project)" >&2
                exit 1
            fi
            shift
            SANDY_WORKSPACE_ARG="$1"
            ;;
        --workspace=*) SANDY_WORKSPACE_ARG="${1#--workspace=}" ;;
        --attach)     SANDY_ATTACH=true ;;
        --stop)       SANDY_STOP=true ;;
        --update-sessions) SANDY_UPDATE_SESSIONS=true ;;
        --dry-run)    SANDY_UPDATE_DRY_RUN=true ;;
        --yes)        SANDY_UPDATE_YES=true ;;
        --idle-for)
            if [ $# -lt 2 ] || [[ "$2" == -* ]]; then
                echo "[sandy] ERROR: --idle-for requires a value in minutes (e.g. --idle-for 30)" >&2
                exit 1
            fi
            shift
            if ! [[ "$1" =~ ^[0-9]+$ ]] || [ "$1" -eq 0 ]; then
                echo "[sandy] ERROR: --idle-for requires a positive integer number of minutes, got: $1" >&2
                exit 1
            fi
            SANDY_UPDATE_IDLE_FOR="$1"
            ;;
        --idle-for=*)
            SANDY_UPDATE_IDLE_FOR="${1#--idle-for=}"
            if ! [[ "$SANDY_UPDATE_IDLE_FOR" =~ ^[0-9]+$ ]] || [ "$SANDY_UPDATE_IDLE_FOR" -eq 0 ]; then
                echo "[sandy] ERROR: --idle-for requires a positive integer number of minutes, got: $SANDY_UPDATE_IDLE_FOR" >&2
                exit 1
            fi
            ;;
        --upgrade)    sandy_self_update; exit 0 ;;
        --agent)
            if [ $# -lt 2 ] || [[ "$2" == -* ]]; then
                echo "[sandy] ERROR: --agent requires a value (e.g. --agent claude,gemini)" >&2
                exit 1
            fi
            shift
            SANDY_AGENT_OVERRIDE="$1"
            ;;
        --agent=*)    SANDY_AGENT_OVERRIDE="${1#--agent=}" ;;
        -vvv)         SANDY_VERBOSE=3; _SANDY_VERBOSE_EXPLICIT=1 ;;
        -vv)          SANDY_VERBOSE=2; _SANDY_VERBOSE_EXPLICIT=1 ;;
        -v)           SANDY_VERBOSE=1; _SANDY_VERBOSE_EXPLICIT=1 ;;
        *)            REMAINING_ARGS+=("$1") ;;
    esac
    shift
done
set -- ${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}

# Host-side headless detection — -p/--print/--prompt among the forwarded args.
# Consumed by the --start dispatcher's H3 reject (a one-shot under --restart
# unless-stopped would restart-loop) and the passive-approval fail-closed
# check. The container-side launch script (USERSETUP heredoc) does its own
# identical scan for its own purposes — this host-side copy is what makes
# $_sandy_is_headless defined under `set -u` in the host process. (Regression
# note: without it, `sandy --start` died with "unbound variable" — but only on
# hosts with docker present, because the docker preflight exits first when
# docker is absent, which is why docker-less static checks couldn't catch it.)
_sandy_is_headless=false
for _sandy_headless_arg in "$@"; do
    case "$_sandy_headless_arg" in
        -p|--print|--prompt) _sandy_is_headless=true; break ;;
    esac
done

# --- Check for sandy updates (non-blocking, cached 24h) ---
sandy_check_update

# --- Preflight checks ---
if ! command -v docker &>/dev/null; then
    error "Docker is not installed or not in PATH."
    exit 1
fi
# `command -v` only proves the client binary exists. If the daemon isn't running,
# sandy would otherwise slip past here and die later with a raw Docker error mid-
# launch. Fail fast with a clear, actionable message. (Fast-path handlers —
# --version/--help/--upgrade/--print-*/--validate-config — have already exited
# above, so this never blocks the no-Docker-needed paths.)
if ! docker info >/dev/null 2>&1; then
    error "Docker is installed but the daemon isn't responding."
    error "  Start Docker (Docker Desktop, or 'sudo systemctl start docker') and retry."
    exit 1
fi
# SANDY_HOME must be writable from here on — sandy writes sandbox state, generated
# build files, and proxy/session configs there. The introspection fast-paths above
# tolerate a read-only home (they write nothing) and have already exited.
if ! ( : > "$SANDY_HOME/.sandy-write-test" ) 2>/dev/null; then
    error "SANDY_HOME ($SANDY_HOME) is not writable (or could not be created)."
    error "  Sandy must write sandbox state and build files there. Fix with:"
    error "    chmod u+rwx \"$SANDY_HOME\"   — or set SANDY_HOME to a writable path."
    exit 1
fi
rm -f "$SANDY_HOME/.sandy-write-test" 2>/dev/null || true

# --- Build file generators ---
generate_dockerfile_base() {
    cat > "$SANDY_HOME/Dockerfile.base.new" <<'DOCKERFILE_BASE'
FROM debian:bookworm-slim

# Some Docker Desktop versions prevent the _apt user from reading the
# temp files apt stages for gpgv, producing spurious "invalid signature"
# errors on apt-get update. Run gpgv as root to sidestep the sandbox.
RUN echo 'APT::Sandbox::User "root";' > /etc/apt/apt.conf.d/99-no-sandbox

# System tools + C/C++ toolchain
RUN apt-get update && apt-get install -y \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        git \
        git-lfs \
        gosu \
        jq \
        less \
        libcairo2 \
        libgdk-pixbuf-2.0-0 \
