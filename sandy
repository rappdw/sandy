if [ -d "$LEGACY_SANDBOX" ] && [ ! -d "$SANDBOX_DIR" ]; then
    info "Migrating sandbox: ${FULL_HASH} → ${SANDBOX_NAME}"
    mv "$LEGACY_SANDBOX" "$SANDBOX_DIR"
    # Migrate the companion .claude.json too
    if [ -f "$LEGACY_SANDBOX.claude.json" ]; then
        mv "$LEGACY_SANDBOX.claude.json" "$SANDY_HOME/sandboxes/${SANDBOX_NAME}.claude.json"
    fi
fi

if [ ! -d "$SANDBOX_DIR" ]; then
    info "Creating new sandbox: $SANDBOX_DIR"
    mkdir -p "$SANDBOX_DIR"
    # Seed settings from host's ~/.claude if available
    if [ -f "$HOME/.claude/settings.json" ]; then
        cp "$HOME/.claude/settings.json" "$SANDBOX_DIR/settings.json"
        info "  Seeded settings.json"
    fi
    # Seed statsig cache for feature flags
    if [ -d "$HOME/.claude/statsig" ]; then
        cp -r "$HOME/.claude/statsig" "$SANDBOX_DIR/statsig"
        info "  Seeded statsig/"
    fi
    # NOTE: Plugin marketplace catalogs are NOT seeded from host — the sandy-plugins
    # marketplace is configured via extraKnownMarketplaces in user-setup.sh (baked into
    # the image). Claude Code fetches the catalog on first /plugin browse.
    # Write sandy-required defaults into settings.json (merge with seeded copy)
    SETTINGS_FILE="$SANDBOX_DIR/settings.json"
    [ -f "$SETTINGS_FILE" ] || echo '{}' > "$SETTINGS_FILE"
    # Use node to safely merge JSON (available from the host or as a fallback)
    if command -v node &>/dev/null; then
        node -e "
            const fs = require('fs');
            const f = process.argv[1];
            let raw = fs.readFileSync(f, 'utf8');
            // Fix common JSON issues: trailing commas, missing commas before keys
            raw = raw.replace(/,(\s*[}\]])/g, '\$1');
            raw = raw.replace(/(\"[^\"]*\")\s*\n(\s*\")/g, '\$1,\n\$2');
            let s;
            try { s = JSON.parse(raw); } catch { s = {}; }
            const skip = (process.env.SANDY_SKIP_PERMISSIONS || 'true') !== 'false';
            const defaults = {teammateMode:'tmux', spinnerTipsEnabled:false, skipDangerousModePermissionPrompt:skip};
            for (const [k,v] of Object.entries(defaults)) { if (!(k in s)) s[k]=v; }
            // Strip enabledPlugins — no plugins installed in fresh sandbox
            delete s.enabledPlugins;
            fs.writeFileSync(f, JSON.stringify(s, null, 2) + '\n');
        " "$SETTINGS_FILE"
    elif command -v jq &>/dev/null; then
        # jq fallback for hosts without node
        skip_perm="true"
        [ "${SANDY_SKIP_PERMISSIONS:-true}" = "false" ] && skip_perm="false"
        jq --arg skip "$skip_perm" '
            .teammateMode //= "tmux" |
            .spinnerTipsEnabled //= false |
            .skipDangerousModePermissionPrompt //= ($skip == "true") |
            del(.enabledPlugins)
        ' "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp" && mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"
    else
        # Last resort: write defaults only if file is empty/bare
        if [ "$(cat "$SETTINGS_FILE")" = "{}" ]; then
            skip_perm="true"
            [ "${SANDY_SKIP_PERMISSIONS:-true}" = "false" ] && skip_perm="false"
            printf '{"teammateMode":"tmux","spinnerTipsEnabled":false,"skipDangerousModePermissionPrompt":%s}\n' "$skip_perm" > "$SETTINGS_FILE"
        fi
    fi
else
    info "Reusing sandbox: $SANDBOX_DIR"
fi

# Ensure persistent package directories exist (created once, reused across sessions)
mkdir -p "$SANDBOX_DIR/pip"                 # PYTHONUSERBASE (pip install --user)
mkdir -p "$SANDBOX_DIR/uv"                 # uv-managed Python versions
