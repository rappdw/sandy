# Resolve which ref of the proxy module to build into the sandy-proxy image.
# Precedence: explicit SANDY_PROXY_REF override > the sandy release tag (when
# running a tagged release) > "main" (for -dev/-rc builds, which track main).
#
# The proxy lives in the sandy repo under proxy/ as a nested Go module. Rather
# than maintain a separate proxy/vX.Y.Z tag at every release, the image build
# `git clone`s the sandy repo at this ref and `go build`s proxy/ from the tree —
# so the existing root vX.Y.Z tag is the pin, exactly as requested.
#
# Dev note: before the M2.7 proxy work merges to main, set
#   SANDY_PROXY_REF=<branch-or-commit>
# (e.g. the m2.7-proxy branch) so the image can build from unreleased source.
_sandy_proxy_ref() {
    if [ -n "${SANDY_PROXY_REF:-}" ]; then
        printf '%s' "$SANDY_PROXY_REF"
        return
    fi
    # GitHub Actions PR builds check out a detached merge ref, so the branch
    # detection below would wrongly fall back to main — which has no proxy/ until
    # this very PR merges. GITHUB_HEAD_REF is the PR's source branch (which does
    # carry proxy/), so build from it. It's unset for push-to-main / release CI,
    # where the version/branch logic below is the correct path.
    if [ -n "${GITHUB_HEAD_REF:-}" ]; then
        printf '%s' "$GITHUB_HEAD_REF"
        return
    fi
    case "$SANDY_VERSION" in
        *-dev)
            # Dev tree: build the proxy from source. From a git checkout, use
            # the current branch (it carries proxy/ — so `./sandy` works on a
            # feature branch before it merges); otherwise fall back to main
            # (installed copies, detached HEAD).
            local _d _b
            _d="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)" || _d="."
            _b="$(git -C "$_d" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
            if [ -n "$_b" ] && [ "$_b" != "HEAD" ]; then
                printf '%s' "$_b"
            else
                printf 'main'
            fi
            ;;
        *-rc*)
            # Published release candidate: a vX.Y.Z-rcN tag exists, so pin to
            # it exactly like a stable release — installed rc users must get
            # the tagged proxy, and the ref string changing rc1→rc2 is what
            # makes Dockerfile.proxy's hash move so proxy fixes in later rcs
            # actually rebuild. From a pre-tag git checkout (cutting the rc
            # itself), prefer the branch so the tag needn't exist yet.
            local _d _b
            _d="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)" || _d="."
            _b="$(git -C "$_d" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
            if [ -n "$_b" ] && [ "$_b" != "HEAD" ]; then
                printf '%s' "$_b"
            else
                printf 'v%s' "$SANDY_VERSION"
            fi
            ;;
        *)           printf 'v%s' "$SANDY_VERSION" ;;
    esac
}

# sandy-proxy egress-proxy image (M2.7). Multi-stage: a golang build stage that
# clones the sandy repo at the resolved ref and statically compiles proxy/, then
# a `scratch` runtime holding just the binary. The proxy never terminates TLS
# and resolves upstreams with Go's pure resolver, so it needs no CA bundle and
# no libc — scratch is the smallest, hardest-to-attack base for a security
# component. The git ref is a build-arg so the build hash (and thus rebuilds)
# track the pinned version.
generate_dockerfile_proxy() {
    local ref
    ref="$(_sandy_proxy_ref)"
    cat > "$SANDY_HOME/Dockerfile.proxy.new" <<DOCKERFILE
# syntax pinned implicitly by the golang base tag
FROM golang:1.24-bookworm AS build
ARG SANDY_PROXY_REF=${ref}
RUN git clone https://github.com/rappdw/sandy /src \\
 && git -C /src checkout "\${SANDY_PROXY_REF}" \\
 && cd /src/proxy \\
 && CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /sandy-proxy .

FROM scratch
COPY --from=build /sandy-proxy /usr/local/bin/sandy-proxy
# Config is bind-mounted at /etc/sandy-proxy.json by the launcher (PR 2.7.3).
# Readiness (#37): scratch has no shell, so the healthcheck IS the binary
# re-invoked with -healthcheck, probing its own listeners. The container reports
# `healthy` only once the listeners actually bind, not merely when the process
# starts — closing the transient "connection refused" window on the first
# request. Exec form (no shell); the launcher's gate polls .State.Health.Status.
HEALTHCHECK --interval=1s --start-period=0s --timeout=2s --retries=3 CMD ["/usr/local/bin/sandy-proxy", "-healthcheck"]
ENTRYPOINT ["/usr/local/bin/sandy-proxy"]
DOCKERFILE
}

generate_entrypoint() {
    cat > "$SANDY_HOME/entrypoint.sh.new" <<'ENTRYPOINT'
#!/bin/bash
# --- Root-only setup (runs before dropping to user claude) ---
if [ "${SANDY_VERBOSE:-0}" -ge 3 ]; then
    set -x
fi

# Determine runtime UID/GID (match host user for bind-mount permissions on Linux)
RUN_UID="${HOST_UID:-1001}"
RUN_GID="${HOST_GID:-1001}"

# Fix ownership of tmpfs home directory (mounted with uid=1001, may differ from host)
chown "$RUN_UID:$RUN_GID" /home/claude

# Seed known_hosts from host if available
if [ -f "/tmp/host-ssh-known_hosts" ]; then
    mkdir -p /home/claude/.ssh
    cp /tmp/host-ssh-known_hosts /home/claude/.ssh/known_hosts
    chown -R "$RUN_UID:$RUN_GID" /home/claude/.ssh
    chmod 700 /home/claude/.ssh
    chmod 644 /home/claude/.ssh/known_hosts
fi

if [ "${SANDY_SSH:-token}" = "agent" ]; then
    # --- SSH agent mode ---
    # SSH agent relay: create a Unix socket that relays to the host's TCP relay
    if [ -n "${SSH_RELAY_PORT:-}" ]; then
        rm -f /tmp/ssh-agent.sock
        socat UNIX-LISTEN:/tmp/ssh-agent.sock,fork,mode=0600,uid="$RUN_UID" \
              TCP:host.docker.internal:${SSH_RELAY_PORT} &
        # Wait for socket to appear
        for i in $(seq 1 50); do [ -S /tmp/ssh-agent.sock ] && break; sleep 0.1; done
        export SSH_AUTH_SOCK=/tmp/ssh-agent.sock
    elif [ -S "/tmp/ssh-agent.sock" ]; then
        # Linux: socket was mounted directly
        chmod 600 /tmp/ssh-agent.sock && chown "$RUN_UID:$RUN_GID" /tmp/ssh-agent.sock
    fi

    # Copy host SSH config/keys with correct ownership and permissions.
    # Use -L to dereference symlinks (host absolute paths break in container).
    # Skip dangling symlinks (target doesn't exist on host).
    if [ -d "/tmp/host-ssh" ]; then
        mkdir -p /home/claude/.ssh
        for _f in /tmp/host-ssh/*  /tmp/host-ssh/.*; do
            [ -e "$_f" ] || continue
            case "$(basename "$_f")" in .|..) continue ;; esac
            cp -aL "$_f" /home/claude/.ssh/ 2>/dev/null || true
        done
        chown -R "$RUN_UID:$RUN_GID" /home/claude/.ssh
        chmod 700 /home/claude/.ssh
        chmod 600 /home/claude/.ssh/* 2>/dev/null || true
        chmod 644 /home/claude/.ssh/*.pub 2>/dev/null || true
        chmod 644 /home/claude/.ssh/known_hosts 2>/dev/null || true
        chmod 644 /home/claude/.ssh/config 2>/dev/null || true
    fi

    # Egress-proxy mode: the agent is on the --internal sidecar, so a direct
    # TCP to github.com:22 is impossible — git-over-SSH must tunnel through the
    # proxy's CONNECT listener (:3128). socat's PROXY address speaks HTTP
    # CONNECT; ssh substitutes %h/%p with the real target. We prepend a Host *
    # block so it applies to every ssh target (ssh uses the first ProxyCommand
    # it obtains for a host). The proxy allowlist-checks github.com:22 (in the
    # default set) before splicing.
    if [ -n "${SANDY_PROXY_IP:-}" ]; then
        mkdir -p /home/claude/.ssh
        _sshcfg=/home/claude/.ssh/config
        _sshtmp="$(mktemp)"
        {
            printf 'Host *\n    ProxyCommand socat - PROXY:%s:%%h:%%p,proxyport=3128\n\n' "$SANDY_PROXY_IP"
            [ -f "$_sshcfg" ] && cat "$_sshcfg"
        } > "$_sshtmp"
        mv "$_sshtmp" "$_sshcfg"
        chown -R "$RUN_UID:$RUN_GID" /home/claude/.ssh
        chmod 700 /home/claude/.ssh
        chmod 644 "$_sshcfg"
    fi
fi

# Fix ownership of persistent package mounts. Note: .gstack is intentionally
# omitted — it's bind-mounted from the workspace (not from $SANDBOX_DIR), so
# chown'ing it here would write through to the host workspace's ownership,
# which we don't want to touch.
for d in /home/claude/.pip-packages /home/claude/.local/share/uv \
         /home/claude/.npm-global /home/claude/go /home/claude/.cargo; do
    chown "$RUN_UID:$RUN_GID" "$d" 2>/dev/null || true
done

# Restore native install layout so Claude Code finds its binary and data at the
# expected paths (the real files live outside /home/claude to survive the tmpfs overlay).
# Gemini CLI is installed globally via npm and doesn't need this relocation.
mkdir -p /home/claude/.local/bin /home/claude/.local/share
case ",${SANDY_AGENT:-claude}," in *,claude,*)
    ln -sf /usr/local/bin/claude /home/claude/.local/bin/claude
    ln -sf /opt/claude-code /home/claude/.local/share/claude
    ;; esac
# chown the tmpfs dirs individually — avoid -R which would recurse into
# the bind-mounted uv directory at .local/share/uv
chown "$RUN_UID:$RUN_GID" /home/claude/.local /home/claude/.local/bin \
    /home/claude/.local/share 2>/dev/null || true
[ -L /home/claude/.local/share/claude ] && chown "$RUN_UID:$RUN_GID" /home/claude/.local/share/claude 2>/dev/null || true

# Create pip/pip3 wrappers that auto-add --user for install commands when NOT
# inside a virtualenv. Created here (root section) because the user section is
# inside bash -c '...' where heredoc quoting breaks.
cat > /home/claude/.local/bin/pip <<'PIPWRAP'
#!/bin/bash
if [ -z "$VIRTUAL_ENV" ] && [ "${1:-}" = "install" ]; then
    shift
    exec python3 -m pip install --user "$@"
fi
exec python3 -m pip "$@"
PIPWRAP
cp /home/claude/.local/bin/pip /home/claude/.local/bin/pip3
chmod +x /home/claude/.local/bin/pip /home/claude/.local/bin/pip3
chown "$RUN_UID:$RUN_GID" /home/claude/.local/bin/pip /home/claude/.local/bin/pip3

# Drop privileges to host user's UID/GID
exec gosu "$RUN_UID:$RUN_GID" /usr/local/bin/user-setup.sh "$@"
ENTRYPOINT
}

generate_user_setup() {
    cat > "$SANDY_HOME/user-setup.sh.new" <<'USERSETUP'
#!/bin/bash
set -e
trap 'echo "[sandy] ERROR: user-setup.sh failed at line $LINENO: $BASH_COMMAND" >&2' ERR
if [ "${SANDY_VERBOSE:-0}" -ge 1 ]; then
    sandy_log() { printf '\033[0;36m[sandy] ▶ %s\033[0m\n' "$1"; }
else
    sandy_log() { :; }
fi
if [ "${SANDY_VERBOSE:-0}" -ge 2 ]; then
    set -x
fi
export HOME=/home/claude
# Convenience: _sandy_has_X returns true if agent X is in the comma-separated SANDY_AGENT list.
_sandy_has_claude()   { case ",${SANDY_AGENT:-claude}," in *,claude,*)   return 0 ;; esac; return 1; }
_sandy_has_gemini()   { case ",${SANDY_AGENT:-claude}," in *,gemini,*)   return 0 ;; esac; return 1; }
