            .teammateMode //= "tmux" |
            .spinnerTipsEnabled //= false |
            .skipDangerousModePermissionPrompt //= ($skip == "true") |
            del(.enabledPlugins)
        ' "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp" && mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"
    else
        # Last resort: write defaults only if file is empty/bare
        if [ "$(cat "$SETTINGS_FILE")" = "{}" ]; then
            skip_perm="true"
            [ "${SANDY_SKIP_PERMISSIONS:-true}" = "false" ] && skip_perm="false"
            printf '{"teammateMode":"tmux","spinnerTipsEnabled":false,"skipDangerousModePermissionPrompt":%s}\n' "$skip_perm" > "$SETTINGS_FILE"
        fi
    fi
