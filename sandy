# Gemini extensions seeding (SANDY_GEMINI_EXTENSIONS)
# Idempotent: check against the installed extension list (keyed on source URL)
# rather than guessing the directory name from the repo basename — extensions
# install under their declared name, which often differs (e.g. .../security
# installs as gemini-cli-security).
if _sandy_has_gemini && [ -n "${SANDY_GEMINI_EXTENSIONS:-}" ] && command -v gemini &>/dev/null; then
    sandy_log "Installing Gemini extensions"
    mkdir -p "$HOME/.gemini/extensions"
    # Cache the installed-extensions listing once per launch.
    _gem_installed="$(gemini extensions list 2>/dev/null || true)"
    IFS=',' read -ra _exts <<< "$SANDY_GEMINI_EXTENSIONS"
    for _ext in "${_exts[@]}"; do
        _ext="$(echo "$_ext" | tr -d '[:space:]')"
        [ -z "$_ext" ] && continue
        # Match on the URL and on the repo basename — covers both display
        # formats that different Gemini CLI versions use in `extensions list`.
        _name="$(basename "$_ext" .git)"
        if echo "$_gem_installed" | grep -qFe "$_ext" || \
           echo "$_gem_installed" | grep -qiE "(^|[^a-z0-9-])${_name}([^a-z0-9-]|$)"; then
            continue
        fi
        _install_out="$(gemini extensions install "$_ext" 2>&1)" || {
            # "already installed" is a benign race, not a failure
            if echo "$_install_out" | grep -qi "already installed"; then
                :
            else
                echo "[sandy] WARN: Failed to install Gemini extension: $_ext" >&2
                echo "$_install_out" >&2
            fi
        }
    done
fi

# Remap ANSI dark blue (color 4) to a readable bright blue
printf "\033]4;4;rgb:61/8f/ff\033\\"
trap "printf \"\033]104;4\033\\\\\"" EXIT

sandy_log "Configuring project settings"
WORKSPACE="${SANDY_WORKSPACE:-/workspace}"

# Ensure project-level config dirs exist (Claude only — Gemini uses .gemini/)
if _sandy_has_claude; then
    mkdir -p "$WORKSPACE/.claude" 2>/dev/null || true

    # Project dir for current workspace
    _cur_proj="$HOME/.claude/projects/$(echo "$WORKSPACE" | tr '/' '-')"
    mkdir -p "$_cur_proj"
fi

# Ensure plugin marketplaces are configured in settings.json (idempotent, Claude only)
SETTINGS_FILE="$HOME/.claude/settings.json"
if _sandy_has_claude && [ -f "$SETTINGS_FILE" ]; then
    node -e '
        const fs = require("fs");
        const f = process.argv[1];
        let s;
        try { s = JSON.parse(fs.readFileSync(f, "utf8")); } catch(e) { s = {}; }
        if (!s.extraKnownMarketplaces) s.extraKnownMarketplaces = {};
        const required = {
            "claude-plugins-official": { source: { source: "github", repo: "anthropics/claude-plugins-official" } },
            "sandy-plugins": { source: { source: "github", repo: "rappdw/sandy-plugins" } }
        };
        const deprecated = ["thinkkit", "ait", "pka-skills"];
        let changed = false;
        for (const name of deprecated) {
            if (s.extraKnownMarketplaces[name]) {
                delete s.extraKnownMarketplaces[name];
                changed = true;
            }
        }
        for (const [name, cfg] of Object.entries(required)) {
            if (!s.extraKnownMarketplaces[name]) {
                s.extraKnownMarketplaces[name] = cfg;
                changed = true;
            }
        }
        if (changed) fs.writeFileSync(f, JSON.stringify(s, null, 2) + "\n");
    ' "$SETTINGS_FILE"
fi

sandy_log "Configuring git"
# Trust all directories (host UID differs from container UID; container is sandboxed)
git config --global --add safe.directory "*"

# Set git identity from host
if [ -n "${GIT_USER_NAME:-}" ]; then
    git config --global user.name "$GIT_USER_NAME"
fi
if [ -n "${GIT_USER_EMAIL:-}" ]; then
    git config --global user.email "$GIT_USER_EMAIL"
fi

sandy_log "Running dev environment checks"
# --- Dev environment checks ---
# Set up git-lfs filters if the workspace is a git repo using LFS (home is tmpfs, so config is lost each session)
if [ -d "$WORKSPACE/.git" ] || [ -f "$WORKSPACE/.git" ]; then
    if find "$WORKSPACE" -name .gitattributes -maxdepth 3 -exec grep -ql "filter=lfs" {} + 2>/dev/null; then
        git lfs install 2>/dev/null || true
    fi
fi

# Auto-install Python version if .python-version exists (uv is idempotent & fast)
if [ -f "$WORKSPACE/.python-version" ]; then
    PY_WANT="$(cat "$WORKSPACE/.python-version" | tr -d "[:space:]")"
    if [ -n "$PY_WANT" ] && command -v uv &>/dev/null; then
        printf "\033[0;36m● Installing Python %s via uv...\033[0m\n" "$PY_WANT"
        uv python install "$PY_WANT" 2>/dev/null && \
            printf "\033[0;36m● Python %s ready\033[0m\n" "$PY_WANT" || true
    fi
fi

# If .venv exists but its python symlink is broken, auto-install the needed version
if [ -L "$WORKSPACE/.venv/bin/python" ] && [ ! -e "$WORKSPACE/.venv/bin/python" ]; then
    VENV_TARGET="$(readlink "$WORKSPACE/.venv/bin/python")"
    # Extract version from symlink (e.g. /usr/bin/python3.12 → 3.12, .pyenv/versions/3.10.4/... → 3.10)
    PY_VER="$(echo "$VENV_TARGET" | grep -oE '[0-9]+\.[0-9]+' | head -1)"
    if [ -n "$PY_VER" ] && command -v uv &>/dev/null; then
        printf "\033[0;36m● Installing Python %s via uv (.venv needs it)...\033[0m\n" "$PY_VER"
        if uv python install "$PY_VER" 2>/dev/null; then
            printf "\033[0;36m● Python %s ready\033[0m\n" "$PY_VER"
        else
            printf "\033[0;33m⚠ .venv needs Python %s but uv could not install it\033[0m\n" "$PY_VER"
        fi
    else
        printf "\033[0;33m⚠ .venv/bin/python → %s (not found in container)\033[0m\n" "$VENV_TARGET"
    fi
fi

# Warn if node_modules contains native addons built for a different platform
if [ -d "$WORKSPACE/node_modules" ]; then
    # Check for .node files — if any exist, verify they are Linux ELF binaries
    BAD_NATIVE="$(find "$WORKSPACE/node_modules" -name "*.node" -type f 2>/dev/null | head -1)"
    if [ -n "$BAD_NATIVE" ] && ! file "$BAD_NATIVE" 2>/dev/null | grep -q "ELF"; then
        printf "\033[0;33m⚠ node_modules/ contains native addons built for a different platform\033[0m\n"
        printf "\033[0;33m  Fix: npm rebuild\033[0m\n"
    fi
fi

sandy_log "Configuring git auth"
# Authenticate gh CLI with all available accounts (works in both token and agent modes)
if [ -n "${GH_ACCOUNTS:-}" ] && command -v gh &>/dev/null; then
    IFS=',' read -ra _gh_pairs <<< "$GH_ACCOUNTS"
    for _pair in "${_gh_pairs[@]}"; do
        _user="${_pair%%:*}"
        _tok="${_pair#*:}"
        echo "$_tok" | gh auth login --with-token 2>/dev/null || true
    done
elif [ -n "${GIT_TOKEN:-}" ] && command -v gh &>/dev/null; then
    echo "${GIT_TOKEN}" | gh auth login --with-token 2>/dev/null || true
fi
# Configure git auth: in token mode, rewrite SSH URLs to HTTPS and use gh as
# credential helper (supports multi-account — gh returns the right token per repo).
if [ "${SANDY_SSH:-token}" = "token" ] && command -v gh &>/dev/null; then
    git config --global url."https://github.com/".insteadOf "git@github.com:"
    git config --global --add url."https://github.com/".insteadOf "ssh://git@github.com/"
    gh auth setup-git 2>/dev/null || true
fi

sandy_log "Refreshing plugin marketplaces"
# Refresh plugin marketplaces (once per day, or forced when channels need plugins).
# Plugin marketplaces and channels are Claude-specific.
if _sandy_has_claude; then
_marketplace_cache="$HOME/.claude/plugins/.marketplace_updated"
_now=$(date +%s)
_stale=true
if [ -f "$_marketplace_cache" ]; then
    _cached_time=$(cat "$_marketplace_cache" 2>/dev/null || echo 0)
    if (( _now - _cached_time < 86400 )); then _stale=false; fi
fi
# Force refresh when channels are configured — plugins may need installing
[ -n "${SANDY_CHANNELS:-}" ] && _stale=true
if [ "$_stale" = true ]; then
    claude plugin marketplace update >/dev/null 2>&1 || true
    mkdir -p "$(dirname "$_marketplace_cache")"
    echo "$_now" > "$_marketplace_cache"
fi

# Auto-install and enable channel plugins referenced in SANDY_CHANNELS.
# Installed-but-disabled is a real state (user may have toggled off); we always
# ensure the plugin is enabled when the channel is configured.
if [ -n "${SANDY_CHANNELS:-}" ]; then
    for _chan in telegram discord; do
        if [[ "$SANDY_CHANNELS" == *"$_chan"* ]]; then
            # Install if not present (grep -qi handles multiple output formats)
            if ! claude plugin list 2>/dev/null | grep -qi "${_chan}"; then
                printf "\033[0;36m● Installing %s channel plugin...\033[0m\n" "$_chan"
                if ! claude plugin install "${_chan}@claude-plugins-official" 2>&1; then
                    printf "\033[0;31m✗ Failed to install %s channel plugin\033[0m\n" "$_chan" >&2
                    continue
                fi
            fi
            # Always ensure enabled (idempotent; silent if already enabled).
            # The enable command takes just the plugin name, not plugin@marketplace.
            claude plugin enable "$_chan" >/dev/null 2>&1 || \
                claude plugin enable "${_chan}@claude-plugins-official" >/dev/null 2>&1 || true
        fi
    done
fi

# Seed channel config from env vars (token + allowlist per channel)
_seed_channel() {
    local chan="$1" token_var="$2" senders_var="$3"
    local token="${!token_var:-}"
    local senders="${!senders_var:-}"
    [ -z "$token" ] && return
    mkdir -p "$HOME/.claude/channels/$chan"
    echo "${token_var}=$token" > "$HOME/.claude/channels/$chan/.env"
    chmod 600 "$HOME/.claude/channels/$chan/.env"
    [ -f "$HOME/.claude/channels/$chan/access.json" ] && return
    if [ -n "$senders" ]; then
        ALLOW_JSON=$(echo "$senders" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | awk 'NR>1{printf ","}{printf "\"%s\"",$0}')
        cat > "$HOME/.claude/channels/$chan/access.json" <<CHACCESS
{
  "dmPolicy": "allowlist",
  "allowFrom": [$ALLOW_JSON],
  "groups": {},
  "pending": {}
}
CHACCESS
    else
        cat > "$HOME/.claude/channels/$chan/access.json" <<'CHACCESS'
{
  "dmPolicy": "pairing",
  "allowFrom": [],
  "groups": {},
  "pending": {}
}
CHACCESS
    fi
}
_seed_channel telegram TELEGRAM_BOT_TOKEN TELEGRAM_ALLOWED_SENDERS
_seed_channel discord DISCORD_BOT_TOKEN DISCORD_ALLOWED_SENDERS
fi  # end Claude-only plugin/channel block

# --- Agent command builders (used by single-agent and dual-pane launch modes) ---
build_claude_cmd() {
    local cmd="claude --model ${SANDY_MODEL:-claude-opus-4-6} --teammate-mode tmux"
    if [ "${SANDY_SKIP_PERMISSIONS:-true}" = "true" ]; then
        cmd+=" --dangerously-skip-permissions"
    fi
    if [ -n "${SANDY_CHANNELS:-}" ] && [ "${SANDY_AGENT:-claude}" = "claude" ]; then
        # Native channels plugin path — only for pure-claude sessions.
        # For 'both', channels are delivered via the host-side tmux-inject relay.
        cmd+=" --channels $SANDY_CHANNELS"
    fi
    local auto_continue=true
    if [ "${SANDY_NEW_SESSION:-false}" = "true" ]; then
        auto_continue=false
    fi
    for arg in "$@"; do
        case "$arg" in
            -p|--resume|--continue) auto_continue=false ;;
        esac
    done
    local cmd_base="$cmd"
    if [ "$auto_continue" = "true" ]; then
        local session_dir="$HOME/.claude/projects/$(echo "$WORKSPACE" | tr '/' '-')/"
        if ls "$session_dir"*.jsonl &>/dev/null; then
            cmd+=" --continue"
        fi
    fi
    for arg in "$@"; do
        cmd+=" $(printf "%q" "$arg")"
        cmd_base+=" $(printf "%q" "$arg")"
    done
    if [ "$cmd" != "$cmd_base" ]; then
        cmd="$cmd || $cmd_base"
    fi
    if [ "${SANDY_VERBOSE:-0}" -ge 1 ]; then
        cmd="$cmd; _exit=\$?; echo ''; echo \"[sandy] Claude Code exited (code: \$_exit)\"; read -p 'Press Enter to exit...'"
    fi
    printf '%s' "$cmd"
}

build_gemini_cmd() {
    # Gemini CLI has its own per-tool sandbox; disable it since sandy provides
    # whole-session isolation via Docker. GEMINI_SANDBOX=false is the documented
    # way to disable Gemini's built-in sandbox (`--sandbox=none` is NOT valid).
    export GEMINI_SANDBOX=false
    local cmd="gemini"
    if [ "${SANDY_SKIP_PERMISSIONS:-true}" = "true" ]; then
        cmd+=" --yolo"
    fi
    if [ -n "${GEMINI_MODEL:-}" ]; then
        cmd+=" --model $(printf "%q" "$GEMINI_MODEL")"
    fi
    # Translate Claude-style flags to Gemini equivalents.
    # -p / --print "prompt" → --prompt "prompt"  (Gemini has no -p shorthand)
    # --continue / -c       → drop (Gemini has no headless resume flag)
    for arg in "$@"; do
        case "$arg" in
            -p|--print)    cmd+=" --prompt" ;;
            --continue|-c) : ;;
            *)             cmd+=" $(printf "%q" "$arg")" ;;
        esac
    done
    if [ "${SANDY_VERBOSE:-0}" -ge 1 ]; then
        cmd="$cmd; _exit=\$?; echo ''; echo \"[sandy] Gemini CLI exited (code: \$_exit)\"; read -p 'Press Enter to exit...'"
    fi
    printf '%s' "$cmd"
}

# Detect headless / one-shot mode — bypass tmux so output reaches the parent shell.
# Triggered by -p / --print / --prompt in the forwarded args.
_sandy_is_headless=false
for _arg in "$@"; do
    case "$_arg" in
        -p|--print|--prompt) _sandy_is_headless=true; break ;;
    esac
done

if [ "${SANDY_AGENT:-claude}" = "claude" ]; then
sandy_log "Launching Claude Code"
if [ "${SANDY_REMOTE_CONTROL:-false}" = "true" ]; then
    # Remote-control server mode — no tmux wrapper, no auto-resume
    CLAUDE_CMD="claude remote-control --name \"sandy: ${SANDY_PROJECT_NAME:-$(basename "$WORKSPACE")}\""
    for arg in "$@"; do
        CLAUDE_CMD+=" $(printf "%q" "$arg")"
    done
    if [ "${SANDY_VERBOSE:-0}" -ge 1 ]; then
        CLAUDE_CMD="$CLAUDE_CMD; _exit=\$?; echo ''; echo \"[sandy] Claude Code exited (code: \$_exit)\"; read -p 'Press Enter to exit...'"
    fi
    cd "$WORKSPACE"
    exec bash -c "$CLAUDE_CMD 2>&1"
elif [ "$_sandy_is_headless" = "true" ]; then
    # Headless one-shot — no tmux wrapper so output streams to parent stdout
    CLAUDE_CMD="$(build_claude_cmd "$@")"
    cd "$WORKSPACE"
    exec bash -c "$CLAUDE_CMD"
else
    CLAUDE_CMD="$(build_claude_cmd "$@")"
    cd "$WORKSPACE"
    tmux new-session -s sandy -n "sandy: ${SANDY_PROJECT_NAME:-$(basename "$WORKSPACE")}" -- bash -c "$CLAUDE_CMD 2>&1"
fi
elif [ "${SANDY_AGENT:-claude}" = "gemini" ]; then
    sandy_log "Launching Gemini CLI"
    GEMINI_CMD="$(build_gemini_cmd "$@")"
    cd "$WORKSPACE"
    if [ "$_sandy_is_headless" = "true" ]; then
        exec bash -c "$GEMINI_CMD"
    else
        tmux new-session -s sandy -n "sandy: ${SANDY_PROJECT_NAME:-$(basename "$WORKSPACE")}" -- bash -c "$GEMINI_CMD 2>&1"
    fi
elif [ "${SANDY_AGENT:-claude}" = "both" ]; then
    if [ "$_sandy_is_headless" = "true" ]; then
        # Headless mode with dual-agent doesn't make sense — route to Claude only.
        sandy_log "Headless mode with SANDY_AGENT=both: routing to Claude only"
        CLAUDE_CMD="$(build_claude_cmd "$@")"
        cd "$WORKSPACE"
        exec bash -c "$CLAUDE_CMD"
    fi
    sandy_log "Launching Claude Code + Gemini CLI (dual-pane)"
    CLAUDE_CMD="$(build_claude_cmd "$@")"
    GEMINI_CMD="$(build_gemini_cmd "$@")"
    cd "$WORKSPACE"
    tmux new-session -d -s sandy -n "sandy: ${SANDY_PROJECT_NAME:-$(basename "$WORKSPACE")}" -- bash -c "$CLAUDE_CMD 2>&1"
    tmux split-window -h -t sandy -- bash -c "$GEMINI_CMD 2>&1"
    tmux select-pane -t sandy.0
    tmux attach -t sandy
fi
USERSETUP
}

generate_tmux_conf() {
    cat > "$SANDY_HOME/tmux.conf.new" <<'TMUXCONF'
set -g history-limit 10000
set -g mouse on
set -g default-terminal "tmux-256color"
set -as terminal-features ",tmux-256color:RGB"
set -as terminal-overrides ",*:U8=1"
set -sg escape-time 0

# Pane borders — clean single-line, short labels
set -g pane-border-lines single
set -g pane-border-style "fg=colour240"
set -g pane-active-border-style "fg=colour51"
set -g pane-border-status top
set -g pane-border-format " #[fg=colour51]#{window_name}#[default] "

# Status bar
set -g status-position bottom
set -g status-style "bg=colour235,fg=colour248"
set -g status-left "#[fg=colour51,bold] sandy "
set -g status-left-length 10
set -g status-right "#[fg=colour248] %H:%M "
set -g status-right-length 10

# Allow OSC escape sequences (notifications, hyperlinks) to pass through
# to the outer terminal (cmux, iTerm2, etc.)
set -g allow-passthrough on

# Copy mouse selections to system clipboard via OSC 52
set -g set-clipboard on

# Better redraw behavior
set -g focus-events on
setw -g aggressive-resize on
TMUXCONF
}

generate_channel_relay() {
    cat > "$SANDY_HOME/channel-relay.sh.new" <<'RELAY'
#!/usr/bin/env bash
# sandy channel-relay — host-side Telegram → tmux injection bridge.
# Long-polls the Telegram Bot API and injects messages into the container's
# tmux session via `docker exec ... tmux send-keys`. Stateless, agent-agnostic.
#
# Required env: TELEGRAM_BOT_TOKEN, SANDY_CONTAINER_NAME
# Optional:     TELEGRAM_ALLOWED_SENDERS (csv of user IDs), SANDY_CHANNEL_TARGET_PANE (default 0)
set -u
: "${TELEGRAM_BOT_TOKEN:?}"
: "${SANDY_CONTAINER_NAME:?}"
TARGET_PANE="${SANDY_CHANNEL_TARGET_PANE:-0}"
ALLOWED="${TELEGRAM_ALLOWED_SENDERS:-}"
API="https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}"
OFFSET=0

_is_allowed() {
    local uid="$1"
    [ -z "$ALLOWED" ] && return 0
    case ",$ALLOWED," in *,"$uid",*) return 0 ;; esac
    return 1
}

_inject() {
    local text="$1"
    # Wait for container tmux session to exist (up to 30s)
    local tries=0
    while [ $tries -lt 60 ]; do
        if docker exec "$SANDY_CONTAINER_NAME" tmux has-session -t sandy 2>/dev/null; then
            break
        fi
        sleep 0.5
        tries=$((tries+1))
    done
    docker exec "$SANDY_CONTAINER_NAME" tmux send-keys -t "sandy.${TARGET_PANE}" "$text" Enter 2>/dev/null || true
}

# Drain stale updates once at startup
_init="$(curl -sS --max-time 5 "${API}/getUpdates?timeout=0&offset=-1" 2>/dev/null || true)"
if [ -n "$_init" ]; then
    OFFSET="$(echo "$_init" | python3 -c 'import json,sys
try:
    d=json.load(sys.stdin)
    r=d.get("result",[])
    print(r[-1]["update_id"]+1 if r else 0)
except Exception:
    print(0)' 2>/dev/null || echo 0)"
fi

while :; do
    resp="$(curl -sS --max-time 60 "${API}/getUpdates?timeout=50&offset=${OFFSET}" 2>/dev/null || true)"
    [ -z "$resp" ] && { sleep 2; continue; }
    # Parse updates; emit: update_id\tuser_id\ttext
    parsed="$(echo "$resp" | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(0)
if not d.get("ok"): sys.exit(0)
for u in d.get("result", []):
    uid = u.get("update_id", 0)
    m = u.get("message") or u.get("edited_message") or {}
    text = m.get("text") or m.get("caption") or ""
    sender = (m.get("from") or {}).get("id", "")
    if not text:
        print(f"{uid}\t\t")
        continue
    # strip control chars; flatten newlines into spaces
    text = text.replace("\r"," ").replace("\n"," ")
    print(f"{uid}\t{sender}\t{text}")
' 2>/dev/null || true)"
    [ -z "$parsed" ] && continue
    while IFS=$'\t' read -r uid sender text; do
        [ -z "$uid" ] && continue
        OFFSET=$((uid+1))
        [ -z "$text" ] && continue
        if _is_allowed "$sender"; then
            _inject "$text"
        fi
    done <<< "$parsed"
done
RELAY
    chmod +x "$SANDY_HOME/channel-relay.sh.new"
}

generate_skill_pack_dockerfiles() {
    local packs="$1"
    local base_outfile="$SANDY_HOME/Dockerfile.skills-base.new"
    local outfile="$SANDY_HOME/Dockerfile.skills.new"
    local needs_base=false

    local pack
    IFS=',' read -ra _pack_list <<< "$packs"

    # --- Generate base image (heavy deps: Playwright, Chromium, system libs) ---
    cat > "$base_outfile" <<'SKILLS_BASE_HEADER'
FROM sandy-claude-code
SKILLS_BASE_HEADER

    for pack in "${_pack_list[@]}"; do
        pack="$(echo "$pack" | tr -d '[:space:]')"
        case "$pack" in
            gstack)
                needs_base=true
                cat >> "$base_outfile" <<'GSTACK_BASE_BLOCK'

# --- gstack base: Playwright + Chromium (rarely changes) ---
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/skills/gstack/.browsers

# Bootstrap gstack just enough to install Playwright
RUN mkdir -p /opt/skills/gstack \
 && cd /opt/skills/gstack \
 && npm init -y >/dev/null 2>&1 \
 && npm install playwright@latest --save >/dev/null 2>&1 \
 && npx playwright install-deps chromium \
 && npx playwright install chromium \
 && rm -rf node_modules package.json package-lock.json
GSTACK_BASE_BLOCK
                ;;
        esac
    done
    echo "" >> "$base_outfile"

    if [ "$needs_base" != true ]; then
        rm -f "$base_outfile"
    fi

    # --- Generate code image (gstack source, bun build — changes frequently) ---
    local skills_base_name
    skills_base_name="sandy-skills-base-$(echo "$packs" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sort | tr '\n' '-' | sed 's/-$//' | tr '[:upper:]' '[:lower:]')"

    if [ "$needs_base" = true ]; then
        cat > "$outfile" <<SKILLS_HEADER
FROM ${skills_base_name}
SKILLS_HEADER
    else
        cat > "$outfile" <<'SKILLS_HEADER'
FROM sandy-claude-code
SKILLS_HEADER
    fi

    for pack in "${_pack_list[@]}"; do
        pack="$(echo "$pack" | tr -d '[:space:]')"
        local version repo
        version="$(skill_pack_lookup "$pack" version)" || true
        repo="$(skill_pack_lookup "$pack" repo)" || true
        if [ -z "$version" ] || [ -z "$repo" ]; then
            error "Unknown skill pack: $pack"
            exit 1
        fi
        case "$pack" in
            gstack)
                cat >> "$outfile" <<GSTACK_BLOCK

# --- gstack skill pack ($version) ---
# Download gstack at pinned version
RUN mkdir -p /opt/skills/gstack \\
 && curl -fsSL "${repo}/archive/${version}.tar.gz" \\
    | tar -xz --strip-components=1 -C /opt/skills/gstack

# Install dependencies and build (browse binary + skill docs)
RUN cd /opt/skills/gstack \\
 && (bun install --frozen-lockfile 2>/dev/null || bun install) \\
 && bun run build \\
 && echo "${version}" > browse/dist/.version \\
 && rm -rf node_modules/.cache

# Make all bin/ scripts executable
RUN chmod +x /opt/skills/gstack/bin/*
GSTACK_BLOCK
                ;;
            *)
                error "No build recipe for skill pack: $pack"
                exit 1
                ;;
        esac
    done

    # No USER directive — entrypoint runs as root and drops privileges via gosu
    echo "" >> "$outfile"
}

ensure_build_files() {
    mkdir -p "$SANDY_HOME"
    generate_dockerfile_base
    generate_entrypoint
    generate_user_setup
    generate_tmux_conf
    generate_channel_relay

    # Only update on-disk files if content has changed
    local changed=false
    for f in Dockerfile.base entrypoint.sh user-setup.sh tmux.conf channel-relay.sh; do
        if [ ! -f "$SANDY_HOME/$f" ] || ! diff -q "$SANDY_HOME/$f.new" "$SANDY_HOME/$f" &>/dev/null; then
            mv "$SANDY_HOME/$f.new" "$SANDY_HOME/$f"
            changed=true
        else
            rm "$SANDY_HOME/$f.new"
        fi
    done

    if [ "$changed" = true ]; then
        info "Build files updated."
    fi
}

# Generate the agent-specific Dockerfile after SANDY_AGENT is known.
ensure_agent_dockerfile() {
    local f
    case "$SANDY_AGENT" in
        gemini) generate_dockerfile_gemini; f="Dockerfile.gemini" ;;
        both)   generate_dockerfile_both;   f="Dockerfile.both" ;;
        *)      generate_dockerfile;        f="Dockerfile" ;;
    esac
    if [ ! -f "$SANDY_HOME/$f" ] || ! diff -q "$SANDY_HOME/$f.new" "$SANDY_HOME/$f" &>/dev/null; then
        mv "$SANDY_HOME/$f.new" "$SANDY_HOME/$f"
    else
        rm "$SANDY_HOME/$f.new"
    fi
}

# --- Initialize ---
ensure_build_files

# --- Per-project sandbox directory ---
WORK_DIR="$(pwd)"

# Safe key-value config parser (no arbitrary code execution)
_load_sandy_config() {
    local file="$1"
    [ -f "$file" ] || return 0
    while IFS='=' read -r key value; do
        value="${value#\"}" ; value="${value%\"}"
        value="${value#\'}" ; value="${value%\'}"
        case "$key" in
            SANDY_SSH|SANDY_MODEL|SANDY_SKILL_PACKS|SANDY_SKIP_PERMISSIONS|\
            SANDY_ALLOW_NO_ISOLATION|SANDY_ALLOW_LAN_HOSTS|\
            SANDY_CPUS|SANDY_MEM|SANDY_GPU|SANDY_CHANNELS|SANDY_VERBOSE|\
            SANDY_AGENT|\
            CLAUDE_CODE_OAUTH_TOKEN|\
            TELEGRAM_BOT_TOKEN|TELEGRAM_ALLOWED_SENDERS|\
            DISCORD_BOT_TOKEN|DISCORD_ALLOWED_SENDERS|\
            ANTHROPIC_API_KEY|CLAUDE_CODE_MAX_OUTPUT_TOKENS|\
            CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS|\
            GEMINI_API_KEY|GEMINI_MODEL|SANDY_GEMINI_EXTENSIONS|SANDY_GEMINI_AUTH|\
            GOOGLE_CLOUD_PROJECT|GOOGLE_CLOUD_LOCATION|GOOGLE_GENAI_USE_VERTEXAI|GOOGLE_API_KEY|\
            SANDY_CHANNEL_TARGET_PANE)
                export "$key=$value" ;;
        esac
    done < <(grep -E '^[A-Z_]+=.+' "$file" 2>/dev/null)
}

# Load config/secrets: user-level first, then per-project (project overrides user)
_load_sandy_config "$SANDY_HOME/config"
_load_sandy_config "$SANDY_HOME/.secrets"
_load_sandy_config "$WORK_DIR/.sandy/config"
_load_sandy_config "$WORK_DIR/.sandy/.secrets"

# --- Resolve agent ---
SANDY_AGENT="${SANDY_AGENT:-claude}"
case "$SANDY_AGENT" in
    claude) IMAGE_NAME="sandy-claude-code" ;;
    gemini) IMAGE_NAME="sandy-gemini-cli" ;;
    both)   IMAGE_NAME="sandy-both" ;;
    *) echo "[sandy] ERROR: Invalid SANDY_AGENT '$SANDY_AGENT' (must be 'claude', 'gemini', or 'both')" >&2; exit 1 ;;
esac
if [ "$SANDY_AGENT" = "gemini" ]; then
    if [ -n "${SANDY_SKILL_PACKS:-}" ]; then
        echo "[sandy] ERROR: SANDY_SKILL_PACKS is not supported with SANDY_AGENT=gemini" >&2
        exit 1
    fi
fi
# Channels on non-Claude agents use the host-side tmux-inject relay. Only
# Telegram is supported in v1.5; Discord still requires the Claude plugin path.
if [ -n "${SANDY_CHANNELS:-}" ] && [ "$SANDY_AGENT" != "claude" ]; then
    case ",$SANDY_CHANNELS," in
        *,discord,*)
            echo "[sandy] ERROR: SANDY_CHANNELS=discord is only supported with SANDY_AGENT=claude" >&2
            exit 1 ;;
    esac
fi
if [ "$SANDY_REMOTE_CONTROL" = true ] && [ "$SANDY_AGENT" != "claude" ]; then
    echo "[sandy] ERROR: --remote is only supported with SANDY_AGENT=claude (Gemini CLI has no remote-control mode)" >&2
    exit 1
fi
export SANDY_AGENT

ensure_agent_dockerfile
case "$SANDY_AGENT" in
    gemini)
        DOCKERFILE_PATH="$SANDY_HOME/Dockerfile.gemini"
        BUILD_HASH_FILE_NAME=".build_hash_gemini" ;;
    both)
        DOCKERFILE_PATH="$SANDY_HOME/Dockerfile.both"
        BUILD_HASH_FILE_NAME=".build_hash_both" ;;
    *)
        DOCKERFILE_PATH="$SANDY_HOME/Dockerfile"
        BUILD_HASH_FILE_NAME=".build_hash" ;;
esac

SHORT_HASH="$(printf '%s' "$WORK_DIR" | sha256)"
SHORT_HASH="${SHORT_HASH%% *}"
SHORT_HASH="${SHORT_HASH:0:8}"
DIR_BASE="$(basename "$WORK_DIR" | tr -cd 'a-zA-Z0-9._-')"
DIR_BASE="${DIR_BASE:-project}"
SANDBOX_NAME="${DIR_BASE}-${SHORT_HASH}"
SANDBOX_DIR="$SANDY_HOME/sandboxes/${SANDBOX_NAME}"

# Compute container workspace path
if [[ "$WORK_DIR" == "$HOME"/* ]]; then
    SANDY_WORKSPACE="/home/claude/${WORK_DIR#$HOME/}"
else
    SANDY_WORKSPACE="$WORK_DIR"
fi

# Apply --rebuild flag (must come after ensure_build_files creates SANDY_HOME)
if [ "$SANDY_REBUILD" = true ]; then
    rm -f "$SANDY_HOME/.base_build_hash" "$SANDY_HOME/.build_hash" "$SANDY_HOME/.build_hash_gemini" "$SANDY_HOME/.build_hash_both" "$SANDY_HOME/.skills_build_hash"
    info "Build cache cleared. Images will be rebuilt."
fi

# --- Build images (two-phase: base + final) ---

# Phase 1: Base image (language runtimes — rebuilds rarely)
BASE_HASH="$(cat "$SANDY_HOME/Dockerfile.base" | sha256 | cut -d' ' -f1)"
BASE_HASH_FILE="$SANDY_HOME/.base_build_hash"
BASE_REBUILT=false
if [ ! -f "$BASE_HASH_FILE" ] || [ "$(cat "$BASE_HASH_FILE")" != "$BASE_HASH" ] || ! docker image inspect "$BASE_IMAGE_NAME" &>/dev/null; then
    info "Building base image (language runtimes)..."
    docker build --no-cache -t "$BASE_IMAGE_NAME" -f "$SANDY_HOME/Dockerfile.base" "$SANDY_HOME"
    echo "$BASE_HASH" > "$BASE_HASH_FILE"
    BASE_REBUILT=true
else
    info "Base image up to date."
fi

# Phase 2: Final image (agent — rebuilds on agent updates or base change)
BUILD_HASH="$(cat "$DOCKERFILE_PATH" "$SANDY_HOME/entrypoint.sh" "$SANDY_HOME/user-setup.sh" "$SANDY_HOME/tmux.conf" | sha256 | cut -d' ' -f1)"
HASH_FILE="$SANDY_HOME/$BUILD_HASH_FILE_NAME"
NEEDS_BUILD=false
if [ ! -f "$HASH_FILE" ] || [ "$(cat "$HASH_FILE")" != "$BUILD_HASH" ] || [ "$BASE_REBUILT" = true ] || ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    NEEDS_BUILD=true
fi

# Check for newer agent version (skip if already rebuilding)
_check_claude_update() {
    local inst latest
    inst="$(docker run --rm --entrypoint cat "$IMAGE_NAME" /opt/claude-code/.version 2>/dev/null || true)"
    latest="$(curl -fsSL --max-time 5 https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/latest 2>/dev/null || true)"
    if [ -n "$latest" ] && [ -n "$inst" ] && [ "$latest" != "$inst" ]; then
        info "Claude Code update available: $inst → $latest"
        return 0
    fi
    return 1
}
_check_gemini_update() {
    local inst latest
    inst="$(docker run --rm --entrypoint cat "$IMAGE_NAME" /opt/gemini-cli/.version 2>/dev/null || true)"
    latest="$(curl -fsSL --max-time 5 'https://registry.npmjs.org/@google/gemini-cli/latest' 2>/dev/null \
        | grep -oE '"version"[[:space:]]*:[[:space:]]*"[^"]+"' | head -1 \
        | sed -E 's/.*"([^"]+)"$/\1/' || true)"
    if [ -n "$latest" ] && [ -n "$inst" ] && [ "$latest" != "$inst" ]; then
        info "Gemini CLI update available: $inst → $latest"
        return 0
    fi
    return 1
}
if [ "$NEEDS_BUILD" = false ]; then
    case "$SANDY_AGENT" in
        gemini) _check_gemini_update && NEEDS_BUILD=true ;;
        claude) _check_claude_update && NEEDS_BUILD=true ;;
        both)
            if _check_claude_update || _check_gemini_update; then
                NEEDS_BUILD=true
            fi ;;
    esac
fi

if [ "$NEEDS_BUILD" = true ]; then
    info "Building sandbox image..."
    docker build -q --no-cache -t "$IMAGE_NAME" -f "$DOCKERFILE_PATH" "$SANDY_HOME"
    echo "$BUILD_HASH" > "$HASH_FILE"
else
    info "Sandbox image up to date."
fi

SKILLS_REBUILT=false

if [ "$SANDY_BUILD_ONLY" = true ]; then
    info "Build complete. Exiting (--build-only)."
    exit 0
fi

# --- Ensure the per-instance isolated network exists ---
CONTAINER_SUBNET=""
ensure_network() {
    info "Creating isolated network..."
    docker network create \
        --driver bridge \
        --ipv6=false \
        -o com.docker.network.bridge.name="$BRIDGE_NAME" \
        "$NETWORK_NAME" >/dev/null
    # Query the dynamically-assigned subnet and bridge name
    CONTAINER_SUBNET="$(docker network inspect "$NETWORK_NAME" --format '{{(index .IPAM.Config 0).Subnet}}')"
    BRIDGE_NAME="$(docker network inspect "$NETWORK_NAME" --format '{{index .Options "com.docker.network.bridge.name"}}')"
}

ensure_network

# --- Phase 2.5: Skill pack image (after config so SANDY_SKILL_PACKS is available) ---
if [ -n "${SANDY_SKILL_PACKS:-}" ]; then
    # Resolve latest versions from GitHub (caches locally for offline fallback)
    skill_pack_resolve_versions "$SANDY_SKILL_PACKS"

    # (Re)generate skill pack Dockerfiles (base + code) with resolved versions
    generate_skill_pack_dockerfiles "$SANDY_SKILL_PACKS"

    _pack_suffix="$(echo "$SANDY_SKILL_PACKS" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sort | tr '\n' '-' | sed 's/-$//' | tr '[:upper:]' '[:lower:]')"

    # --- Phase 2.5a: Skills base image (Playwright, Chromium — rarely changes) ---
    if [ -f "$SANDY_HOME/Dockerfile.skills-base.new" ]; then
        SKILLS_BASE_IMAGE="sandy-skills-base-${_pack_suffix}"
        if [ ! -f "$SANDY_HOME/Dockerfile.skills-base" ] || ! diff -q "$SANDY_HOME/Dockerfile.skills-base.new" "$SANDY_HOME/Dockerfile.skills-base" &>/dev/null; then
            mv "$SANDY_HOME/Dockerfile.skills-base.new" "$SANDY_HOME/Dockerfile.skills-base"
        else
            rm -f "$SANDY_HOME/Dockerfile.skills-base.new"
        fi

        SKILLS_BASE_HASH="$(cat "$SANDY_HOME/Dockerfile.skills-base" | sha256 | cut -d' ' -f1)"
        SKILLS_BASE_HASH_FILE="$SANDY_HOME/.skills_base_build_hash"

        SKILLS_BASE_NEEDS_BUILD=false
        if [ ! -f "$SKILLS_BASE_HASH_FILE" ] \
                || [ "$(cat "$SKILLS_BASE_HASH_FILE")" != "$SKILLS_BASE_HASH" ] \
                || [ "$NEEDS_BUILD" = true ] \
                || ! docker image inspect "$SKILLS_BASE_IMAGE" &>/dev/null; then
            SKILLS_BASE_NEEDS_BUILD=true
        fi

        if [ "$SKILLS_BASE_NEEDS_BUILD" = true ]; then
            info "Building skill pack base image (Playwright + Chromium)..."
            docker build -t "$SKILLS_BASE_IMAGE" \
                -f "$SANDY_HOME/Dockerfile.skills-base" "$SANDY_HOME"
            echo "$SKILLS_BASE_HASH" > "$SKILLS_BASE_HASH_FILE"
        else
            info "Skill pack base image up to date."
        fi
    fi

    # --- Phase 2.5b: Skills code image (gstack source + build — changes frequently) ---
    SKILLS_IMAGE_NAME="sandy-skills-${_pack_suffix}"
    if [ ! -f "$SANDY_HOME/Dockerfile.skills" ] || ! diff -q "$SANDY_HOME/Dockerfile.skills.new" "$SANDY_HOME/Dockerfile.skills" &>/dev/null; then
        mv "$SANDY_HOME/Dockerfile.skills.new" "$SANDY_HOME/Dockerfile.skills"
    else
        rm -f "$SANDY_HOME/Dockerfile.skills.new"
    fi

    SKILLS_BUILD_HASH="$(cat "$SANDY_HOME/Dockerfile.skills" | sha256 | cut -d' ' -f1)"
    SKILLS_HASH_FILE="$SANDY_HOME/.skills_build_hash"

    SKILLS_NEEDS_BUILD=false
    if [ ! -f "$SKILLS_HASH_FILE" ] \
            || [ "$(cat "$SKILLS_HASH_FILE")" != "$SKILLS_BUILD_HASH" ] \
            || [ "${SKILLS_BASE_NEEDS_BUILD:-false}" = true ] \
            || [ "$NEEDS_BUILD" = true ] \
            || ! docker image inspect "$SKILLS_IMAGE_NAME" &>/dev/null; then
        SKILLS_NEEDS_BUILD=true
    fi

    if [ "$SKILLS_NEEDS_BUILD" = true ]; then
        info "Building skill pack image (${SANDY_SKILL_PACKS})..."
        docker build --no-cache -t "$SKILLS_IMAGE_NAME" \
            -f "$SANDY_HOME/Dockerfile.skills" "$SANDY_HOME"
        echo "$SKILLS_BUILD_HASH" > "$SKILLS_HASH_FILE"
        SKILLS_REBUILT=true
    else
        info "Skill pack image up to date."
    fi
    IMAGE_NAME="$SKILLS_IMAGE_NAME"
elif [ -f "$SANDY_HOME/Dockerfile.skills" ]; then
    # Clean up stale skill pack Dockerfiles if packs were disabled
    rm -f "$SANDY_HOME/Dockerfile.skills" "$SANDY_HOME/Dockerfile.skills-base"
fi

# --- Detect available resources (after config sourcing so overrides work) ---
AVAILABLE_CPUS="$(docker info --format '{{.NCPU}}' 2>/dev/null || echo 2)"
AVAILABLE_MEM_GB="$(docker info --format '{{.MemTotal}}' 2>/dev/null | awk '{printf "%d", $1/1073741824}')"
# Validate: must be a positive integer, default to 4 on parse failure
if ! [[ "$AVAILABLE_MEM_GB" =~ ^[0-9]+$ ]] || [ "$AVAILABLE_MEM_GB" -eq 0 ]; then
    AVAILABLE_MEM_GB=4
fi
SANDY_CPUS="${SANDY_CPUS:-$AVAILABLE_CPUS}"
SANDY_MEM="${SANDY_MEM:-$(( AVAILABLE_MEM_GB > 2 ? AVAILABLE_MEM_GB - 1 : 2 ))g}"

# Preflight: SSH agent mode on macOS requires socat and python3 for the relay
if [ "${SANDY_SSH:-token}" = "agent" ] && [ "$(uname -s)" != "Linux" ]; then
    for _dep in socat python3; do
        if ! command -v "$_dep" &>/dev/null; then
            error "SANDY_SSH=agent requires $_dep on macOS."
            error "Install it: brew install $_dep"
            exit 1
        fi
    done
fi

SANDBOX_IS_NEW=false
if [ ! -d "$SANDBOX_DIR" ]; then
    info "Creating new sandbox: $SANDBOX_DIR"
    mkdir -p "$SANDBOX_DIR"
    SANDBOX_IS_NEW=true
fi

# Auto-migrate v1 layout → v1.5 layout: v1 used $SANDBOX_DIR itself as the
# Claude .claude/ root. v1.5 uses $SANDBOX_DIR/claude/ and $SANDBOX_DIR/gemini/
# as siblings so dual-agent mode can mount both. Idempotent: the sweep only
# moves entries that are still at the top level. The allowlist covers every
# known Claude-owned entry so partial migrations from earlier v1.5 builds get
# cleaned up on next launch.
_v1_claude_entries="settings.json projects plugins statsig channels hooks todos history.jsonl shell-snapshots backups cache commands file-history paste-cache plans sessions session-env tasks telemetry agents skills ide mcp-servers"
_v1_leftovers=""
for _e in $_v1_claude_entries; do
    [ -e "$SANDBOX_DIR/$_e" ] && _v1_leftovers="$_v1_leftovers $_e"
done
if [ -n "$_v1_leftovers" ]; then
    info "Migrating sandbox to v1.5 layout (claude/ subdir)...$_v1_leftovers"
    mkdir -p "$SANDBOX_DIR/claude"
    for _e in $_v1_leftovers; do
        if [ ! -e "$SANDBOX_DIR/claude/$_e" ]; then
            # Clean move — nothing in the way.
