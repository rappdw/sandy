#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# sandy — an isolated sibling for your coding agents
#
# Runs Claude Code, Gemini CLI, or Codex CLI (or any combo, side-by-side) in a Docker container with:
#   - Filesystem: read/write limited to current directory only
#   - Network: public internet only, NO LAN access
#   - Resources: capped CPU and memory
#   - Per-project sandbox: isolated ~/.claude per working directory
#
# Usage:
#   sandy                         Resume last session (or start new)
#   sandy --new                   Start a fresh session
#   sandy -p "prompt"             One-shot prompt
#   sandy --agent claude,gemini   Override agent selection for this run
# =============================================================================

SANDY_VERSION="0.11.3-dev"
SANDY_COMMIT=""  # baked in by install.sh; empty = detect from git at runtime

SANDY_HOME="${SANDY_HOME:-$HOME/.sandy}"
# Validate SANDY_HOME — reject shell metacharacters
if [[ "$SANDY_HOME" =~ [\;\$\`\&\|\<\>] ]]; then
    echo "[sandy] ERROR: Invalid SANDY_HOME: contains shell metacharacters" >&2
    exit 1
fi
BASE_IMAGE_NAME="sandy-base"
# IMAGE_NAME is set dynamically after config load, based on SANDY_AGENT
IMAGE_NAME=""
# Per-instance network names keyed on PID to avoid concurrent iptables races
BRIDGE_NAME="br-sdy-$$"
NETWORK_NAME="sandy_net_$$"

# --- Skill pack registry ---
# To add a new pack: add entries to both arrays at the same index.
# Repos must be GitHub repos (used for tarball download and release checks).
# Versions are resolved dynamically from GitHub releases — SKILL_PACK_VERSIONS
# is only the initial fallback if no cached or remote version is available.
SKILL_PACK_NAMES=(gstack)
SKILL_PACK_REPOS=("https://github.com/garrytan/gstack")
SKILL_PACK_VERSIONS=("main")
# Release tag prefix per pack (tags matching this prefix are checked for updates)
SKILL_PACK_TAG_PREFIXES=("")

skill_pack_lookup() {
    local pack="$1" field="$2"
    local i
    for i in "${!SKILL_PACK_NAMES[@]}"; do
        if [ "${SKILL_PACK_NAMES[$i]}" = "$pack" ]; then
            case "$field" in
                repo) echo "${SKILL_PACK_REPOS[$i]}" ;;
                version) echo "${SKILL_PACK_VERSIONS[$i]}" ;;
                tag_prefix) echo "${SKILL_PACK_TAG_PREFIXES[$i]}" ;;
            esac
            return 0
        fi
    done
    return 1
}

# Check GitHub for the latest release tag matching a prefix for a skill pack.
# Falls back to the latest commit SHA on the default branch if no releases exist.
# Returns the tag name, commit SHA, or empty string on failure.
skill_pack_latest_release() {
    local pack="$1"
    local repo tag_prefix owner_repo
    repo="$(skill_pack_lookup "$pack" repo)" || return 1
    tag_prefix="$(skill_pack_lookup "$pack" tag_prefix)" || return 1
    owner_repo="$(echo "$repo" | sed 's|https://github.com/||')"

    # Try releases first (if tag prefix is set)
    if [ -n "$tag_prefix" ]; then
        local release_tag
        release_tag="$(curl -fsSL --max-time 5 \
            "https://api.github.com/repos/${owner_repo}/releases" 2>/dev/null \
        | node -e "
            let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
                try {
                    const releases = JSON.parse(d);
                    const match = releases.find(r => !r.draft && !r.prerelease && r.tag_name.startsWith('${tag_prefix}'));
                    if (match) console.log(match.tag_name);
                } catch(e) {}
            })
        " 2>/dev/null || true)"
        if [ -n "$release_tag" ]; then
            echo "$release_tag"
            return 0
        fi
    fi

    # Fall back to latest commit SHA on default branch
    curl -fsSL --max-time 5 \
        "https://api.github.com/repos/${owner_repo}/commits?per_page=1" 2>/dev/null \
    | node -e "
        let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
            try {
                const commits = JSON.parse(d);
                if (commits[0]) console.log(commits[0].sha.slice(0,12));
            } catch(e) {}
        })
    " 2>/dev/null || true
}

# Resolve the effective version for a skill pack. Checks GitHub for the latest
# release, caches the result, falls back to cache then hardcoded default.
# Updates SKILL_PACK_VERSIONS in-place so downstream code sees the resolved version.
skill_pack_resolve_versions() {
    local packs="$1"
    mkdir -p "$SANDY_HOME"
    local pack
    IFS=',' read -ra _sp_resolve <<< "$packs"
    for pack in "${_sp_resolve[@]}"; do
        pack="$(echo "$pack" | tr -d '[:space:]')"
        local cache_file="$SANDY_HOME/.skill_version_${pack}"
        local cached="" latest="" resolved=""

        # Read cached version
        [ -f "$cache_file" ] && cached="$(cat "$cache_file")"

        # Check GitHub for latest release
        latest="$(skill_pack_latest_release "$pack")"

        if [ -n "$latest" ]; then
            resolved="$latest"
            if [ "$latest" != "$cached" ]; then
                [ -n "$cached" ] && info "Skill pack update: $pack $cached → $latest"
                echo "$latest" > "$cache_file"
            fi
        elif [ -n "$cached" ]; then
            resolved="$cached"
        else
            # Fall back to hardcoded default
            resolved="$(skill_pack_lookup "$pack" version)" || true
            [ -n "$resolved" ] && echo "$resolved" > "$cache_file"
        fi

        # Update the in-memory version array
        if [ -n "$resolved" ]; then
            local i
            for i in "${!SKILL_PACK_NAMES[@]}"; do
                if [ "${SKILL_PACK_NAMES[$i]}" = "$pack" ]; then
                    SKILL_PACK_VERSIONS[$i]="$resolved"
                fi
            done
        fi
    done
}

# --- Colors (disabled when not a terminal) ---
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' NC=''
fi

info()  { echo -e "${GREEN}[sandy]${NC} $*"; }
warn()  { echo -e "${YELLOW}[sandy]${NC} $*"; }
error() { echo -e "${RED}[sandy]${NC} $*" >&2; }
sha256() { shasum -a 256 2>/dev/null || sha256sum; }

# Numeric semver compare. _ver_lt A B → 0 if A < B (strips -dev/-rc suffix).
# Portable across macOS bash 3.2 and Linux without relying on `sort -V`.
_ver_lt() {
    local a="${1%%-*}" b="${2%%-*}"
    local IFS=.
    local -a A B
    # shellcheck disable=SC2206
    A=($a); B=($b)
    local i ai bi
    for i in 0 1 2; do
        ai="${A[i]:-0}"; bi="${B[i]:-0}"
        # Guard against non-numeric junk
        [[ "$ai" =~ ^[0-9]+$ ]] || ai=0
        [[ "$bi" =~ ^[0-9]+$ ]] || bi=0
        if [ "$ai" -lt "$bi" ]; then return 0; fi
        if [ "$ai" -gt "$bi" ]; then return 1; fi
    done
    return 1
}

# Sandboxes created before this version pre-date the workspace mount path
# change (c99eb97, v0.7.10) from /workspace → /home/claude/<rel>. Any cached
# absolute paths inside the sandbox (venv pyvenv.cfg, .pth files, editable
# installs, Python package caches) reference /workspace/... and break
# silently inside the new mount layout. Bump this when introducing further
# sandbox-incompatible changes.
SANDY_SANDBOX_MIN_COMPAT="0.7.10"

SANDY_REPO_URL="https://raw.githubusercontent.com/rappdw/sandy/main/sandy"
SANDY_API_URL="https://api.github.com/repos/rappdw/sandy/releases/latest"

# Self-update: download latest sandy from GitHub and replace the running script
sandy_self_update() {
    local script_path
    script_path="$(readlink -f "${BASH_SOURCE[0]}")"
    local tmp
    tmp="$(mktemp)"
    info "Downloading latest sandy..."
    if ! curl -fsSL "$SANDY_REPO_URL" -o "$tmp"; then
        error "Failed to download update."
        rm -f "$tmp"
        exit 1
    fi
    local new_ver
    new_ver="$(grep -m1 '^SANDY_VERSION=' "$tmp" | cut -d'"' -f2)"
    if [ -z "$new_ver" ]; then
        error "Downloaded file does not look like sandy."
        rm -f "$tmp"
        exit 1
    fi
    if [ "$new_ver" = "$SANDY_VERSION" ]; then
        info "Already on latest version ($SANDY_VERSION)."
        rm -f "$tmp"
        exit 0
    fi
    chmod +x "$tmp"
    mv "$tmp" "$script_path"
    info "Updated sandy: $SANDY_VERSION → $new_ver"
    # Clear update cache
    rm -f "$SANDY_HOME/.update_check"
}

# Check for newer version (cached, non-blocking)
sandy_check_update() {
    mkdir -p "$SANDY_HOME"
    local cache="$SANDY_HOME/.update_check"
    local now
    now=$(date +%s)
    if [ -f "$cache" ]; then
        local cached_time cached_ver
        read -r cached_time cached_ver < "$cache" 2>/dev/null || true
        if [ -n "$cached_time" ] && (( now - cached_time < 86400 )); then
            if [ -n "$cached_ver" ] && [ "$cached_ver" != "v$SANDY_VERSION" ]; then
                warn "Update available: $SANDY_VERSION → ${cached_ver#v}. Run 'sandy --upgrade' to update."
            fi
            return
        fi
    fi
    local latest
    latest="$(curl -fsSL --max-time 3 "$SANDY_API_URL" 2>/dev/null \
        | grep -o '"tag_name":"[^"]*"' | cut -d'"' -f4)" || true
    if [ -n "$latest" ]; then
        echo "$now $latest" > "$cache"
        if [ "$latest" != "v$SANDY_VERSION" ]; then
            warn "Update available: $SANDY_VERSION → ${latest#v}. Run 'sandy --upgrade' to update."
        fi
    fi
}

# Merge JSON keys into a file. Usage: json_merge <file> '{"key":"value"}'
json_merge() {
    command -v node &>/dev/null || return 0
    node -e '
        const fs=require("fs"), f=process.argv[1], m=JSON.parse(process.argv[2]);
        let s;
        try { s=JSON.parse(fs.readFileSync(f,"utf8")); }
        catch(e) { console.error("[sandy] WARN: could not parse "+f+", starting fresh"); s={}; }
        Object.assign(s,m);
        fs.writeFileSync(f, JSON.stringify(s,null,2)+"\n");
    ' "$1" "$2"
}

# --- Version ---
sandy_full_version() {
    local ver="$SANDY_VERSION"
    local hash="${SANDY_COMMIT}"
    if [ -z "$hash" ]; then
        # Try to detect from git if running from a repo checkout
        local script_dir
        script_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
        hash="$(git -C "$script_dir" rev-parse --short HEAD 2>/dev/null)" || true
    fi
    [ -n "$hash" ] && ver="$ver-$hash"
    echo "$ver"
}
if [[ "${1:-}" == "-v" || "${1:-}" == "--version" ]]; then
    echo "sandy $(sandy_full_version)"
    exit 0
fi

# --- Protected path lists (single source of truth) ---
# Files that host tools source or execute on cd/install/scan lookup belong
# here. Package manifests (package.json, pyproject.toml, Cargo.toml, Makefile)
# are intentionally NOT protected — the agent has legitimate reason to edit
# them. Called by the RUN_FLAGS construction loop (below) and by the test
# harness via `sandy --print-protected-paths`.
_sandy_protected_files() {
    cat <<'EOF'
.bashrc
.bash_profile
.zshrc
.zprofile
.profile
.gitconfig
.ripgreprc
.mcp.json
.envrc
.tool-versions
.mise.toml
.nvmrc
.node-version
.python-version
.ruby-version
.npmrc
.yarnrc
.yarnrc.yml
.pypirc
.netrc
.pre-commit-config.yaml
EOF
}
# Top-level .git files that can trigger host-side code execution if tampered.
# Separate list because gated on -f instead of -e.
_sandy_protected_git_files() {
    cat <<'EOF'
.git/config
.gitmodules
.git/HEAD
.git/packed-refs
EOF
}
# Protected directories. .github/workflows is included by default; opt out via
# SANDY_ALLOW_WORKFLOW_EDIT=1 in .sandy/config (passive tier).
_sandy_protected_dirs() {
    cat <<'EOF'
.git/hooks
.git/info
.vscode
.idea
.circleci
.devcontainer
EOF
    [ "${SANDY_ALLOW_WORKFLOW_EDIT:-0}" = "1" ] || echo ".github/workflows"
}

# Debug flag for test harness — print the three protected-path lists and exit.
# Format: one path per line, prefixed by "file:", "gitfile:", or "dir:".
# Reads SANDY_ALLOW_WORKFLOW_EDIT from the environment (not from .sandy/config).
if [[ "${1:-}" == "--print-protected-paths" ]]; then
    while IFS= read -r _p; do [ -n "$_p" ] && echo "file:$_p"; done < <(_sandy_protected_files)
    while IFS= read -r _p; do [ -n "$_p" ] && echo "gitfile:$_p"; done < <(_sandy_protected_git_files)
    while IFS= read -r _p; do [ -n "$_p" ] && echo "dir:$_p"; done < <(_sandy_protected_dirs)
    exit 0
fi

# --- Help ---
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    cat <<EOF
sandy $(sandy_full_version) — an isolated sibling for your coding agents

Run Claude Code, Gemini CLI, or Codex CLI (or any combo) in a Docker container
with filesystem isolation, network isolation, resource limits, and per-project
credential sandboxes.

Usage:
  sandy                          Resume last session (or start new)
  sandy --new                    Start a fresh session
  sandy -p "prompt"              One-shot prompt
  sandy --resume                 Open session picker
  sandy --remote                 Start in remote-control server mode
  sandy --agent claude,gemini    Launch specific agent(s) for this run
  sandy --help                   Show this help

Environment variables:
  SANDY_MODEL        Model to use (default: claude-opus-4-6)
  ANTHROPIC_API_KEY  API key (not needed with Claude Max / OAuth)
  SANDY_HOME         Sandy config directory (default: ~/.sandy)
  SANDY_SSH          Git SSH method: "token" (default) uses gh CLI token
                     with HTTPS; "agent" forwards host SSH agent via relay
  SANDY_SKIP_PERMISSIONS  Set to "false" to keep Claude Code's permission
                     system active (default: "true" — bypasses permissions)
  SANDY_ALLOW_LAN_HOSTS  Comma-separated IPs/CIDRs to allow through
                     LAN isolation (e.g. "192.168.1.50,10.0.0.0/24")
  SANDY_ALLOW_NO_ISOLATION  Set to "1" to allow launch when iptables
                     rules cannot be applied (Linux only)
  SANDY_CPUS         CPU limit for container (default: auto-detected)
  SANDY_MEM          Memory limit for container (default: auto-detected)
  SANDY_GPU          GPU passthrough: "all" for all GPUs, or device IDs
                     like "0" or "0,1" (requires NVIDIA Container Toolkit)
  SANDY_SKILL_PACKS  Comma-separated skill packs to install (e.g. "gstack")
  SANDY_AGENT        AI agent(s): "claude" (default), "gemini", "codex",
                     or comma-separated combo (e.g. "claude,gemini,codex").
                     Alias: "all" = "claude,gemini,codex".
  GEMINI_API_KEY     Google API key for Gemini CLI (SANDY_AGENT=gemini only)
  GEMINI_MODEL       Gemini model override (SANDY_AGENT=gemini only)
  OPENAI_API_KEY     OpenAI API key for Codex CLI
  CODEX_MODEL        Codex model override (SANDY_AGENT=codex only)
  CLAUDE_CODE_MAX_OUTPUT_TOKENS  Max output tokens per response (default: 128000)

Per-project config:
  .sandy/config      Parsed on launch (allowlisted KEY=VALUE lines only)

Flags:
  --help             Show this help
  --version          Show version
  --rebuild          Force rebuild of the sandbox Docker image
  --build-only       Build images and exit (for CI)
  --new              Start a fresh session (default: resume last)
  --resume           Open session picker
  --remote           Start in remote-control server mode
  --upgrade          Update sandy to the latest version
  --agent <list>     Agent(s) to launch (overrides SANDY_AGENT and
                     .sandy/config). Comma-separated for multi-agent,
                     e.g. --agent claude,gemini or --agent=claude,codex
  -v                 Verbose: show startup sections, pause on exit
  -vv                Debug: add bash trace to user-setup.sh
  -vvv               Full trace: also trace entrypoint.sh and show docker flags

All other arguments are forwarded to the agent (claude or gemini).
EOF
    exit 0
fi

# --- Parse sandy flags (order-independent, consumed before forwarding to claude) ---
SANDY_REBUILD=false
SANDY_BUILD_ONLY=false
SANDY_NEW_SESSION=false
SANDY_REMOTE_CONTROL=false
SANDY_VERBOSE="${SANDY_VERBOSE:-0}"
# --agent's value is stashed here rather than assigned directly to SANDY_AGENT,
# because SANDY_AGENT is also set by _load_sandy_config() further down and we
# want the CLI flag to win over per-project and user config. The override is
# applied just before agent resolution.
SANDY_AGENT_OVERRIDE=""
REMAINING_ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --rebuild)    SANDY_REBUILD=true ;;
        --build-only) SANDY_BUILD_ONLY=true ;;
        --new)        SANDY_NEW_SESSION=true ;;
        --remote)     SANDY_REMOTE_CONTROL=true ;;
        --upgrade)    sandy_self_update; exit 0 ;;
        --agent)
            if [ $# -lt 2 ] || [[ "$2" == -* ]]; then
                echo "[sandy] ERROR: --agent requires a value (e.g. --agent claude,gemini)" >&2
                exit 1
            fi
            shift
            SANDY_AGENT_OVERRIDE="$1"
            ;;
        --agent=*)    SANDY_AGENT_OVERRIDE="${1#--agent=}" ;;
        -vvv)         SANDY_VERBOSE=3 ;;
        -vv)          SANDY_VERBOSE=2 ;;
        -v)           SANDY_VERBOSE=1 ;;
        *)            REMAINING_ARGS+=("$1") ;;
    esac
    shift
done
set -- ${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}

# --- Check for sandy updates (non-blocking, cached 24h) ---
sandy_check_update

# --- Preflight checks ---
if ! command -v docker &>/dev/null; then
    error "Docker is not installed or not in PATH."
    exit 1
fi

# --- Build file generators ---
generate_dockerfile_base() {
    cat > "$SANDY_HOME/Dockerfile.base.new" <<'DOCKERFILE_BASE'
FROM debian:bookworm-slim

# System tools + C/C++ toolchain
RUN apt-get update && apt-get install -y \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        git \
        git-lfs \
        gosu \
        jq \
        less \
        libcairo2 \
        libgdk-pixbuf-2.0-0 \
        libpango1.0-0 \
        libssl-dev \
        ncurses-term \
        openssh-client \
        pkg-config \
        python3 \
        python3-pip \
        python3-venv \
        ripgrep \
        socat \
        tmux \
        unzip \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Go (arch-aware)
ARG GO_VERSION=1.24.1
RUN ARCH="$(dpkg --print-architecture)" \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${ARCH}.tar.gz" \
       | tar -C /usr/local -xz

# Rust stable (system-wide)
ENV RUSTUP_HOME=/usr/local/rustup
ENV CARGO_HOME=/usr/local/cargo
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --no-modify-path --default-toolchain stable \
    && chmod -R a+rX /usr/local/rustup /usr/local/cargo

# Bun
RUN curl -fsSL https://bun.sh/install | BUN_INSTALL=/usr/local bash

# uv — fast Python package/version manager
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_UNMANAGED_INSTALL=/usr/local/bin sh

# User
RUN useradd -m -s /bin/bash -u 1001 claude

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PATH="/home/claude/.local/bin:/usr/local/cargo/bin:/usr/local/go/bin:$PATH"
DOCKERFILE_BASE
}

generate_dockerfile() {
    cat > "$SANDY_HOME/Dockerfile.new" <<DOCKERFILE
FROM ${BASE_IMAGE_NAME}
# Install Claude Code natively. The installer places files under
# /home/claude/.local/{bin,share}/claude.  Since /home/claude gets a
# tmpfs overlay at runtime, we relocate the binary to /usr/local/bin
# and the data directory to /opt/claude-code.  The entrypoint symlinks
# them back into the expected paths.
RUN HOME=/home/claude su -s /bin/bash claude -c "curl -fsSL https://claude.ai/install.sh | bash" \\
 && cp -L /home/claude/.local/bin/claude /usr/local/bin/claude \\
 && mv /home/claude/.local/share/claude /opt/claude-code \\
 && { /usr/local/bin/claude --version 2>/dev/null | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' > /opt/claude-code/.version || true; }
# synthkit dependencies (WeasyPrint needs pango/cairo/gdk-pixbuf)
RUN apt-get update && apt-get install -y --no-install-recommends \\
    libpango1.0-dev libcairo2-dev libgdk-pixbuf2.0-dev \\
 && rm -rf /var/lib/apt/lists/*
RUN UV_TOOL_DIR=/opt/uv-tools UV_TOOL_BIN_DIR=/usr/local/bin uv tool install --python-preference system synthkit
COPY tmux.conf /etc/tmux.conf
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY user-setup.sh /usr/local/bin/user-setup.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/user-setup.sh
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
DOCKERFILE
}

generate_dockerfile_gemini() {
    cat > "$SANDY_HOME/Dockerfile.gemini.new" <<DOCKERFILE
FROM ${BASE_IMAGE_NAME}
# Install Gemini CLI as a global npm package. Unlike Claude Code, no binary
# relocation is needed — npm -g places \`gemini\` directly into PATH.
RUN npm install -g @google/gemini-cli \\
 && mkdir -p /opt/gemini-cli \\
 && { npm list -g @google/gemini-cli --depth=0 2>/dev/null \\
      | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' > /opt/gemini-cli/.version || true; }
# synthkit dependencies (WeasyPrint needs pango/cairo/gdk-pixbuf)
RUN apt-get update && apt-get install -y --no-install-recommends \\
    libpango1.0-dev libcairo2-dev libgdk-pixbuf2.0-dev \\
 && rm -rf /var/lib/apt/lists/*
RUN UV_TOOL_DIR=/opt/uv-tools UV_TOOL_BIN_DIR=/usr/local/bin uv tool install --python-preference system synthkit
# osv-scanner: required by the gemini-cli-security extension (pre-built binary, not go install)
RUN curl -fsSL https://github.com/google/osv-scanner/releases/latest/download/osv-scanner_linux_amd64 \\
      -o /usr/local/bin/osv-scanner \\
 && chmod +x /usr/local/bin/osv-scanner
COPY tmux.conf /etc/tmux.conf
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY user-setup.sh /usr/local/bin/user-setup.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/user-setup.sh
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
DOCKERFILE
}

generate_dockerfile_codex() {
    cat > "$SANDY_HOME/Dockerfile.codex.new" <<DOCKERFILE
FROM ${BASE_IMAGE_NAME}
# Install Codex CLI as a global npm package. The @openai/codex package ships
# a prebuilt Rust binary per platform; Node is only the installation vehicle.
RUN npm install -g @openai/codex \\
 && mkdir -p /opt/codex \\
 && { codex --version 2>/dev/null | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' > /opt/codex/.version || true; }
# synthkit dependencies (WeasyPrint needs pango/cairo/gdk-pixbuf)
RUN apt-get update && apt-get install -y --no-install-recommends \\
    libpango1.0-dev libcairo2-dev libgdk-pixbuf2.0-dev \\
