#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# sandy — an isolated sibling for your coding agents
#
# Runs Claude Code, Gemini CLI, or Codex CLI (or any combo, side-by-side) in a Docker container with:
#   - Filesystem: read/write limited to current directory only
#   - Network: public internet only, NO LAN access
#   - Resources: capped CPU and memory
#   - Per-project sandbox: isolated ~/.claude per working directory
#
# Usage:
#   sandy                         Resume last session (or start new)
#   sandy --new                   Start a fresh session
#   sandy -p "prompt"             One-shot prompt
#   sandy --agent claude,gemini   Override agent selection for this run
# =============================================================================

SANDY_VERSION="1.2.2-dev"
SANDY_COMMIT=""  # baked in by install.sh; empty = detect from git at runtime

# Schema contract version for --print-schema / --print-state / --validate-config.
# Bumped when existing fields change semantics; additive changes do not bump.
# See SPEC_INTROSPECTION.md in the repo for the contract.
SANDY_SCHEMA_VERSION=1

# --- Config tier lists (single source of truth for _load_sandy_config,
# --- --validate-config, and --print-schema) ---
#
# SANDY_PRIVILEGED_KEYS: settable only from $SANDY_HOME/{config,.secrets} or
#   the environment. From a workspace .sandy/config they are quarantined and
#   require explicit per-workspace approval (see _resolve_passive_privileged_approval).
SANDY_PRIVILEGED_KEYS=(
    SANDY_SSH
    SANDY_SKIP_PERMISSIONS
    SANDY_ALLOW_NO_ISOLATION
    SANDY_ALLOW_LAN_HOSTS
    SANDY_LOCAL_LLM_HOST
    SANDY_ALLOW_HOSTS
    SANDY_EXTRA_ENV
    SANDY_AGENT_ARGS
    ANTHROPIC_API_KEY
    CLAUDE_CODE_OAUTH_TOKEN
    GEMINI_API_KEY
    OPENAI_API_KEY
    GOOGLE_API_KEY
    CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS
    SANDY_SCREENSHOT_DIR
    SANDY_GEMINI_EXTENSIONS
    TELEGRAM_BOT_TOKEN
    TELEGRAM_ALLOWED_SENDERS
    DISCORD_BOT_TOKEN
    DISCORD_ALLOWED_SENDERS
)

# SANDY_PASSIVE_KEYS: allowed from a workspace .sandy/config (checked into
#   version control) as well as host config and the environment. MOST have no
#   security-boundary impact. The exceptions are VALUE-AWARE (see
#   _sandy_passive_value_privileged below): a few keys are passive for values
#   that STRENGTHEN — or leave unchanged — the sandbox's isolation, but a value
#   that WEAKENS it (turning the egress proxy off, downgrading strict, dropping
#   workflow protection) is quarantined to the per-workspace approval path just
#   like a privileged key. This stops a committed .sandy/config from silently
#   lowering isolation (threat-model adversary #2) while keeping "a repo may make
#   the sandbox tighter, never looser" frictionless.
SANDY_PASSIVE_KEYS=(
    SANDY_AGENT
    SANDY_MODEL
    SANDY_CPUS
    SANDY_MEM
    SANDY_GPU
    SANDY_SKILL_PACKS
    SANDY_CHANNELS
    SANDY_CHANNEL_TARGET_PANE
    SANDY_VERBOSE
    SANDY_VENV_OVERLAY
    SANDY_EGRESS_PROXY
    SANDY_EGRESS_NO_ISOLATION
    SANDY_EGRESS_STRICT
    SANDY_ALLOW_WORKFLOW_EDIT
    CLAUDE_CODE_MAX_OUTPUT_TOKENS
    GEMINI_MODEL
    SANDY_GEMINI_AUTH
    GOOGLE_CLOUD_PROJECT
    GOOGLE_CLOUD_LOCATION
    GOOGLE_GENAI_USE_VERTEXAI
    CODEX_MODEL
    SANDY_CODEX_AUTH
    OPENCODE_MODEL
    SANDY_OPENCODE_AUTH
)

# SANDY_ENV_ONLY_KEYS: honored only when set in the process environment.
#   NOT readable from any config file — these are CI / debug escape hatches
#   that a committed .sandy/config must never be able to flip on.
SANDY_ENV_ONLY_KEYS=(
    SANDY_AUTO_APPROVE_PRIVILEGED
    SANDY_DEBUG_CLEANUP
)

# Value-aware privileged classification. A handful of passive keys are safe to
# set from a workspace .sandy/config for values that STRENGTHEN or don't change
# isolation, but must go through the per-workspace approval gate for a value
# that WEAKENS it — otherwise a committed config could silently lower the
# sandbox's protection with no prompt (threat-model adversary #2), which is
# exactly what the privileged tier exists to prevent. Returns 0 (treat as
# privileged, i.e. approval-gated) when key=value is a weakening from a passive
# source; 1 otherwise. Consulted ONLY for the passive (workspace) tier — host
# config and env are trusted and set these directly.
_sandy_passive_value_privileged() {
    case "$1" in
        SANDY_EGRESS_NO_ISOLATION) [ "$2" = "1" ] && return 0 ;;  # proxy OFF
        SANDY_EGRESS_STRICT)       [ "$2" = "0" ] && return 0 ;;  # strict -> permissive downgrade
        SANDY_EGRESS_PROXY)        [ "$2" = "0" ] && return 0 ;;  # deprecated alias: =0 == proxy off
        SANDY_ALLOW_WORKFLOW_EDIT) [ "$2" = "1" ] && return 0 ;;  # drops .github/workflows protection
    esac
    return 1
}

# Return 0 if $1 equals any of the remaining positional args.
_key_in_list() {
    local target="$1"; shift
    local k
    for k in "$@"; do [ "$k" = "$target" ] && return 0; done
    return 1
}

SANDY_HOME="${SANDY_HOME:-$HOME/.sandy}"
# Validate SANDY_HOME — reject shell metacharacters
if [[ "$SANDY_HOME" =~ [\;\$\`\&\|\<\>] ]]; then
    echo "[sandy] ERROR: Invalid SANDY_HOME: contains shell metacharacters" >&2
    exit 1
fi
# Empty fixtures for bind-mount-as-ro fallback targets (S1.0). Created eagerly
# here — before any fast-path flag handlers (--print-protected-paths, --help,
# --version) return — so that every sandy invocation guarantees the invariant.
# Idempotent; zero cost if already present. Suppressed under `|| true` because
# the fixtures are only needed for the real-launch path; introspection
# handlers (--print-schema / --print-state / --validate-config) don't mount
# anything and must not abort just because the home dir is read-only
# (e.g. a CI environment inspecting an installed sandy).
mkdir -p "$SANDY_HOME" 2>/dev/null || true
[ -f "$SANDY_HOME/.empty-ro-file" ] || : > "$SANDY_HOME/.empty-ro-file" 2>/dev/null || true
[ -d "$SANDY_HOME/.empty-ro-dir" ]  || mkdir -p "$SANDY_HOME/.empty-ro-dir" 2>/dev/null || true
BASE_IMAGE_NAME="sandy-base"
# IMAGE_NAME is set dynamically after config load, based on SANDY_AGENT
IMAGE_NAME=""
# Per-instance network names keyed on PID to avoid concurrent iptables races
BRIDGE_NAME="br-sdy-$$"
NETWORK_NAME="sandy_net_$$"
# Platform — detected up-front so early functions (e.g. the egress-proxy network
# setup, which runs well before the legacy isolation block) can branch on it.
OS="$(uname -s)"

# --- Skill pack registry ---
# To add a new pack: add entries to both arrays at the same index.
# Repos must be GitHub repos (used for tarball download and release checks).
# Versions are resolved dynamically from GitHub releases — SKILL_PACK_VERSIONS
# is only the initial fallback if no cached or remote version is available.
SKILL_PACK_NAMES=(gstack)
SKILL_PACK_REPOS=("https://github.com/garrytan/gstack")
SKILL_PACK_VERSIONS=("main")
# Release tag prefix per pack (tags matching this prefix are checked for updates)
SKILL_PACK_TAG_PREFIXES=("")

skill_pack_lookup() {
    local pack="$1" field="$2"
    local i
    for i in "${!SKILL_PACK_NAMES[@]}"; do
        if [ "${SKILL_PACK_NAMES[$i]}" = "$pack" ]; then
            case "$field" in
                repo) echo "${SKILL_PACK_REPOS[$i]}" ;;
                version) echo "${SKILL_PACK_VERSIONS[$i]}" ;;
                tag_prefix) echo "${SKILL_PACK_TAG_PREFIXES[$i]}" ;;
            esac
            return 0
        fi
    done
    return 1
}

# Check GitHub for the latest release tag matching a prefix for a skill pack.
# Falls back to the latest commit SHA on the default branch if no releases exist.
# Returns the tag name, commit SHA, or empty string on failure.
skill_pack_latest_release() {
    local pack="$1"
    local repo tag_prefix owner_repo
    repo="$(skill_pack_lookup "$pack" repo)" || return 1
    tag_prefix="$(skill_pack_lookup "$pack" tag_prefix)" || return 1
    owner_repo="$(echo "$repo" | sed 's|https://github.com/||')"

    # Try releases first (if tag prefix is set)
    if [ -n "$tag_prefix" ]; then
        local release_tag
        release_tag="$(curl -fsSL --max-time 5 \
            "https://api.github.com/repos/${owner_repo}/releases" 2>/dev/null \
        | node -e "
            let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
                try {
                    const releases = JSON.parse(d);
                    const match = releases.find(r => !r.draft && !r.prerelease && r.tag_name.startsWith('${tag_prefix}'));
                    if (match) console.log(match.tag_name);
                } catch(e) {}
            })
        " 2>/dev/null || true)"
        if [ -n "$release_tag" ]; then
            echo "$release_tag"
            return 0
        fi
    fi

    # Fall back to latest commit SHA on default branch
    curl -fsSL --max-time 5 \
        "https://api.github.com/repos/${owner_repo}/commits?per_page=1" 2>/dev/null \
    | node -e "
        let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
            try {
                const commits = JSON.parse(d);
                if (commits[0]) console.log(commits[0].sha.slice(0,12));
            } catch(e) {}
        })
    " 2>/dev/null || true
}

# Resolve the effective version for a skill pack. Checks GitHub for the latest
# release, caches the result, falls back to cache then hardcoded default.
# Updates SKILL_PACK_VERSIONS in-place so downstream code sees the resolved version.
skill_pack_resolve_versions() {
    local packs="$1"
    mkdir -p "$SANDY_HOME"
    local pack
    IFS=',' read -ra _sp_resolve <<< "$packs"
    for pack in "${_sp_resolve[@]}"; do
        pack="$(echo "$pack" | tr -d '[:space:]')"
        local cache_file="$SANDY_HOME/.skill_version_${pack}"
        local cached="" latest="" resolved=""

        # Read cached version
        [ -f "$cache_file" ] && cached="$(cat "$cache_file")"

        # Check GitHub for latest release
        latest="$(skill_pack_latest_release "$pack")"

        if [ -n "$latest" ]; then
            resolved="$latest"
            if [ "$latest" != "$cached" ]; then
                [ -n "$cached" ] && info "Skill pack update: $pack $cached → $latest"
                echo "$latest" > "$cache_file"
            fi
        elif [ -n "$cached" ]; then
            resolved="$cached"
        else
            # Fall back to hardcoded default
            resolved="$(skill_pack_lookup "$pack" version)" || true
            [ -n "$resolved" ] && echo "$resolved" > "$cache_file"
        fi

        # Update the in-memory version array
        if [ -n "$resolved" ]; then
            local i
            for i in "${!SKILL_PACK_NAMES[@]}"; do
                if [ "${SKILL_PACK_NAMES[$i]}" = "$pack" ]; then
                    SKILL_PACK_VERSIONS[$i]="$resolved"
                fi
            done
        fi
    done
}

# --- Colors (disabled when not a terminal) ---
# The daemon supervisor (SANDY_DAEMON_SUPERVISOR=1) runs under nohup with no
# TTY, but its streamed log IS shown to the --start client — so force colors on
# there too, otherwise every [sandy] line renders white in the daemon log (#51).
if [ -t 1 ] || [ "${SANDY_DAEMON_SUPERVISOR:-0}" = "1" ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' NC=''
fi

info()  { echo -e "${GREEN}[sandy]${NC} $*"; }
warn()  { echo -e "${YELLOW}[sandy]${NC} $*"; }
error() { echo -e "${RED}[sandy]${NC} $*" >&2; }
sha256() { shasum -a 256 2>/dev/null || sha256sum; }

# Numeric semver compare. _ver_lt A B → 0 if A < B (strips -dev/-rc suffix).
# Portable across macOS bash 3.2 and Linux without relying on `sort -V`.
_ver_lt() {
    local a="${1%%-*}" b="${2%%-*}"
    local IFS=.
    local -a A B
    # shellcheck disable=SC2206
    A=($a); B=($b)
    local i ai bi
    for i in 0 1 2; do
        ai="${A[i]:-0}"; bi="${B[i]:-0}"
        # Guard against non-numeric junk
        [[ "$ai" =~ ^[0-9]+$ ]] || ai=0
        [[ "$bi" =~ ^[0-9]+$ ]] || bi=0
        if [ "$ai" -lt "$bi" ]; then return 0; fi
        if [ "$ai" -gt "$bi" ]; then return 1; fi
    done
    return 1
}

# Should `cur` be nagged to update to `latest`? True when `latest` has higher
# release precedence: a greater numeric core (via _ver_lt), OR an equal core
# where `cur` is a pre-release (-rcN/-dev) and `latest` is either the final
# (no suffix) or a higher pre-release. Mirrors semver: 1.0.0-rc1 < 1.0.0 and
# 1.0.0-rc1 < 1.0.0-rc2. Without this, an rc/-dev build is never told about
# its own final release (equal cores → _ver_lt is false), so rc soaks never
# converge on the final.
_ver_should_update() {
    local cur="$1" latest="$2"
    if _ver_lt "$cur" "$latest"; then return 0; fi
    if _ver_lt "$latest" "$cur"; then return 1; fi
    # Equal numeric cores — compare pre-release suffixes.
    local cs ls
    cs="${cur#*-}";    [ "$cs" = "$cur" ]    && cs=""   # suffix after first '-' ('' if none)
    ls="${latest#*-}"; [ "$ls" = "$latest" ] && ls=""
    if [ -z "$cs" ]; then return 1; fi          # cur is final; equal-core latest is never newer
    if [ -z "$ls" ]; then return 0; fi          # cur pre-release, latest final → nag
    # Both pre-release, same core: nag only if latest's suffix sorts after cur's
    # (lexical — fine for rc1..rc9; rcN≥10 is not a realistic sandy cadence).
    [ "$ls" != "$cs" ] && [[ "$ls" > "$cs" ]]
}

# Sandboxes created before this version pre-date the workspace mount path
# change (c99eb97, v0.7.10) from /workspace → /home/claude/<rel>. Any cached
# absolute paths inside the sandbox (venv pyvenv.cfg, .pth files, editable
# installs, Python package caches) reference /workspace/... and break
# silently inside the new mount layout. Bump this when introducing further
# sandbox-incompatible changes.
SANDY_SANDBOX_MIN_COMPAT="0.7.10"

# Classify a sandbox's recorded .sandy_created_version against the compat floor.
# Pure (no side effects, no exit) so it can be unit-tested directly. Echoes one of:
#   ok          — created at/after the floor; safe to use
#   below-floor — created before the floor; the current layout would break it
#   unknown     — no marker / empty (pre-0.10.1 sandbox, version untracked)
#   invalid     — marker present but not a parseable version (corrupt/copied-in)
# The 1.x forward-compat promise is enforced by the caller: 'below-floor' is a
# hard refuse-to-launch; 'unknown'/'invalid' warn (we can't prove they're below
# the floor); 'ok' is silent. The floor (SANDY_SANDBOX_MIN_COMPAT) is read from
# the global so the launch path and the tests share one source of truth.
_sandbox_compat_classify() {
    local ver="$1"
    if [ -z "$ver" ] || [ "$ver" = "unknown" ]; then echo "unknown"; return; fi
    if ! [[ "$ver" =~ ^[0-9]+\.[0-9]+\.[0-9]+([-.].*)?$ ]]; then echo "invalid"; return; fi
    if _ver_lt "$ver" "$SANDY_SANDBOX_MIN_COMPAT"; then echo "below-floor"; else echo "ok"; fi
}

SANDY_REPO_URL="https://raw.githubusercontent.com/rappdw/sandy/main/sandy"
SANDY_API_URL="https://api.github.com/repos/rappdw/sandy/releases/latest"

# Self-update: download latest sandy from GitHub and replace the running script
sandy_self_update() {
    local script_path
    script_path="$(readlink -f "${BASH_SOURCE[0]}")"
    local tmp
    tmp="$(mktemp)"
    info "Downloading latest sandy..."
    if ! curl -fsSL "$SANDY_REPO_URL" -o "$tmp"; then
        error "Failed to download update."
        rm -f "$tmp"
        exit 1
    fi
    local new_ver
    new_ver="$(grep -m1 '^SANDY_VERSION=' "$tmp" | cut -d'"' -f2)"
    if [ -z "$new_ver" ]; then
        error "Downloaded file does not look like sandy."
        rm -f "$tmp"
        exit 1
    fi
    if [ "$new_ver" = "$SANDY_VERSION" ]; then
        info "Already on latest version ($SANDY_VERSION)."
        rm -f "$tmp"
        exit 0
    fi
    chmod +x "$tmp"
    mv "$tmp" "$script_path"
    info "Updated sandy: $SANDY_VERSION → $new_ver"
    # Clear update cache
    rm -f "$SANDY_HOME/.update_check"
}

# Check for newer version (cached, non-blocking)
sandy_check_update() {
    mkdir -p "$SANDY_HOME"
    local cache="$SANDY_HOME/.update_check"
    local now
    now=$(date +%s)
    if [ -f "$cache" ]; then
        local cached_time cached_ver
        read -r cached_time cached_ver < "$cache" 2>/dev/null || true
        if [ -n "$cached_time" ] && (( now - cached_time < 86400 )); then
            if [ -n "$cached_ver" ] && _ver_should_update "$SANDY_VERSION" "${cached_ver#v}"; then
                warn "Update available: $SANDY_VERSION → ${cached_ver#v}. Run 'sandy --upgrade' to update."
            fi
            return
        fi
    fi
    local latest
    latest="$(curl -fsSL --max-time 3 "$SANDY_API_URL" 2>/dev/null \
        | grep -o '"tag_name":"[^"]*"' | cut -d'"' -f4)" || true
    if [ -n "$latest" ]; then
        echo "$now $latest" > "$cache"
        # _ver_should_update, not string inequality: a plain != would nag
        # NEWER-than-latest versions (an rc/-dev tree vs the latest stable
        # release) to "update" — a downgrade prompt. _ver_should_update is
        # precedence-aware: it stays silent on a downgrade but DOES nag an rc
        # about its own final (equal cores, cur pre-release, latest final).
        if _ver_should_update "$SANDY_VERSION" "${latest#v}"; then
            warn "Update available: $SANDY_VERSION → ${latest#v}. Run 'sandy --upgrade' to update."
        fi
    fi
}

# Merge JSON keys into a file. Usage: json_merge <file> '{"key":"value"}'
json_merge() {
    command -v node &>/dev/null || return 0
    node -e '
        const fs=require("fs"), f=process.argv[1], m=JSON.parse(process.argv[2]);
        let s;
        try { s=JSON.parse(fs.readFileSync(f,"utf8")); }
        catch(e) { console.error("[sandy] WARN: could not parse "+f+", starting fresh"); s={}; }
        Object.assign(s,m);
        fs.writeFileSync(f, JSON.stringify(s,null,2)+"\n");
    ' "$1" "$2"
}

# --- Version ---
sandy_full_version() {
    local ver="$SANDY_VERSION"
    local hash="${SANDY_COMMIT}"
    if [ -z "$hash" ]; then
        # Try to detect from git if running from a repo checkout
        local script_dir
        script_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
        hash="$(git -C "$script_dir" rev-parse --short HEAD 2>/dev/null)" || true
    fi
    [ -n "$hash" ] && ver="$ver-$hash"
    echo "$ver"
}
if [[ "${1:-}" == "-v" || "${1:-}" == "--version" ]]; then
    echo "sandy $(sandy_full_version)"
    exit 0
fi

